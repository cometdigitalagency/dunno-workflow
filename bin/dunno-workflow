#!/bin/bash
# =============================================================================
# dunno-workflow — Launch Claude Code agent team in iTerm2 split panes
#
# Reads workflow.yaml from the current directory to configure agents, events,
# ticket sources, and layout. Generates prompts, launchers, and iTerm2 panes.
#
# Install: brew install cometdigitalagency/dunno/dunno-workflow
# Usage:   dunno-workflow start [--debug] [--test] [--issue N]
# =============================================================================

set -e

VERSION="0.3.8"

# ==================== Commands ====================

show_help() {
    echo "dunno-workflow v${VERSION} — Declarative Claude Code agent teams"
    echo ""
    echo "Usage:"
    echo "  dunno-workflow init               Create workflow.yaml in current directory"
    echo "  dunno-workflow start [options]     Launch agent team in iTerm2"
    echo "  dunno-workflow validate            Validate workflow.yaml (schema + event graph)"
    echo "  dunno-workflow analyze [options]   Analyze logs for agent failures, create issues"
    echo "  dunno-workflow stop                Stop all running agent sessions"
    echo "  dunno-workflow context [list|clear] Inspect or reset shared agent context"
    echo "  dunno-workflow version             Show version"
    echo ""
    echo "Global flags:"
    echo "  --help, -h          Show this help"
    echo "  --version, -v       Show version"
    echo ""
    echo "Start options:"
    echo "  --issue, -i <num>   Ticket number to work on"
    echo "  --test, -t          Test mode — mock issue, no ticket source needed"
    echo "  --e2e, -e           End-to-end test — small ticket through full PM→architect→workers→QA flow"
    echo "  --debug, -d         Enable LOGS pane with filtered session logging"
}

cmd_version() { echo "dunno-workflow v${VERSION}"; }

get_template_dir() {
    local script_path
    script_path="$(cd "$(dirname "$0")" && pwd)"
    if [ -d "$script_path/../share/dunno-workflow/templates" ]; then
        echo "$script_path/../share/dunno-workflow/templates"; return
    fi
    if [ -d "$script_path/../templates" ]; then
        echo "$script_path/../templates"; return
    fi
    echo "ERROR: Could not find template directory" >&2; exit 1
}

cmd_init() {
    local upgrade=false
    [ "${1:-}" = "--upgrade" ] && upgrade=true

    if [ "$upgrade" = true ]; then
        if [ ! -f "workflow.yaml" ]; then
            echo "No workflow.yaml found. Run 'dunno-workflow init' first."; exit 1
        fi
        if ! command -v yq &>/dev/null; then
            echo "ERROR: yq is required for upgrade. brew install yq"; exit 1
        fi

        local changes=0

        # Add provider field to agents that don't have it
        local agent_names
        agent_names=$(yq '.agents | keys | .[]' workflow.yaml)
        for agent in $agent_names; do
            local has_provider
            has_provider=$(yq ".agents.$agent.provider // \"\"" workflow.yaml)
            if [ -z "$has_provider" ]; then
                yq -i ".agents.$agent.provider = \"claude\"" workflow.yaml
                echo "  + Added provider: claude to agent '$agent'"
                changes=$((changes + 1))
            fi
        done

        # Add memory section if missing
        local has_memory
        has_memory=$(yq '.memory // ""' workflow.yaml)
        if [ -z "$has_memory" ] || [ "$has_memory" = "null" ]; then
            yq -i '.memory.enabled = true' workflow.yaml
            echo "  + Added memory.enabled: true"
            changes=$((changes + 1))
        fi

        # Add monitoring section if missing
        local has_monitoring
        has_monitoring=$(yq '.monitoring // ""' workflow.yaml)
        if [ -z "$has_monitoring" ] || [ "$has_monitoring" = "null" ]; then
            yq -i '.monitoring.webhook_url = "http://localhost:3000"' workflow.yaml
            echo "  + Added monitoring.webhook_url"
            changes=$((changes + 1))
        fi

        if [ "$changes" -eq 0 ]; then
            echo "workflow.yaml is already up to date. No changes needed."
        else
            echo "Upgraded workflow.yaml ($changes change(s)). Run 'dunno-workflow validate' to verify."
        fi
        return 0
    fi

    if [ -f "workflow.yaml" ]; then
        echo "workflow.yaml already exists."
        echo "  Use 'dunno-workflow init --upgrade' to add new fields without losing your config."
        exit 1
    fi
    local tpl; tpl="$(get_template_dir)"
    cp "$tpl/workflow.yaml" ./workflow.yaml
    mkdir -p tickets
    if [ -f "$tpl/tickets/TEMPLATE.md" ]; then cp "$tpl/tickets/TEMPLATE.md" ./tickets/TEMPLATE.md; fi
    echo "Created workflow.yaml and tickets/TEMPLATE.md"
    echo "Edit workflow.yaml to configure your agent team, then run: dunno-workflow start"
}

# ==================== Validation Helpers ====================

# Global state for graph validation (bash 3.2 compatible — no associative arrays)
_v_all_agents=""
_v_defined_events=""
_v_agent_sends=""      # newline-delimited "agent:evt1 evt2 ..."
_v_agent_receives=""   # newline-delimited "agent:evt1 evt2 ..."
_v_worker_agents=""
_v_interactive_agent=""

_v_extract_data() {
    _v_all_agents=$(yq '.agents | keys | .[]' workflow.yaml)
    _v_defined_events=$(yq '.events // {} | keys | .[]' workflow.yaml 2>/dev/null)
    _v_agent_sends=""
    _v_agent_receives=""
    _v_worker_agents=""
    _v_interactive_agent=""
    for agent in $_v_all_agents; do
        local s r
        s=$(yq ".agents.$agent.sends // [] | .[]" workflow.yaml 2>/dev/null | tr '\n' ' ')
        r=$(yq ".agents.$agent.receives // [] | .[]" workflow.yaml 2>/dev/null | tr '\n' ' ')
        _v_agent_sends="${_v_agent_sends}${agent}:${s}
"
        _v_agent_receives="${_v_agent_receives}${agent}:${r}
"
        local interactive auto_start
        interactive=$(yq ".agents.$agent.interactive // false" workflow.yaml)
        auto_start=$(yq ".agents.$agent.auto_start // false" workflow.yaml)
        [ "$interactive" = "true" ] && _v_interactive_agent="$agent"
        if [ "$interactive" != "true" ] && [ "$auto_start" != "true" ]; then
            _v_worker_agents="$_v_worker_agents $agent"
        fi
    done
}

_v_agent_sends_list() {
    echo "$_v_agent_sends" | grep "^${1}:" | sed "s/^${1}://" | tr -s ' ' | sed 's/^ //;s/ $//'
}

_v_agent_receives_list() {
    echo "$_v_agent_receives" | grep "^${1}:" | sed "s/^${1}://" | tr -s ' ' | sed 's/^ //;s/ $//'
}

_v_sends_contains() {
    local agent="$1" evt="$2"
    local line
    line=$(echo "$_v_agent_sends" | grep "^${agent}:" || true)
    local events=" ${line#*:}"
    [[ " $events " == *" $evt "* ]] && return 0 || return 1
}

_v_receives_contains() {
    local agent="$1" evt="$2"
    local line
    line=$(echo "$_v_agent_receives" | grep "^${agent}:" || true)
    local events=" ${line#*:}"
    [[ " $events " == *" $evt "* ]] && return 0 || return 1
}

_v_expand_alias() {
    local input="$1"
    local result=""
    local IFS='|'
    for part in $input; do
        part=$(echo "$part" | tr -d ' ')
        if [ "$part" = "workers" ]; then
            result="$result $_v_worker_agents"
        else
            result="$result $part"
        fi
    done
    echo "$result" | tr -s ' ' | sed 's/^ //;s/ $//'
}

# ==================== Graph Checks ====================

_v_check_missing_events() {
    local errors_ref=$1 agent evt
    for agent in $_v_all_agents; do
        for evt in $(_v_agent_sends_list "$agent"); do
            [ -z "$evt" ] && continue
            if ! echo "$_v_defined_events" | grep -qx "$evt" 2>/dev/null; then
                echo "ERROR: Agent '$agent' sends event '$evt' not defined in events:"
                eval "(($errors_ref++))" || true || true
            fi
        done
        for evt in $(_v_agent_receives_list "$agent"); do
            [ -z "$evt" ] && continue
            if ! echo "$_v_defined_events" | grep -qx "$evt" 2>/dev/null; then
                echo "ERROR: Agent '$agent' receives event '$evt' not defined in events:"
                eval "(($errors_ref++))" || true || true
            fi
        done
    done
}

_v_check_orphaned_events() {
    local warnings_ref=$1 evt agent found
    for evt in $_v_defined_events; do
        found=false
        for agent in $_v_all_agents; do
            if _v_sends_contains "$agent" "$evt" || _v_receives_contains "$agent" "$evt"; then
                found=true; break
            fi
        done
        if [ "$found" = false ]; then
            echo "WARNING: Event '$evt' is defined but no agent references it"
            eval "(($warnings_ref++))" || true
        fi
    done
}

_v_check_dead_agents() {
    local errors_ref=$1 agent evt other has_sender
    for agent in $_v_all_agents; do
        for evt in $(_v_agent_receives_list "$agent"); do
            [ -z "$evt" ] && continue
            has_sender=false
            for other in $_v_all_agents; do
                [ "$other" = "$agent" ] && continue
                if _v_sends_contains "$other" "$evt"; then has_sender=true; break; fi
            done
            if [ "$has_sender" = false ]; then
                echo "ERROR: Agent '$agent' receives '$evt' but no other agent sends it (dead agent)"
                eval "(($errors_ref++))" || true
            fi
        done
    done
}

_v_check_unused_sends() {
    local warnings_ref=$1 agent evt other has_receiver
    for agent in $_v_all_agents; do
        for evt in $(_v_agent_sends_list "$agent"); do
            [ -z "$evt" ] && continue
            has_receiver=false
            for other in $_v_all_agents; do
                [ "$other" = "$agent" ] && continue
                if _v_receives_contains "$other" "$evt"; then has_receiver=true; break; fi
            done
            if [ "$has_receiver" = false ]; then
                echo "WARNING: Agent '$agent' sends '$evt' but no other agent receives it"
                eval "(($warnings_ref++))" || true
            fi
        done
    done
}

_v_check_direction_consistency() {
    local errors_ref=$1 evt dir sender receivers_str s r
    for evt in $_v_defined_events; do
        dir=$(yq ".events.$evt.direction // \"\"" workflow.yaml)
        [ -z "$dir" ] || [ "$dir" = '""' ] && continue
        sender="${dir%% ->*}"
        receivers_str="${dir#*-> }"
        sender=$(echo "$sender" | tr -d ' ')
        local expected_senders expected_receivers
        expected_senders=$(_v_expand_alias "$sender")
        expected_receivers=$(_v_expand_alias "$receivers_str")
        for s in $expected_senders; do
            if ! _v_sends_contains "$s" "$evt"; then
                echo "ERROR: Direction says '$s' sends '$evt' but agent config disagrees"
                eval "(($errors_ref++))" || true
            fi
        done
        for r in $expected_receivers; do
            if ! _v_receives_contains "$r" "$evt"; then
                echo "ERROR: Direction says '$r' receives '$evt' but agent config disagrees"
                eval "(($errors_ref++))" || true
            fi
        done
    done
}

_v_check_event_loops() {
    local warnings_ref=$1 evt s r
    for evt in $_v_defined_events; do
        local senders="" receivers=""
        for agent in $_v_all_agents; do
            if _v_sends_contains "$agent" "$evt"; then senders="$senders $agent"; fi
            if _v_receives_contains "$agent" "$evt"; then receivers="$receivers $agent"; fi
        done
        for s in $senders; do
            for r in $receivers; do
                [ "$s" = "$r" ] && continue
                if _v_receives_contains "$s" "$evt" && _v_sends_contains "$r" "$evt"; then
                    echo "WARNING: Event '$evt' has a cycle: '$s' and '$r' both send and receive it"
                    eval "(($warnings_ref++))" || true
                    return 0
                fi
            done
        done
    done
}

_v_check_unreachable_agents() {
    local errors_ref=$1
    [ -z "$_v_interactive_agent" ] && return 0
    local visited="$_v_interactive_agent"
    local queue="$_v_interactive_agent"
    while [ -n "$queue" ]; do
        local current="${queue%% *}"
        if [ "$current" = "$queue" ]; then queue=""; else queue="${queue#* }"; fi
        for evt in $(_v_agent_sends_list "$current"); do
            [ -z "$evt" ] && continue
            for other in $_v_all_agents; do
                _v_receives_contains "$other" "$evt" || continue
                if ! echo " $visited " | grep -q " $other "; then
                    visited="$visited $other"
                    queue="${queue:+$queue }$other"
                fi
            done
        done
    done
    for agent in $_v_all_agents; do
        [ "$agent" = "$_v_interactive_agent" ] && continue
        if ! echo " $visited " | grep -q " $agent "; then
            echo "ERROR: Agent '$agent' is unreachable from interactive agent '$_v_interactive_agent'"
            eval "(($errors_ref++))" || true
        fi
    done
}

_v_check_self_loops() {
    local errors_ref=$1 agent evt
    for agent in $_v_all_agents; do
        for evt in $(_v_agent_sends_list "$agent"); do
            [ -z "$evt" ] && continue
            if _v_receives_contains "$agent" "$evt"; then
                echo "ERROR: Agent '$agent' both sends and receives event '$evt' (self-loop)"
                eval "(($errors_ref++))" || true
            fi
        done
    done
}

_v_render_event_flow() {
    echo ""
    echo "  Event Flow:"
    for evt in $_v_defined_events; do
        local senders="" receivers="" agent
        for agent in $_v_all_agents; do
            if _v_sends_contains "$agent" "$evt"; then senders="${senders:+$senders, }$agent"; fi
            if _v_receives_contains "$agent" "$evt"; then receivers="${receivers:+$receivers, }$agent"; fi
        done
        [ -z "$senders" ] && senders="(none)"
        [ -z "$receivers" ] && receivers="(none)"
        printf "    %-16s %s ──► %s\n" "${evt}:" "$senders" "$receivers"
    done
    echo ""
}

# ==================== Validate Command ====================

cmd_validate() {
    if [ ! -f "workflow.yaml" ]; then echo "ERROR: workflow.yaml not found"; exit 1; fi
    if ! command -v yq &>/dev/null; then echo "ERROR: yq required. brew install yq"; exit 1; fi

    # Phase 0: YAML syntax
    local parse_err
    if ! parse_err=$(yq 'true' workflow.yaml 2>&1); then
        echo "ERROR: workflow.yaml has syntax errors:"
        echo "$parse_err" | sed 's/^/  /'
        exit 1
    fi

    local errors=0 warnings=0

    # Phase 1: Schema checks
    [ "$(yq '.project.name // ""' workflow.yaml)" = "" ] && echo "ERROR: project.name required" && ((errors++))
    [ "$(yq '.tickets.source // ""' workflow.yaml)" = "" ] && echo "ERROR: tickets.source required" && ((errors++))
    local ic; ic=$(yq '[.agents[] | select(.interactive == true)] | length' workflow.yaml)
    [ "$ic" -ne 1 ] && echo "ERROR: exactly one agent must have interactive: true (found $ic)" && ((errors++))

    # Phase 2: Graph checks (only if events or agent event refs exist)
    local has_events has_agent_events
    has_events=$(yq '.events // {} | length' workflow.yaml)
    has_agent_events=$(yq '[.agents[] | ((.sends // []) + (.receives // []))] | flatten | length' workflow.yaml)

    if [ "$has_events" -gt 0 ] || [ "$has_agent_events" -gt 0 ]; then
        _v_extract_data
        _v_check_missing_events errors
        _v_check_orphaned_events warnings
        _v_check_dead_agents errors
        _v_check_unused_sends warnings
        _v_check_direction_consistency errors
        _v_check_event_loops warnings
        _v_check_unreachable_agents errors
        _v_check_self_loops errors
        # Phase 3: Render event flow
        _v_render_event_flow
    fi

    # Phase 4: Provider/model checks
    local _v_agent_names
    _v_agent_names=$(yq '.agents | keys | .[]' workflow.yaml)
    for _v_a in $_v_agent_names; do
        local _v_prov _v_mod
        _v_prov=$(yq ".agents.$_v_a.provider // \"claude\"" workflow.yaml)
        _v_mod=$(yq ".agents.$_v_a.model // \"\"" workflow.yaml)
        case "$_v_prov" in
            claude|codex) ;;
            *) echo "ERROR: agent '$_v_a' has invalid provider '$_v_prov' (must be claude or codex)"; ((errors++)) ;;
        esac
        if [ "$_v_prov" = "codex" ] && [ -z "$_v_mod" ]; then
            echo "ERROR: agent '$_v_a' uses provider 'codex' but has no model set"; ((errors++))
        fi
    done

    # Phase 4: Summary
    if [ "$errors" -eq 0 ]; then
        echo "workflow.yaml is valid"
        echo "  Project: $(yq '.project.name' workflow.yaml)"
        echo "  Ticket source: $(yq '.tickets.source' workflow.yaml)"
        echo "  Agents: $(yq '.agents | keys | join(", ")' workflow.yaml)"
        [ "$has_events" -gt 0 ] && echo "  Events: $(yq '.events | keys | join(", ")' workflow.yaml)"
        [ "$warnings" -gt 0 ] && echo "  $warnings warning(s)"
        return 0
    else
        echo ""
        echo "$errors error(s), $warnings warning(s)"
        exit 1
    fi
}

# ==================== Analyze Command ====================

ANALYZE_REPORT_REPO="cometdigitalagency/dunno-workflow"
_findings=""
_finding_count=0

_add_finding() {
    local severity="$1" title="$2" detail="$3" evidence="$4" expected="$5"
    _finding_count=$((_finding_count + 1))
    _findings="${_findings}${severity}|${title}|${detail}|${evidence}|${expected}
"
    if [ "$severity" = "ERROR" ]; then
        echo "  ❌ ${title}"
    else
        echo "  ⚠️  ${title}"
    fi
    [ -n "$detail" ] && echo "     → ${detail}"
    return 0
}

analyze_stuck_agents() {
    local log_dir="$1"
    for logfile in "$log_dir"/*.log; do
        local agent
        agent=$(basename "$logfile" .log)
        [ "$agent" = "pm" ] || [ "$agent" = "architect" ] && continue
        # Check if agent received a TASK but never sent DONE
        if grep -aq "TASK" "$logfile" 2>/dev/null; then
            if ! grep -aq "DONE-${agent}" "$logfile" 2>/dev/null && ! grep -aq "Auto-sent DONE-${agent}" "$logfile" 2>/dev/null; then
                local task_line
                task_line=$(grep -a "TASK" "$logfile" | head -1 | cut -c1-120)
                _add_finding "ERROR" \
                    "STUCK AGENT: ${agent} received TASK but no DONE-${agent} found" \
                    "Task: ${task_line}..." \
                    "$(grep -an 'TASK\|Session ended\|DONE' "$logfile" | tail -5)" \
                    "Agent should send DONE-${agent} after completing work"
            fi
        fi
    done
}

analyze_done_delivery() {
    local log_dir="$1"
    local arch_log="$log_dir/architect.log"
    [ -f "$arch_log" ] || return 0
    for logfile in "$log_dir"/*.log; do
        local agent
        agent=$(basename "$logfile" .log)
        [ "$agent" = "pm" ] || [ "$agent" = "architect" ] && continue
        # Check if auto-DONE was sent but architect didn't receive it
        if grep -aq "Auto-sent DONE-${agent}" "$logfile" 2>/dev/null; then
            if ! grep -aq "DONE-${agent}" "$arch_log" 2>/dev/null; then
                _add_finding "ERROR" \
                    "DONE NOT DELIVERED: ${agent} auto-sent DONE but architect has no matching receipt" \
                    "send-to-agent.sh may have failed to deliver the trigger file" \
                    "$(grep -a 'Auto-sent' "$logfile" | tail -1)" \
                    "Architect should receive DONE-${agent} via trigger file"
            fi
        fi
    done
}

analyze_session_crashes() {
    local log_dir="$1"
    # Match real crash signatures, not conversational mentions of "error"
    local crash_pattern="Traceback (most recent\|FATAL\|segfault\|Segmentation fault\|panic:\|Unhandled exception\|Session crashed\|claude: error\|SIGTERM\|SIGKILL\|killed by signal"
    local exclude_pattern="error handling\|error_rate\|ErrorTracker\|fix.*error\|no error\|error message\|error code\|error log\|error in\|errors found"
    for logfile in "$log_dir"/*.log; do
        local agent
        agent=$(basename "$logfile" .log)
        if grep -qai "$crash_pattern" "$logfile" 2>/dev/null; then
            local err_lines
            # Filter out binary/ANSI escape sequence matches (e.g. "Binary file ... matches")
            err_lines=$(grep -ai "$crash_pattern" "$logfile" | grep -avi "$exclude_pattern" | grep -v "^Binary file" | sed 's/\x1b\[[0-9;]*[a-zA-Z]//g' | grep -i "$crash_pattern" | head -3)
            if [ -n "$err_lines" ]; then
                _add_finding "ERROR" \
                    "SESSION CRASH: ${agent} has error traces in log" \
                    "" \
                    "$err_lines" \
                    "Agent sessions should complete without errors"
            fi
        fi
    done
}

analyze_permission_blocks() {
    local log_dir="$1"
    # Skip interactive agent — permission blocks are expected (limited --allowedTools by design)
    local interactive_agent
    interactive_agent=$(yq '.agents | to_entries[] | select(.value.interactive == true) | .key' workflow.yaml 2>/dev/null) || true
    # Match actual tool permission denials from Claude CLI, not conversational mentions
    local perm_pattern="tool use was blocked\|not allowed to use\|Tool .* is not permitted\|User denied tool"
    for logfile in "$log_dir"/*.log; do
        local agent
        agent=$(basename "$logfile" .log)
        [ -n "$interactive_agent" ] && [ "$agent" = "$interactive_agent" ] && continue
        if grep -qai "$perm_pattern" "$logfile" 2>/dev/null; then
            local perm_lines
            perm_lines=$(grep -ai "$perm_pattern" "$logfile" | head -3)
            _add_finding "ERROR" \
                "PERMISSION BLOCKED: ${agent} was denied tool access" \
                "Check --allowedTools configuration for this agent" \
                "$perm_lines" \
                "Non-interactive agents should have all needed tools pre-approved"
        fi
    done
}

analyze_dispatch_timeouts() {
    local log_dir="$1"
    local arch_log="$log_dir/architect.log"
    [ -f "$arch_log" ] || return 0
    # Find agents that architect dispatched to but that never received the message
    for logfile in "$log_dir"/*.log; do
        local agent
        agent=$(basename "$logfile" .log)
        [ "$agent" = "pm" ] || [ "$agent" = "architect" ] && continue
        local agent_upper
        agent_upper=$(echo "$agent" | tr '[:lower:]' '[:upper:]')
        # Architect sent to this agent but agent log has no "Received message"
        if grep -aq "send-to-agent.sh.*${agent_upper}" "$arch_log" 2>/dev/null; then
            if ! grep -aq "Received message" "$logfile" 2>/dev/null; then
                _add_finding "ERROR" \
                    "DISPATCH TIMEOUT: architect sent to ${agent} but no message received" \
                    "Trigger file may not have been written or agent loop not running" \
                    "$(grep -a "send-to-agent.*${agent_upper}" "$arch_log" | head -1 | cut -c1-120)" \
                    "Worker should pick up trigger file within 1-2 seconds"
            fi
        fi
    done
}

analyze_missing_complete() {
    local log_dir="$1"
    local arch_log="$log_dir/architect.log"
    local pm_log="$log_dir/pm.log"
    [ -f "$arch_log" ] && [ -f "$pm_log" ] || return 0
    # Check if architect received all DONEs but never sent COMPLETE to PM
    local has_dones=true
    for logfile in "$log_dir"/*.log; do
        local agent
        agent=$(basename "$logfile" .log)
        [ "$agent" = "pm" ] || [ "$agent" = "architect" ] && continue
        if grep -aq "TASK" "$logfile" 2>/dev/null; then
            if ! grep -aq "DONE-${agent}" "$arch_log" 2>/dev/null; then
                has_dones=false
                break
            fi
        fi
    done
    if [ "$has_dones" = true ] && ! grep -aq "COMPLETE" "$pm_log" 2>/dev/null; then
        # Only flag if there were actually tasks dispatched
        if grep -aq "DONE-" "$arch_log" 2>/dev/null; then
            _add_finding "ERROR" \
                "MISSING COMPLETE: all workers reported DONE but PM never received COMPLETE" \
                "Architect may have failed to send COMPLETE message to PM" \
                "$(grep -a 'DONE-' "$arch_log" | tail -3)" \
                "Architect should send COMPLETE to PM after all workers are done"
        fi
    fi
}

_gh_api() {
    local method="$1" endpoint="$2" data="$3"
    local token="${GITHUB_TOKEN:-${DUNNO_GITHUB_TOKEN:-}}"
    if [ -z "$token" ]; then
        echo "ERROR: GITHUB_TOKEN or DUNNO_GITHUB_TOKEN env var required for issue creation." >&2
        echo "  Generate a token at https://github.com/settings/tokens (needs 'repo' scope)" >&2
        echo "  Then: export GITHUB_TOKEN=ghp_..." >&2
        return 1
    fi
    if [ -n "$data" ]; then
        curl -sf -X "$method" \
            -H "Authorization: token $token" \
            -H "Accept: application/vnd.github+json" \
            -H "Content-Type: application/json" \
            -d "$data" \
            "https://api.github.com${endpoint}" 2>/dev/null
    else
        curl -sf -X "$method" \
            -H "Authorization: token $token" \
            -H "Accept: application/vnd.github+json" \
            "https://api.github.com${endpoint}" 2>/dev/null
    fi
}

_ensure_labels() {
    local repo="$1" project_label="$2"
    # Create labels if they don't exist (ignore errors if they already exist)
    _gh_api POST "/repos/${repo}/labels" '{"name":"auto-detected","color":"D93F0B","description":"Auto-detected by dunno-workflow analyze"}' >/dev/null 2>&1 || true
    _gh_api POST "/repos/${repo}/labels" '{"name":"bug","color":"D73A4A","description":"Something isn'"'"'t working"}' >/dev/null 2>&1 || true
    if [ -n "$project_label" ]; then
        _gh_api POST "/repos/${repo}/labels" \
            "{\"name\":\"project:${project_label}\",\"color\":\"1D76DB\",\"description\":\"Source project: ${project_label}\"}" \
            >/dev/null 2>&1 || true
    fi
}

_create_issue() {
    local title="$1" body="$2" dry_run="$3" project_label="$4"
    if [ "$dry_run" = true ]; then
        echo "  [DRY RUN] Would create: \"Bug: ${title}\" [project:${project_label:-unknown}]"
        return 0
    fi

    local token="${GITHUB_TOKEN:-${DUNNO_GITHUB_TOKEN:-}}"
    if [ -z "$token" ]; then
        echo "  ⚠️  Skipped: no GITHUB_TOKEN set (export GITHUB_TOKEN=ghp_...)"
        return 0
    fi

    # Ensure labels exist
    _ensure_labels "$ANALYZE_REPORT_REPO" "$project_label"

    # Dedup: check if matching issue already exists
    local existing
    existing=$(_gh_api GET "/repos/${ANALYZE_REPORT_REPO}/issues?labels=auto-detected&state=open&per_page=100" "" || true)
    if echo "$existing" | grep -qF "$title" 2>/dev/null; then
        echo "  ⏭  Skipped (duplicate): \"${title}\""
        return 0
    fi

    # Escape body for JSON
    local json_body
    json_body=$(printf '%s' "$body" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))' 2>/dev/null || printf '"%s"' "$body")
    local json_title
    json_title=$(printf '%s' "Bug: ${title}" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))' 2>/dev/null || printf '"%s"' "Bug: ${title}")

    # Build labels array
    local labels_json='"bug","auto-detected"'
    if [ -n "$project_label" ]; then
        labels_json="${labels_json},\"project:${project_label}\""
    fi

    local response
    response=$(_gh_api POST "/repos/${ANALYZE_REPORT_REPO}/issues" \
        "{\"title\":${json_title},\"body\":${json_body},\"labels\":[${labels_json}]}") || {
        echo "  ⚠️  Failed to create issue (check GITHUB_TOKEN permissions)"
        return 1
    }

    local issue_url
    issue_url=$(echo "$response" | python3 -c 'import sys,json; print(json.loads(sys.stdin.read())["html_url"])' 2>/dev/null || echo "(created)")
    echo "  Created: ${issue_url}"
}

cmd_analyze() {
    local SESSION="" DRY_RUN=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            --session|-s) SESSION="$2"; shift 2 ;;
            --dry-run|-n) DRY_RUN=true; shift ;;
            --help|-h)
                echo "Usage: dunno-workflow analyze [--session <name>] [--dry-run]"
                echo ""
                echo "Options:"
                echo "  --session, -s <name>  Analyze specific session (default: latest)"
                echo "  --dry-run, -n         Show findings without creating issues"
                exit 0 ;;
            *) echo "Unknown option: $1"; exit 1 ;;
        esac
    done

    local LOG_BASE=".team-logs"
    if [ ! -d "$LOG_BASE" ]; then
        echo "ERROR: No .team-logs/ directory found. Run with --debug to enable logging."
        exit 1
    fi

    if [ -z "$SESSION" ]; then
        SESSION=$(ls -1t "$LOG_BASE" 2>/dev/null | grep -v '^archived$' | head -1)
    fi
    if [ -z "$SESSION" ] || [ ! -d "$LOG_BASE/$SESSION" ]; then
        echo "ERROR: No log sessions found in .team-logs/"
        exit 1
    fi

    local LOG_DIR="$LOG_BASE/$SESSION"
    local log_count
    log_count=$(ls "$LOG_DIR"/*.log 2>/dev/null | wc -l | tr -d ' ')

    echo ""
    echo "  Analyzing session: $SESSION"
    echo "  Logs: $LOG_DIR/ ($log_count agent logs)"
    echo ""
    echo "  Findings:"

    _findings=""
    _finding_count=0

    analyze_stuck_agents "$LOG_DIR"
    analyze_done_delivery "$LOG_DIR"
    analyze_session_crashes "$LOG_DIR"
    analyze_permission_blocks "$LOG_DIR"
    analyze_dispatch_timeouts "$LOG_DIR"
    analyze_missing_complete "$LOG_DIR"

    if [ "$_finding_count" -eq 0 ]; then
        echo "  ✅ No issues found. All agents completed successfully."
        echo ""
        return 0
    fi

    echo ""
    echo "  $_finding_count issue(s) found."
    [ "$DRY_RUN" = true ] && echo "  (dry-run mode — no issues will be created)"
    echo ""

    # Read project context
    local source_repo="" project_name="" workflow_content=""
    if [ -f "workflow.yaml" ]; then
        source_repo=$(yq '.project.repo // ""' workflow.yaml 2>/dev/null)
        project_name=$(yq '.project.name // ""' workflow.yaml 2>/dev/null)
        workflow_content=$(cat "workflow.yaml")
    fi

    # Create issues from findings
    local IFS=$'\n'
    for finding in $_findings; do
        [ -z "$finding" ] && continue
        local sev title detail evidence expected
        sev=$(echo "$finding" | cut -d'|' -f1)
        title=$(echo "$finding" | cut -d'|' -f2)
        detail=$(echo "$finding" | cut -d'|' -f3)
        evidence=$(echo "$finding" | cut -d'|' -f4)
        expected=$(echo "$finding" | cut -d'|' -f5)

        local body
        body="## ${title}

**Detected by:** \`dunno-workflow analyze\`
**Session:** ${SESSION}
**Source repo:** ${source_repo:-unknown}

### What happened
${detail}

### Log evidence
\`\`\`
${evidence}
\`\`\`

### Expected behavior
${expected}

### Labels
\`bug\`, \`auto-detected\`${project_name:+, \`project:${project_name}\`}"

        # Append workflow.yaml if available
        if [ -n "$workflow_content" ]; then
            body="${body}

<details>
<summary>workflow.yaml</summary>

\`\`\`yaml
${workflow_content}
\`\`\`

</details>"
        fi

        _create_issue "$title" "$body" "$DRY_RUN" "$project_name"
    done
    echo ""

    # Archive the session logs after issues have been created
    if [ "$DRY_RUN" = false ]; then
        local archive_dir="$LOG_BASE/archived"
        mkdir -p "$archive_dir"
        mv "$LOG_DIR" "$archive_dir/"
        if [ -f "workflow.yaml" ]; then
            cp "workflow.yaml" "$archive_dir/$SESSION/workflow.yaml"
        fi
        echo "  Archived: $LOG_DIR → $archive_dir/$SESSION"
        echo ""
    fi

    return 0
}

cmd_context() {
    local action="${1:-list}"

    local workflow_file="./workflow.yaml"
    if [ ! -f "$workflow_file" ]; then
        echo "ERROR: workflow.yaml not found. Run from the project directory."
        exit 1
    fi

    if ! command -v yq &>/dev/null; then
        echo "ERROR: yq is required but not installed."; exit 1
    fi

    local mem_enabled
    mem_enabled=$(yq '.memory.enabled // "false"' "$workflow_file")
    if [ "$mem_enabled" != "true" ]; then
        echo "Shared memory is not enabled. Add 'memory: { enabled: true }' to workflow.yaml."
        exit 0
    fi

    local mem_dir agents_doc context_dir
    mem_dir=$(yq '.memory.directory // ".workflow"' "$workflow_file")
    agents_doc=$(yq '.memory.agents_doc // "AGENTS.md"' "$workflow_file")
    context_dir="./${mem_dir}"

    case "$action" in
        list|"")
            echo ""
            echo "  Shared context: ${context_dir}/"
            echo ""
            if [ -f "./${agents_doc}" ]; then
                local line_count
                line_count=$(wc -l < "./${agents_doc}" | tr -d ' ')
                echo "  ${agents_doc} (${line_count} lines)"
            fi
            local state_file="${context_dir}/state.json"
            if [ -f "$state_file" ]; then
                echo "  state.json:"
                if command -v jq &>/dev/null; then
                    local current
                    current=$(jq -r '.current_issue // empty | "    Active: Issue #\(.id) — \(.title) [\(.status)]"' "$state_file" 2>/dev/null)
                    if [ -n "$current" ]; then
                        echo "$current"
                    else
                        echo "    No active issue"
                    fi
                    local hist_count
                    hist_count=$(jq '.history | length' "$state_file" 2>/dev/null)
                    echo "    History: ${hist_count} completed issue(s)"
                else
                    echo "    (install jq to view state details)"
                fi
            else
                echo "  No state.json yet (run 'dunno-workflow start' to initialize)"
            fi
            echo ""
            ;;
        clear)
            echo "  This will reset the shared state (${agents_doc} is kept)."
            printf "  Are you sure? [y/N] "
            read -r confirm
            if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
                printf '{"version":1,"updated_at":"","current_issue":null,"history":[]}\n' > "${context_dir}/state.json"
                echo "  Cleared."
            else
                echo "  Cancelled."
            fi
            ;;
        *)
            echo "Usage: dunno-workflow context [list|clear]"
            exit 1
            ;;
    esac
}

cmd_stop() {
    echo "Stopping agent sessions..."
    tmux kill-session -t dunno-agents 2>/dev/null || true
    echo "Done."
}

# ==================== Start Command (engine) ====================

cmd_start() {
    set -e
    
    REPO_DIR="$(pwd)"
    WORKFLOW_FILE="${REPO_DIR}/workflow.yaml"
    ISSUE_NUM=""
    TEST_MODE=false
    DEBUG_MODE=false
    E2E_MODE=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --issue|-i) ISSUE_NUM="$2"; shift 2 ;;
            --test|-t)  TEST_MODE=true; shift ;;
            --e2e|-e)   E2E_MODE=true; shift ;;
            --debug|-d) DEBUG_MODE=true; shift ;;
            --help|-h)
                echo "Usage: dunno-workflow start [--issue <number>] [--test] [--e2e] [--debug]"
                echo ""
                echo "Options:"
                echo "  --issue, -i <num>   Ticket number to work on"
                echo "  --test, -t          Test mode — mock issue, no ticket source needed"
                echo "  --e2e, -e           End-to-end test — small ticket through full flow"
                echo "  --debug, -d         Enable LOGS pane with filtered session logging"
                echo "  --help, -h          Show this help"
                exit 0 ;;
            *) echo "Unknown option: $1"; exit 1 ;;
        esac
    done
    
    # ==================== Dependencies ====================
    
    if ! command -v yq &>/dev/null; then
        echo "ERROR: yq is required but not installed."
        echo "  brew install yq"
        exit 1
    fi
    
    if [ ! -f "$WORKFLOW_FILE" ]; then
        echo "ERROR: workflow.yaml not found at $WORKFLOW_FILE"
        exit 1
    fi
    
    # ==================== Read workflow.yaml ====================
    
    yq_get() { yq "$1" "$WORKFLOW_FILE"; }
    
    PROJECT_NAME=$(yq_get '.project.name')
    REPO_NAME=$(yq_get '.project.repo')
    TICKET_SOURCE=$(yq_get '.tickets.source')
    
    # Read agent names (preserving YAML key order)
    AGENTS=()
    while IFS= read -r agent; do
        AGENTS+=("$agent")
    done < <(yq_get '.agents | keys | .[]')
    
    # Identify interactive agent (PM) vs workers
    INTERACTIVE_AGENT=""
    WORKER_AGENTS=()
    for agent in "${AGENTS[@]}"; do
        if [ "$(yq_get ".agents.$agent.interactive")" = "true" ]; then
            INTERACTIVE_AGENT="$agent"
        else
            WORKER_AGENTS+=("$agent")
        fi
    done
    
    # Check debug_pane from YAML or --debug flag
    if [ "$(yq_get '.layout.debug_pane')" = "true" ]; then
        DEBUG_MODE=true
    fi
    
    # Create directories
    PROMPT_DIR="${REPO_DIR}/.team-prompts"
    mkdir -p "$PROMPT_DIR"
    
    if [ "$DEBUG_MODE" = true ]; then
        LOG_DIR="${REPO_DIR}/.team-logs/$(date '+%Y-%m-%d_%H-%M-%S')"
        mkdir -p "$LOG_DIR"
    fi

    # Shared memory defaults (overridden by init_context_dir if memory.enabled: true)
    MEMORY_ENABLED="false"
    CONTEXT_DIR=""
    STATE_FILE=""
    MEMORY_AGENTS_DOC="AGENTS.md"

    # ==================== Shared Context Init ====================

    init_context_dir() {
        MEMORY_ENABLED=$(yq_get '.memory.enabled // "false"')
        [ "$MEMORY_ENABLED" != "true" ] && return 0

        local mem_dir
        mem_dir=$(yq_get '.memory.directory // ".workflow"')
        CONTEXT_DIR="${REPO_DIR}/${mem_dir}"
        MEMORY_AGENTS_DOC=$(yq_get '.memory.agents_doc // "AGENTS.md"')

        mkdir -p "${CONTEXT_DIR}"
        STATE_FILE="${CONTEXT_DIR}/state.json"
        if [ ! -f "$STATE_FILE" ]; then
            printf '{"version":1,"updated_at":"","current_issue":null,"history":[]}\n' > "$STATE_FILE"
            echo "  Created state.json"
        fi

        # Bootstrap AGENTS.md only on first run
        local agents_doc_path="${REPO_DIR}/${MEMORY_AGENTS_DOC}"
        if [ ! -f "$agents_doc_path" ]; then
            printf '%b' "# ${PROJECT_NAME} — Agent Team Context\n\nThis file is maintained by the agent team and read at the start of each session.\nEdit freely between sessions to keep conventions current.\n\n## Architecture\n\n_Fill in: key services, data flows, external dependencies._\n\n## Conventions\n\n_Fill in: naming patterns, code style, test strategy, deploy steps._\n\n## Open Questions\n\n_Fill in: unresolved issues the team needs to address._\n\n## Decisions\n\nKey decisions are tracked in \`.workflow/state.json\` per issue.\n" > "$agents_doc_path"
            echo "  Created ${MEMORY_AGENTS_DOC}"
        fi
        echo "  Shared context: ${CONTEXT_DIR}/"
        echo "  Tip: commit AGENTS.md and .workflow/ to git for cross-session persistence."
    }

    init_context_dir

    # ==================== Ticket Source Functions ====================
    # Generate ticket CLI commands based on tickets.source
    
    generate_ticket_commands() {
        local source="$1"
        case "$source" in
            github)
                local gh_repo
                gh_repo=$(yq_get '.tickets.github.repo // .project.repo')
                local lbl_ready lbl_inprog lbl_done
                lbl_ready=$(yq_get '.tickets.github.labels.ready')
                lbl_inprog=$(yq_get '.tickets.github.labels.in_progress')
                lbl_done=$(yq_get '.tickets.github.labels.done')
    
                TICKET_CREATE="gh issue create --repo ${gh_repo} --title \"\$TITLE\" --label \"${lbl_ready},feature\" --body \"\$BODY\""
                TICKET_LIST_READY="gh issue list --repo ${gh_repo} --label ${lbl_ready} --state open --json number,title --jq '.[0].number // empty'"
                TICKET_VIEW="gh issue view \$N --repo ${gh_repo}"
                TICKET_CLAIM="gh issue edit \$N --repo ${gh_repo} --remove-label ${lbl_ready} --add-label ${lbl_inprog}"
                TICKET_COMMENT="gh issue comment \$N --repo ${gh_repo} --body \"\$MSG\""
                TICKET_CLOSE="gh issue close \$N --repo ${gh_repo} && gh issue edit \$N --repo ${gh_repo} --remove-label ${lbl_inprog} --add-label ${lbl_done}"
                TICKET_LIST_OPEN="gh issue list --repo ${gh_repo} --state open"
                TICKET_LIST_STALE="gh issue list --repo ${gh_repo} --label ${lbl_inprog} --state open --json number,title"
                ;;
            file)
                local dir
                dir=$(yq_get '.tickets.file.directory // "./tickets"')
                TICKET_CREATE="echo '---\nid: \$(ls ${dir}/*.md 2>/dev/null | wc -l | tr -d \" \")\ntitle: '\"\$TITLE\"'\nstatus: ready\nlabels: [feature]\ncreated: \$(date +%Y-%m-%d)\n---\n\n\$BODY' > '${dir}/\$(date +%s).md'"
                TICKET_LIST_READY="grep -rl 'status: ready' ${dir}/*.md 2>/dev/null | head -1"
                TICKET_VIEW="cat \$N"
                TICKET_CLAIM="sed -i '' 's/status: ready/status: in-progress/' \$N"
                TICKET_COMMENT="echo -e '\n---\n### \$MSG\n\$(date)' >> \$N"
                TICKET_CLOSE="sed -i '' 's/status: in-progress/status: done/' \$N"
                TICKET_LIST_OPEN="grep -rl 'status: \\(ready\\|in-progress\\)' ${dir}/*.md 2>/dev/null"
                TICKET_LIST_STALE="grep -rl 'status: in-progress' ${dir}/*.md 2>/dev/null"
                ;;
            jira)
                local server project_key
                server=$(yq_get '.tickets.jira.server')
                project_key=$(yq_get '.tickets.jira.project_key')
                local st_ready st_inprog st_done
                st_ready=$(yq_get '.tickets.jira.statuses.ready')
                st_inprog=$(yq_get '.tickets.jira.statuses.in_progress')
                st_done=$(yq_get '.tickets.jira.statuses.done')
                TICKET_CREATE="jira issue create --project ${project_key} --type Task --summary \"\$TITLE\" --body \"\$BODY\""
                TICKET_LIST_READY="jira issue list --project ${project_key} --status \"${st_ready}\" --plain --no-headers | head -1 | awk '{print \$1}'"
                TICKET_VIEW="jira issue view \$N"
                TICKET_CLAIM="jira issue move \$N \"${st_inprog}\""
                TICKET_COMMENT="jira issue comment add \$N --body \"\$MSG\""
                TICKET_CLOSE="jira issue move \$N \"${st_done}\""
                TICKET_LIST_OPEN="jira issue list --project ${project_key} --status \"${st_ready}\" --status \"${st_inprog}\""
                TICKET_LIST_STALE="jira issue list --project ${project_key} --status \"${st_inprog}\" --plain --no-headers"
                ;;
            clickup)
                local list_id
                list_id=$(yq_get '.tickets.clickup.list_id')
                local st_ready st_inprog st_done
                st_ready=$(yq_get '.tickets.clickup.statuses.ready')
                st_inprog=$(yq_get '.tickets.clickup.statuses.in_progress')
                st_done=$(yq_get '.tickets.clickup.statuses.done')
                TICKET_CREATE="clickup task create --list-id ${list_id} --name \"\$TITLE\" --description \"\$BODY\" --status \"${st_ready}\""
                TICKET_LIST_READY="clickup task list --list-id ${list_id} --status \"${st_ready}\" | head -1 | awk '{print \$1}'"
                TICKET_VIEW="clickup task view \$N"
                TICKET_CLAIM="clickup task update \$N --status \"${st_inprog}\""
                TICKET_COMMENT="clickup task comment \$N --text \"\$MSG\""
                TICKET_CLOSE="clickup task update \$N --status \"${st_done}\""
                TICKET_LIST_OPEN="clickup task list --list-id ${list_id}"
                TICKET_LIST_STALE="clickup task list --list-id ${list_id} --status \"${st_inprog}\""
                ;;
            *)
                echo "ERROR: Unknown ticket source: $source"
                exit 1 ;;
        esac
    }
    
    generate_ticket_commands "$TICKET_SOURCE"

    # ── E2E mode: override to file-based tickets with a small test ticket ──
    if [ "$E2E_MODE" = true ]; then
        TICKET_SOURCE="file"
        generate_ticket_commands "file"
        local ticket_dir="${REPO_DIR}/tickets"
        mkdir -p "$ticket_dir"
        local tpl_dir
        tpl_dir="$(get_template_dir)"
        if [ -f "$tpl_dir/e2e-test-ticket.md" ]; then
            cp "$tpl_dir/e2e-test-ticket.md" "$ticket_dir/e2e-test.md"
            echo "E2E: Created test ticket in $ticket_dir/e2e-test.md"
        fi
        TEST_MODE=true
    fi

    # ==================== Helper: send-to-agent.sh ====================
    
    sed 's/^    //' > "$PROMPT_DIR/send-to-agent.sh" << 'HELPER'
    #!/bin/bash
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    AGENT_NAME=$(echo "$1" | tr '[:upper:]' '[:lower:]')
    shift
    MESSAGE="$*"

    # Write trigger file for the worker's file-watch loop
    TRIGGER_DIR="$SCRIPT_DIR/triggers"
    if ! mkdir -p "$TRIGGER_DIR" 2>/dev/null; then
        echo "ERROR: Failed to create trigger directory: $TRIGGER_DIR" >&2
        exit 1
    fi

    # Per-sender trigger files to prevent race conditions.
    # DONE-{sender} messages get a deterministic filename; others get a unique suffix.
    case "$MESSAGE" in
        DONE-*|Done-*)
            # Extract sender name from "DONE-frontend:..." -> "frontend"
            SENDER=$(echo "$MESSAGE" | sed 's/^[Dd][Oo][Nn][Ee]-\([^:]*\).*/\1/' | tr '[:upper:]' '[:lower:]')
            TRIGGER_FILE="$TRIGGER_DIR/${AGENT_NAME}.from-${SENDER}.trigger"
            touch "$TRIGGER_DIR/${AGENT_NAME}.done-sent" 2>/dev/null
            ;;
        *)
            SENDER="msg-$(date +%s)-$$"
            TRIGGER_FILE="$TRIGGER_DIR/${AGENT_NAME}.from-${SENDER}.trigger"
            ;;
    esac

    if ! printf '%s\n' "$MESSAGE" > "$TRIGGER_FILE"; then
        echo "ERROR: Failed to write trigger file: $TRIGGER_FILE" >&2
        exit 1
    fi

    # Verify the write succeeded (non-empty)
    if [ ! -s "$TRIGGER_FILE" ]; then
        echo "ERROR: Trigger file is empty after write: $TRIGGER_FILE" >&2
        exit 1
    fi

    # Deliver message to the iTerm2 pane.
    # Worker agents (event-driven) read from .trigger files — they only need a nudge.
    # Interactive/auto_start agents (PM, architect) receive messages via iTerm2 text
    # input, so we must type the full message into their pane.
    #
    # Long messages (>3KB) are written to a temp file and piped via 'cat' to avoid
    # AppleScript's ~4KB string truncation limit.
    AGENT_UPPER=$(echo "$AGENT_NAME" | tr '[:lower:]' '[:upper:]')

    # Check if target is a worker (has an event-driven polling loop)
    LAUNCHER="$SCRIPT_DIR/run-${AGENT_NAME}.sh"
    if [ -f "$LAUNCHER" ] && grep -q "Event-driven loop" "$LAUNCHER" 2>/dev/null; then
        IS_WORKER=true
    else
        IS_WORKER=false
    fi

    # PM has a background trigger watcher and REPL. Typing multiline messages into
    # its pane causes each line to be interpreted as fresh user input, so PM should
    # receive trigger files only.
    if [ -f "$LAUNCHER" ] && grep -q "INCOMING MESSAGE" "$LAUNCHER" 2>/dev/null; then
        IS_TRIGGER_ONLY=true
    else
        IS_TRIGGER_ONLY=false
    fi

    if [ "$IS_WORKER" = true ] || [ "$IS_TRIGGER_ONLY" = true ]; then
        # Worker agents and the PM REPL consume trigger files directly.
        PANE_TEXT=""
    else
        # Interactive/auto_start agent: type the full message into the pane
        if [ ${#MESSAGE} -gt 3000 ]; then
            # Long message: write to temp file, type a cat command into the pane
            MSG_FILE="$TRIGGER_DIR/${AGENT_NAME}.msg-input"
            printf '%s\n' "$MESSAGE" > "$MSG_FILE"
            PANE_TEXT="cat '${MSG_FILE}' | claude -p --append-system-prompt \"\$SYSTEM_PROMPT\" --allowedTools \"\$ALLOWED_TOOLS\" -n \"${AGENT_NAME}\""
            # Actually, for interactive sessions we just need to type the message
            PANE_TEXT="$MESSAGE"
        else
            PANE_TEXT="$MESSAGE"
        fi
    fi

    deliver_to_pane() {
        local pane_id
        pane_id=$(cat "$TRIGGER_DIR/${AGENT_NAME}.pane" 2>/dev/null)
        if [ -z "$pane_id" ]; then
            echo "not_found"
            return
        fi
        tmux send-keys -t "$pane_id" "$PANE_TEXT" Enter 2>/dev/null \
            && echo "sent" || echo "not_found"
    }

    RESULT=$(deliver_to_pane)

    # Wait for receiver to ACK (max 30s) — only for workers with polling loops.
    # Interactive/auto_start agents don't write ACK files.
    if [ "$IS_WORKER" = true ] || [ "$IS_TRIGGER_ONLY" = true ]; then
        if [ "$RESULT" = "not_found" ]; then
            echo "WARNING: tmux pane for '${AGENT_NAME}' not found (trigger file still delivered)" >&2
        fi
        ACK_FILE="$TRIGGER_DIR/${AGENT_NAME}.ack"
        WAIT=0
        while [ ! -f "$ACK_FILE" ] && [ $WAIT -lt 30 ]; do
            sleep 1
            WAIT=$((WAIT + 1))
        done

        if [ -f "$ACK_FILE" ]; then
            echo "--- [$(date '+%H:%M:%S')] Acknowledged by ${AGENT_NAME} (${WAIT}s) ---"
            rm -f "$ACK_FILE"
        else
            echo "WARNING: ${AGENT_NAME} did not acknowledge after 30s — trigger file may be pending" >&2
        fi
    else
        # Non-worker (architect/PM): retry delivery up to 3 times if pane not found
        ATTEMPT=1
        MAX_ATTEMPTS=3
        while [ "$RESULT" = "not_found" ] && [ $ATTEMPT -lt $MAX_ATTEMPTS ]; do
            ATTEMPT=$((ATTEMPT + 1))
            echo "WARNING: tmux pane for '${AGENT_NAME}' not found — retry $ATTEMPT/$MAX_ATTEMPTS in 3s (trigger file persists as fallback)" >&2
            sleep 3
            RESULT=$(deliver_to_pane)
        done
        if [ "$RESULT" = "not_found" ]; then
            echo "ERROR: tmux pane for '${AGENT_NAME}' not found after $MAX_ATTEMPTS attempts (trigger file persists as fallback)" >&2
        else
            echo "--- [$(date '+%H:%M:%S')] Message sent to ${AGENT_NAME} pane ---"
        fi
    fi
HELPER
    chmod +x "$PROMPT_DIR/send-to-agent.sh"

    # ==================== Generate Shared State Helper ====================

    if [ "$MEMORY_ENABLED" = "true" ]; then
        cat > "$PROMPT_DIR/update-state.sh" << 'STATEHELPER'
#!/bin/bash
# update-state.sh — update the shared state file
# Usage:
#   update-state.sh <state-file> set-issue <id> <title> <context>
#   update-state.sh <state-file> update-agent <agent> <status> [summary]
#   update-state.sh <state-file> add-decision <text>
#   update-state.sh <state-file> complete-issue <summary>
#   update-state.sh <state-file> read-context

STATE_FILE="$1"
shift
ACTION="$1"
shift

if [ -z "$STATE_FILE" ] || [ -z "$ACTION" ]; then
    echo "Usage: $(basename "$0") <state-file> <action> [args...]" >&2
    exit 1
fi

if ! command -v jq &>/dev/null; then
    echo "ERROR: jq is required for shared state. brew install jq" >&2
    exit 1
fi

case "$ACTION" in
    set-issue)
        ID="$1"; TITLE="$2"; CONTEXT="$3"
        jq --arg id "$ID" --arg title "$TITLE" --arg ctx "$CONTEXT" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
            '.current_issue = {id: ($id|tonumber), title: $title, status: "in_progress", context: $ctx, decisions: [], agent_progress: {}} | .updated_at = $ts' \
            "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
        ;;
    update-agent)
        AGENT="$1"; STATUS="$2"; SUMMARY="${3:-}"
        jq --arg agent "$AGENT" --arg status "$STATUS" --arg summary "$SUMMARY" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
            '.current_issue.agent_progress[$agent] = {status: $status, summary: $summary} | .updated_at = $ts' \
            "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
        ;;
    add-decision)
        TEXT="$1"
        jq --arg text "$TEXT" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
            '.current_issue.decisions += [$text] | .updated_at = $ts' \
            "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
        ;;
    complete-issue)
        SUMMARY="$1"
        jq --arg summary "$SUMMARY" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
            '.history = ([{id: .current_issue.id, title: .current_issue.title, resolved_at: $ts, summary: $summary}] + .history) | .history = .history[:5] | .current_issue = null | .updated_at = $ts' \
            "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
        ;;
    read-context)
        jq -r '
            if .current_issue then
                "--- CONTEXT PACKET ---",
                "Issue: #\(.current_issue.id) — \(.current_issue.title)",
                "Status: \(.current_issue.status)",
                "Context: \(.current_issue.context)",
                (if (.current_issue.decisions | length) > 0 then
                    "Decisions:", (.current_issue.decisions[] | "- \(.)")
                else empty end),
                (if (.current_issue.agent_progress | length) > 0 then
                    "Agent Progress:",
                    (.current_issue.agent_progress | to_entries[] | "- \(.key): \(.value.status)\(if .value.summary != "" then " — \(.value.summary)" else "" end)")
                else empty end),
                "--- END CONTEXT ---"
            else
                "(no active issue)"
            end
        ' "$STATE_FILE"
        ;;
    *)
        echo "Unknown action: $ACTION" >&2
        echo "Actions: set-issue, update-agent, add-decision, complete-issue, read-context" >&2
        exit 1
        ;;
esac
STATEHELPER
        chmod +x "$PROMPT_DIR/update-state.sh"
    fi

    # ==================== Generate Claude Hooks ====================

    HOOK_SESSION_DIR="${REPO_DIR}/.workflow/logs/$(date '+%Y-%m-%d_%H-%M-%S')"

    generate_hooks() {
        local claude_dir="${REPO_DIR}/.claude"
        local hooks_dir="${claude_dir}/hooks"
        local settings_file="${claude_dir}/settings.json"
        local hook_script="${hooks_dir}/log-session.sh"

        mkdir -p "$hooks_dir"

        # Write log-session.sh with session dir baked in
        cat > "$hook_script" << HOOKSCRIPT
#!/bin/bash
# log-session.sh — generated by dunno-workflow, regenerated on each start
# Logs agent prompts and bash tool use to .workflow/logs/

INPUT=\$(cat)

_py() { python3 -c "\$1" 2>/dev/null || true; }

SESSION_ID=\$(_py "import sys,json; d=json.load(sys.stdin); print(d.get('session_id','unknown'))" <<< "\$INPUT")
TRANSCRIPT=\$(_py "import sys,json; d=json.load(sys.stdin); print(d.get('transcript_path',''))" <<< "\$INPUT")
EVENT=\$(_py "import sys,json; d=json.load(sys.stdin); print(d.get('hook_event_name',''))" <<< "\$INPUT")

LOG_BASE='${HOOK_SESSION_DIR}'
mkdir -p "\$LOG_BASE"

# Detect agent name from system prompt baked into transcript (grep for state file pattern)
AGENT="unknown"
if [ -f "\$TRANSCRIPT" ]; then
    AGENT=\$(grep -o 'triggers/[a-z_-]*\.state' "\$TRANSCRIPT" 2>/dev/null | head -1 | sed 's|triggers/||;s|\.state||')
    [ -z "\$AGENT" ] && AGENT="pm"
fi

case "\$EVENT" in
    PostToolUse)
        CMD=\$(_py "import sys,json; d=json.load(sys.stdin); print(d.get('tool_input',{}).get('command',''))" <<< "\$INPUT")
        [ -n "\$CMD" ] && printf '[%s] %s\n' "\$(date '+%H:%M:%S')" "\$CMD" >> "\$LOG_BASE/\${AGENT}-commands.log"
        ;;
    Stop)
        STOP_ACTIVE=\$(_py "import sys,json; d=json.load(sys.stdin); print(str(d.get('stop_hook_active',False)).lower())" <<< "\$INPUT")
        if [ "\$STOP_ACTIVE" != "true" ] && [ -f "\$TRANSCRIPT" ]; then
            cp "\$TRANSCRIPT" "\$LOG_BASE/\${AGENT}-transcript.jsonl"
            printf '[%s] transcript saved: %s\n' "\$(date '+%H:%M:%S')" "\$AGENT" >> "\$LOG_BASE/sessions.log"
        fi
        ;;
esac

exit 0
HOOKSCRIPT
        chmod +x "$hook_script"

        # Write .claude/settings.json — skip if user has a non-dunno-workflow file
        if [ -f "$settings_file" ]; then
            local is_ours
            is_ours=$(python3 -c "import sys,json; d=json.load(open('${settings_file}')); print('yes' if '_dunno_workflow' in d else 'no')" 2>/dev/null || echo "no")
            if [ "$is_ours" = "no" ]; then
                echo "  WARNING: .claude/settings.json exists and was not generated by dunno-workflow — skipping hook registration."
                echo "           To enable prompt logging, manually add the hooks from .claude/hooks/log-session.sh."
                return 0
            fi
        fi

        python3 - << PYEOF
import json
settings = {
    "_dunno_workflow": True,
    "_note": "Generated by dunno-workflow — regenerated on each start. Add custom settings to .claude/settings.local.json instead.",
    "hooks": {
        "Stop": [{"hooks": [{"type": "command", "command": ".claude/hooks/log-session.sh"}]}],
        "PostToolUse": [{"matcher": "Bash", "hooks": [{"type": "command", "command": ".claude/hooks/log-session.sh"}]}]
    }
}
with open("${settings_file}", "w") as f:
    json.dump(settings, f, indent=2)
    f.write("\n")
PYEOF
        echo "  Hook logging: ${HOOK_SESSION_DIR}/"
    }

    generate_hooks

    # ==================== Generate System Prompts ====================
    
    generate_system_prompt() {
        local agent="$1"
        local role description interactive
        role=$(yq_get ".agents.$agent.role")
        description=$(yq_get ".agents.$agent.description")
        interactive=$(yq_get ".agents.$agent.interactive")
    
        local prompt=""
        prompt+="You are the ${role} for the ${PROJECT_NAME} platform. ${description}\n\n"
    
        # Workflow steps
        prompt+="## YOUR WORKFLOW\n"
        local step_num=1
        while IFS= read -r step; do
            # Interpolate ticket commands into workflow steps
            step="${step//\{repo\}/$REPO_NAME}"
            prompt+="${step_num}. ${step}\n"
            ((step_num++))
        done < <(yq_get ".agents.$agent.workflow[]")
        prompt+="\n"
    
        # Communicating with agents
        prompt+="## COMMUNICATING WITH AGENTS\n"
        prompt+="You can send messages to any agent by running bash commands:\n"
        for other in "${AGENTS[@]}"; do
            if [ "$other" != "$agent" ]; then
                local other_upper
                other_upper=$(echo "$other" | tr '[:lower:]' '[:upper:]')
                prompt+="- Send message to ${other}: bash -c \"'${PROMPT_DIR}/send-to-agent.sh' ${other_upper} 'your message here'\"\n"
            fi
        done
        prompt+="\n"
    
        # Ticket commands section
        prompt+="## TICKET COMMANDS (source: ${TICKET_SOURCE})\n"
        prompt+="- Create ticket: ${TICKET_CREATE}\n"
        prompt+="- List ready tickets: ${TICKET_LIST_READY}\n"
        prompt+="- View ticket: ${TICKET_VIEW}\n"
        prompt+="- Claim ticket (mark in-progress): ${TICKET_CLAIM}\n"
        prompt+="- Comment on ticket: ${TICKET_COMMENT}\n"
        prompt+="- Close ticket (mark done): ${TICKET_CLOSE}\n"
        prompt+="- List open tickets: ${TICKET_LIST_OPEN}\n"
        prompt+="- List stale in-progress tickets: ${TICKET_LIST_STALE}\n"
        prompt+="\n"
    
        # Rules
        local rules_count
        rules_count=$(yq_get ".agents.$agent.rules | length")
        if [ "$rules_count" != "0" ]; then
            prompt+="## RULES\n"
            while IFS= read -r rule; do
                prompt+="- ${rule}\n"
            done < <(yq_get ".agents.$agent.rules[]")
            prompt+="\n"
        fi
    
        # File ownership
        local owns_count never_count
        owns_count=$(yq_get ".agents.$agent.owns.paths | length")
        never_count=$(yq_get ".agents.$agent.owns.never_edit | length")
        if [ "$owns_count" != "0" ] || [ "$never_count" != "0" ]; then
            prompt+="## FILE OWNERSHIP\n"
            if [ "$owns_count" != "0" ]; then
                prompt+="You may edit files matching: "
                prompt+=$(yq_get ".agents.$agent.owns.paths | join(\", \")")
                prompt+="\n"
            fi
            if [ "$never_count" != "0" ]; then
                prompt+="You must NEVER edit: "
                prompt+=$(yq_get ".agents.$agent.owns.never_edit | join(\", \")")
                prompt+="\n"
            fi
            prompt+="\n"
        fi
    
        # Commands (for PM-like agents)
        local cmds_count
        cmds_count=$(yq_get ".agents.$agent.commands // {} | length")
        if [ "$cmds_count" != "0" ]; then
            prompt+="## COMMANDS (when the user says these)\n"
            # Use yq to emit key=value pairs directly to avoid quoting issues
            while IFS= read -r line; do
                local key="${line%%=*}"
                local val="${line#*=}"
                val="${val//\{repo\}/$REPO_NAME}"
                prompt+="- \"${key}\" → ${val}\n"
            done < <(yq_get ".agents.$agent.commands // {} | to_entries | .[] | .key + \"=\" + .value")
            prompt+="\n"
        fi
    
        # Extra prompt text
        local extra
        extra=$(yq_get ".agents.$agent.prompt_extra // \"\"")
        if [ -n "$extra" ] && [ "$extra" != "\"\"" ] && [ "$extra" != "" ]; then
            prompt+="\n${extra}\n"
        fi
    
        # Stale task recovery for architect (auto_start agents)
        local agent_auto_start
        agent_auto_start=$(yq_get ".agents.$agent.auto_start // false")
        if [ "$agent_auto_start" = "true" ]; then
            prompt+="## STALE TASK RECOVERY\n"
            prompt+="Worker agents auto-send DONE messages when their session ends. However, if you\n"
            prompt+="have been waiting for DONE messages for more than 2 minutes, ping each dispatched\n"
            prompt+="worker to check their status:\n"
            for other in "${AGENTS[@]}"; do
                if [ "$other" != "$agent" ] && [ "$(yq_get ".agents.$other.interactive")" != "true" ] && [ "$(yq_get ".agents.$other.auto_start // false")" != "true" ]; then
                    local other_upper
                    other_upper=$(echo "$other" | tr '[:lower:]' '[:upper:]')
                    prompt+="  ${PROMPT_DIR}/send-to-agent.sh ${other_upper} 'STATUS: Are you done? Reply DONE-${other} if finished.'\n"
                fi
            done
            prompt+="\n"
        fi

        # Completion safety net for architect
        if [ "$agent_auto_start" = "true" ]; then
            prompt+="## COMPLETION SAFETY NET\n"
            prompt+="Before sending COMPLETE to PM, ALWAYS run this command first:\n"
            prompt+="  touch ${PROMPT_DIR}/triggers/.work-done\n"
            prompt+="This ensures PM gets notified even if your session ends unexpectedly.\n\n"
        fi

        # Shared completion policy for all non-interactive agents
        if [ "$interactive" != "true" ]; then
            prompt+="## DEFINITION OF DONE\n"
            prompt+="- Do NOT report done based only on code changes or unit tests.\n"
            prompt+="- Document required services, env vars, migrations, seed data, and startup steps relevant to your task.\n"
            prompt+="- Include the exact commands you used to verify the change.\n"
            prompt+="- If the task depends on infrastructure that is unavailable or unverifiable, report BLOCKED with the exact missing prerequisite.\n"
            prompt+="- Only send DONE when the work, documentation, and verification evidence are all in place.\n\n"
        fi

        # Important rules for event-driven agents
        if [ "$interactive" != "true" ]; then
            prompt+="## IMPORTANT\n"
            prompt+="- If the PM sends you a message (stop, pause, status), handle it immediately.\n"
            prompt+="- ALWAYS post your done marker on the ticket when you finish your tasks.\n"
        fi

        # Status update instructions for non-interactive agents
        if [ "$interactive" != "true" ]; then
            local state_file_path="${PROMPT_DIR}/triggers/${agent}.state"
            prompt+="\n## STATUS UPDATES\n"
            prompt+="Update your own status by writing to your state file:\n"
            prompt+="  echo \"thinking \$(date +%s)\" > ${state_file_path}      # deep analysis\n"
            prompt+="  echo \"waitinginput \$(date +%s)\" > ${state_file_path}   # when asking user\n"
            prompt+="  echo \"retrying \$(date +%s)\" > ${state_file_path}       # after transient error\n\n"
        fi

        # Shared context/memory instructions
        if [ "$MEMORY_ENABLED" = "true" ]; then
            local agents_doc_path="${REPO_DIR}/${MEMORY_AGENTS_DOC}"
            prompt+="\n## SHARED CONTEXT\n"
            prompt+="The team maintains a shared knowledge base. Read stable rules at the start of every task:\n"
            prompt+="  cat '${agents_doc_path}'\n\n"

            if [ "$agent_auto_start" = "true" ]; then
                prompt+="### Shared State (you maintain this)\n"
                prompt+="The team shares a single state file: ${STATE_FILE}\n\n"
                prompt+="Before dispatching tasks, register the issue:\n"
                prompt+="  bash '${PROMPT_DIR}/update-state.sh' '${STATE_FILE}' set-issue <ID> '<title>' '<context>'\n\n"
                prompt+="Record decisions:\n"
                prompt+="  bash '${PROMPT_DIR}/update-state.sh' '${STATE_FILE}' add-decision '<decision text>'\n\n"
                prompt+="After an agent completes:\n"
                prompt+="  bash '${PROMPT_DIR}/update-state.sh' '${STATE_FILE}' update-agent <agent> done '<summary>'\n\n"
                prompt+="After ALL agents complete:\n"
                prompt+="  bash '${PROMPT_DIR}/update-state.sh' '${STATE_FILE}' complete-issue '<final summary>'\n\n"
                prompt+="### Context Packets — CRITICAL\n"
                prompt+="When dispatching a TASK via send-to-agent.sh, include a CONTEXT PACKET in the message.\n"
                prompt+="Generate one with:\n"
                prompt+="  bash '${PROMPT_DIR}/update-state.sh' '${STATE_FILE}' read-context\n\n"
                prompt+="Copy the output and include it in your TASK message so the worker has full context.\n"
                prompt+="Format your TASK messages like this:\n\n"
                prompt+="  TASK [Issue #N]: <brief description>\n\n"
                prompt+="  --- CONTEXT PACKET ---\n"
                prompt+="  Issue: #N — <title>\n"
                prompt+="  Context: <what this issue is about>\n"
                prompt+="  Decisions:\n"
                prompt+="  - <decision 1>\n"
                prompt+="  Agent Progress:\n"
                prompt+="  - <agent>: <status> — <summary>\n"
                prompt+="  --- END CONTEXT ---\n\n"
                prompt+="  Instructions:\n"
                prompt+="  1. ...\n"
                prompt+="  2. ...\n\n"
            else
                prompt+="### Shared Context\n"
                prompt+="Your TASK message includes a CONTEXT PACKET with all the information you need.\n"
                prompt+="You do NOT need to read external state files — everything is in the message.\n\n"
                prompt+="If you discover something important, update the shared state:\n"
                prompt+="  bash '${PROMPT_DIR}/update-state.sh' '${STATE_FILE}' update-agent ${agent} working '<progress note>'\n\n"
            fi
        fi

        printf '%b' "$prompt" > "$PROMPT_DIR/${agent}-system.txt"
    }
    
    # ==================== Generate Init Prompts ====================
    
    generate_init_prompt() {
        local agent="$1"
        local mode="default"
        [ "$TEST_MODE" = true ] && mode="test"
        [ -n "$ISSUE_NUM" ] && mode="issue"
    
        local init_text
        init_text=$(yq_get ".agents.$agent.init.$mode // .agents.$agent.init.default")
    
        # Handle {default} self-reference
        if [ "$init_text" = "{default}" ]; then
            init_text=$(yq_get ".agents.$agent.init.default")
        fi
    
        # Interpolate placeholders
        init_text="${init_text//\{issue_num\}/$ISSUE_NUM}"
        init_text="${init_text//\{repo\}/$REPO_NAME}"
    
        # For test mode with file-based tickets, point architect to the tickets directory
        if [ "$TEST_MODE" = true ] && [ "$agent" = "architect" ] && [ "$TICKET_SOURCE" = "file" ]; then
            local ticket_dir
            ticket_dir=$(yq_get '.tickets.file.directory // "./tickets"')
            init_text+="
    
    Look for ready tickets in the ${ticket_dir}/ directory. Read each .md file and check the
    frontmatter for 'status: ready'. Pick the first one you find, change its status to
    'status: in-progress' using sed, then plan and dispatch tasks to agents."
        elif [ "$TEST_MODE" = true ] && [ "$agent" = "architect" ]; then
            init_text+="
    
    MOCK ISSUE: Add a GET /ping endpoint to the Reddit agent
    ## Summary
    Add a simple health-check endpoint that returns the service status and current timestamp.
    ## Requirements
    - GET /ping endpoint on the Reddit agent returning JSON with status and timestamp
    - A frontend component showing the service latency
    - Tests covering the new functionality
    ## Acceptance Criteria
    - [ ] GET /ping returns 200 with JSON payload
    - [ ] Frontend displays ping latency
    - [ ] All tests pass"
        fi
    
        printf '%s' "$init_text" > "$PROMPT_DIR/${agent}-init.txt"
    }
    
    # ==================== Generate Launcher Scripts ====================
    
    # Map workflow.yaml tool names to Claude Code --allowedTools names
    get_allowed_tools() {
        local agent="$1"
        local tools_list=""
        while IFS= read -r tool; do
            case "$tool" in
                read)          tools_list+="Read," ;;
                edit)          tools_list+="Edit," ;;
                write)         tools_list+="Write," ;;
                bash)          tools_list+="Bash(*)," ;;
                glob)          tools_list+="Glob," ;;
                grep)          tools_list+="Grep," ;;
                task_list)     tools_list+="TaskList," ;;
                task_create)   tools_list+="TaskCreate," ;;
                task_update)   tools_list+="TaskUpdate," ;;
                send_message)  tools_list+="SendMessage," ;;
                *)             tools_list+="${tool}," ;;
            esac
        done < <(yq_get ".agents.$agent.tools[]" 2>/dev/null)
        # Remove trailing comma
        echo "${tools_list%,}"
    }

    # Map workflow.yaml tools to Codex sandbox mode
    get_codex_sandbox_mode() {
        local agent="$1"
        local has_write=false
        while IFS= read -r tool; do
            case "$tool" in
                edit|write) has_write=true ;;
            esac
        done < <(yq_get ".agents.$agent.tools[]" 2>/dev/null)
        if [ "$has_write" = true ]; then
            echo "workspace-write"
        else
            echo "read-only"
        fi
    }

    generate_launcher() {
        local agent="$1"
        local interactive
        interactive=$(yq_get ".agents.$agent.interactive")
        local label
        label=$(echo "$agent" | tr '[:lower:]' '[:upper:]')
        local allowed_tools auto_start_agent
        allowed_tools=$(get_allowed_tools "$agent")
        local provider model codex_sandbox
        provider=$(yq_get ".agents.$agent.provider // \"claude\"")
        model=$(yq_get ".agents.$agent.model // \"\"")
        codex_sandbox=$(get_codex_sandbox_mode "$agent")
        # Find the auto_start agent (architect) for DONE callbacks
        auto_start_agent=""
        auto_start_label=""
        for _a in "${AGENTS[@]}"; do
            if [ "$(yq_get ".agents.$_a.auto_start // false")" = "true" ]; then
                auto_start_agent="$_a"
                auto_start_label=$(echo "$_a" | tr '[:lower:]' '[:upper:]')
                break
            fi
        done
    
        if [ "$interactive" = "true" ]; then
            # Build list of non-interactive agents for the REPL
            local _agent_list=""
            for _a in "${AGENTS[@]}"; do
                [ "$_a" != "$agent" ] && _agent_list+="$_a "
            done
            _agent_list="${_agent_list% }"  # trim trailing space

            # Interactive agent (PM) — bash REPL with LLM fallback
            sed 's/^    //' > "$PROMPT_DIR/run-${agent}.sh" << LAUNCHER
    #!/bin/bash
    cd '${REPO_DIR}'
    printf '\033]0;${label}\007'
    SYSTEM_PROMPT=\$(cat '${PROMPT_DIR}/${agent}-system.txt')
    PROMPT_DIR='${PROMPT_DIR}'
    TRIGGER_DIR='${PROMPT_DIR}/triggers'
    mkdir -p "\$TRIGGER_DIR"
    _PROVIDER='${provider}'
    _MODEL='${model}'
    _CODEX_SANDBOX='${codex_sandbox}'

    # Agent list (non-interactive agents from workflow.yaml)
    AGENT_LIST="${_agent_list}"

    # Ticket commands (generated from workflow.yaml tickets.source)
    CMD_LIST_OPEN="${TICKET_LIST_OPEN}"
    CMD_LIST_READY="${TICKET_LIST_READY}"
    CMD_VIEW="${TICKET_VIEW}"
    CMD_CLAIM="${TICKET_CLAIM}"
    CMD_COMMENT="${TICKET_COMMENT}"
    CMD_CLOSE="${TICKET_CLOSE}"
    CMD_CREATE="${TICKET_CREATE}"
    CMD_LIST_STALE="${TICKET_LIST_STALE}"

    # Banner
    echo "╔══════════════════════════════════════╗"
    echo "║       ${label}                       ║"
    echo "╠══════════════════════════════════════╣"
    echo "║  Commands:                           ║"
    echo "║  • status                            ║"
    echo "║  • backlog                           ║"
    echo "║  • view <N>                          ║"
    echo "║  • close <N>                         ║"
    echo "║  • claim <N>                         ║"
    echo "║  • comment <N> <msg>                 ║"
    echo "║  • tell <agent> <msg>                ║"
    echo "║  • agents                            ║"
    echo "║  • stale                             ║"
    echo "║  • ai <prompt>  (uses LLM)           ║"
    echo "║  • help                              ║"
    echo "╚══════════════════════════════════════╝"
    echo ""

    # Background: watch for incoming messages (COMPLETE, etc.)
    (while true; do
        _PM_MSG=""
        # Collect per-sender trigger files
        for _tf in "\$TRIGGER_DIR/${agent}.from-"*.trigger; do
            [ -f "\$_tf" ] || continue
            _PM_MSG="\${_PM_MSG}\$(cat "\$_tf")
"
            rm -f "\$_tf"
        done
        # Legacy single trigger file (backward compat)
        if [ -f "\$TRIGGER_DIR/${agent}.trigger" ]; then
            _PM_MSG="\${_PM_MSG}\$(cat "\$TRIGGER_DIR/${agent}.trigger")
"
            rm -f "\$TRIGGER_DIR/${agent}.trigger"
        fi
        if [ -n "\$_PM_MSG" ]; then
            # ACK the pickup
            printf '%s\n' "ACK \$(date '+%H:%M:%S')" > "\$TRIGGER_DIR/${agent}.ack"
            echo ""
            echo "═══════════════════════════════════════"
            echo "  INCOMING MESSAGE"
            echo "═══════════════════════════════════════"
            echo "  \$_PM_MSG"
            echo "═══════════════════════════════════════"
            echo ""
            printf "PM> "
        fi
        sleep 2
    done) &
    BG_PID=\$!
    trap "kill \$BG_PID 2>/dev/null" EXIT

    # Pause helper — press any key to return to PM prompt
    _pm_pause() {
        echo ""
        echo "  (press Enter to continue)"
        read -r -s -n 1 2>/dev/null || true
    }

    # REPL
    while true; do
        read -r -p "PM> " INPUT || { sleep 1; continue; }
        [ -z "\$INPUT" ] && continue

        case "\$INPUT" in
            help)
                echo ""
                echo "  status              List open tickets"
                echo "  backlog             List ready tickets"
                echo "  view <N>            View ticket #N"
                echo "  close <N>           Close ticket #N"
                echo "  claim <N>           Claim ticket #N (mark in-progress)"
                echo "  comment <N> <msg>   Comment on ticket #N"
                echo "  tell <agent> <msg>  Send message to an agent"
                echo "  agents              Show agent statuses"
                echo "  stale               List stale in-progress tickets"
                echo "  ai <prompt>         Ask Claude (uses LLM tokens)"
                echo "  quit                Exit PM"
                echo ""
                ;;
            status)
                echo ""
                eval "\$CMD_LIST_OPEN" 2>/dev/null || echo "  (no tickets found)"
                _pm_pause
                ;;
            backlog|"show backlog")
                echo ""
                eval "\$CMD_LIST_READY" 2>/dev/null || echo "  (no ready tickets)"
                _pm_pause
                ;;
            stale)
                echo ""
                eval "\$CMD_LIST_STALE" 2>/dev/null | jq -r '.[] | "\(.number) \(.title)"' 2>/dev/null || echo "  (no stale tickets)"
                _pm_pause
                ;;
            view\ *|issue\ *)
                N=\$(echo "\$INPUT" | sed 's/^[a-z]* #*//' | tr -d ' ')
                eval "\$(echo "\$CMD_VIEW" | sed "s/\\\$N/\$N/g")" 2>/dev/null || echo "  ERROR: could not view ticket \$N"
                _pm_pause
                ;;
            close\ *|"close issue"\ *)
                N=\$(echo "\$INPUT" | sed 's/^close *issue *#*//' | sed 's/^close *//' | tr -d ' ')
                echo "  Closing ticket #\$N..."
                eval "\$(echo "\$CMD_CLOSE" | sed "s/\\\$N/\$N/g")" 2>/dev/null && echo "  Done." || echo "  ERROR: could not close ticket \$N"
                _pm_pause
                ;;
            claim\ *)
                N=\$(echo "\$INPUT" | sed 's/^claim *#*//' | tr -d ' ')
                echo "  Claiming ticket #\$N..."
                eval "\$(echo "\$CMD_CLAIM" | sed "s/\\\$N/\$N/g")" 2>/dev/null && echo "  Done." || echo "  ERROR: could not claim ticket \$N"
                _pm_pause
                ;;
            comment\ *)
                N=\$(echo "\$INPUT" | awk '{print \$2}' | tr -d '#')
                MSG=\$(echo "\$INPUT" | sed 's/^comment *[#0-9]* *//')
                eval "\$(echo "\$CMD_COMMENT" | sed "s/\\\$N/\$N/g" | sed "s/\\\$MSG/\$MSG/g")" 2>/dev/null && echo "  Comment added." || echo "  ERROR: could not comment on ticket \$N"
                _pm_pause
                ;;
            tell\ *)
                AGENT=\$(echo "\$INPUT" | awk '{print tolower(\$2)}')
                if ! echo " \$AGENT_LIST " | grep -q " \$AGENT "; then
                    echo "  Unknown agent: \$AGENT"
                    echo "  Available: \$AGENT_LIST"
                else
                    MSG=\$(echo "\$INPUT" | sed 's/^tell *[^ ]* *//')
                    AGENT_UPPER=\$(echo "\$AGENT" | tr '[:lower:]' '[:upper:]')
                    '${PROMPT_DIR}/send-to-agent.sh' "\$AGENT_UPPER" "\$MSG"
                    echo "  Sent to \$AGENT."
                fi
                _pm_pause
                ;;
            agents|team)
                echo ""
                printf "  %-14s %-2s %-13s %-10s %s\n" "AGENT" "" "STATUS" "DURATION" "PREVIEW"
                printf "  %-14s %-2s %-13s %-10s %s\n" "─────" "" "──────" "────────" "───────"
                _now=\$(date +%s)
                for _a in \$AGENT_LIST; do
                    _state_file="\$TRIGGER_DIR/\${_a}.state"
                    _status="idle"
                    _duration="—"
                    _preview=""
                    _icon="○"
                    if [ -f "\$_state_file" ]; then
                        _content=\$(cat "\$_state_file")
                        _status=\$(echo "\$_content" | awk '{print \$1}')
                        _ts=\$(echo "\$_content" | awk '{print \$2}')
                        _preview=\$(echo "\$_content" | cut -d' ' -f3- | cut -c1-30)
                        if [ -n "\$_ts" ] && echo "\$_ts" | grep -qE '^[0-9]+\$'; then
                            _elapsed=\$(( _now - _ts ))
                            _min=\$(( _elapsed / 60 ))
                            _sec=\$(( _elapsed % 60 ))
                            _duration="\${_min}m \${_sec}s"
                            if [ "\$_status" != "idle" ] && [ "\$_status" != "offline" ] && [ "\$_elapsed" -gt 300 ]; then
                                _status="offline"
                            fi
                        fi
                    fi
                    [ "\$_status" = "working" ] && _status="running"
                    case "\$_status" in
                        idle)          _icon="○" ;;
                        running)       _icon="●" ;;
                        thinking)      _icon="◌" ;;
                        waitinginput)  _icon="◎" ;;
                        error)         _icon="✗" ;;
                        retrying)      _icon="↺" ;;
                        offline)       _icon="■" ;;
                        *)             _icon="○" ;;
                    esac
                    printf "  %-14s %s  %-13s %-10s %s\n" "\$_a" "\$_icon" "\$_status" "\$_duration" "\$_preview"
                done
                _pm_pause
                ;;
            ai\ *)
                PROMPT=\$(echo "\$INPUT" | sed 's/^ai *//')
                echo ""
                if [ "\$_PROVIDER" = "codex" ]; then
                    printf '%s\n\n---\n\n%s' "\$SYSTEM_PROMPT" "\$PROMPT" | codex exec -m "\$_MODEL" -s "\$_CODEX_SANDBOX" --full-auto -
                else
                    echo "\$PROMPT" | claude -p --model "\$_MODEL" --append-system-prompt "\$SYSTEM_PROMPT" --allowedTools "${allowed_tools}" -n "${agent}"
                fi
                _pm_pause
                ;;
            quit|exit)
                echo "  Goodbye."
                break
                ;;
            *)
                # Unrecognized — fall back to LLM
                echo ""
                if [ "\$_PROVIDER" = "codex" ]; then
                    printf '%s\n\n---\n\n%s' "\$SYSTEM_PROMPT" "\$INPUT" | codex exec -m "\$_MODEL" -s "\$_CODEX_SANDBOX" --full-auto -
                else
                    echo "\$INPUT" | claude -p --model "\$_MODEL" --append-system-prompt "\$SYSTEM_PROMPT" --allowedTools "${allowed_tools}" -n "${agent}"
                fi
                _pm_pause
                ;;
        esac
    done
LAUNCHER
        else
            local starts_immediately
            starts_immediately=$(yq_get ".agents.$agent.auto_start // false")
    
            if [ "$starts_immediately" = "true" ]; then
                # Architect — starts immediately, restarts if session ends
                sed 's/^    //' > "$PROMPT_DIR/run-${agent}.sh" << LAUNCHER
    #!/bin/bash
    cd '${REPO_DIR}'
    printf '\033]0;${label}\007'
    SYSTEM_PROMPT=\$(cat '${PROMPT_DIR}/${agent}-system.txt')
    INIT_PROMPT=\$(cat '${PROMPT_DIR}/${agent}-init.txt')
    _PROVIDER='${provider}'
    _MODEL='${model}'
    _CODEX_SANDBOX='${codex_sandbox}'

    echo "╔══════════════════════════════════════╗"
    echo "║  ${label} agent"
    echo "║  Starting up..."
    echo "╚══════════════════════════════════════╝"
    echo ""

    TRIGGER_DIR='${PROMPT_DIR}/triggers'
    mkdir -p "\$TRIGGER_DIR"

    echo "idle \$(date +%s)" > "\$TRIGGER_DIR/${agent}.state"

    # Collect all per-sender trigger files (and legacy single file) into one message
    _collect_triggers() {
        local _collected=""
        # Per-sender trigger files
        for TRIGGER_FILE in "\$TRIGGER_DIR/${agent}.from-"*.trigger; do
            [ -f "\$TRIGGER_FILE" ] || continue
            _collected="\${_collected}\$(cat "\$TRIGGER_FILE")
"
            rm -f "\$TRIGGER_FILE"
        done
        # Legacy single trigger file (backward compat)
        if [ -f "\$TRIGGER_DIR/${agent}.trigger" ]; then
            _collected="\${_collected}\$(cat "\$TRIGGER_DIR/${agent}.trigger")
"
            rm -f "\$TRIGGER_DIR/${agent}.trigger"
        fi
        printf '%s' "\$_collected"
    }

    # Provider-aware CLI invocation
    _run_agent_cli() {
        local _msg="\$1"
        if [ "\$_PROVIDER" = "codex" ]; then
            printf '%s\n\n---\n\n%s' "\$SYSTEM_PROMPT" "\$_msg" | codex exec -m "\$_MODEL" -s "\$_CODEX_SANDBOX" --full-auto -
        else
            claude --model "\$_MODEL" --append-system-prompt "\$SYSTEM_PROMPT" --allowedTools "${allowed_tools}" -n "${agent}" "\$_msg"
        fi
        return \$?
    }

    # Track whether the architect has dispatched work and is waiting for DONE messages.
    # For non-interactive providers (codex), the session exits after dispatch,
    # so the loop must NOT pick up new tickets while workers are still running.
    _WORK_DISPATCHED=false
    _has_active_work() {
        # Check 1: state.json has an active issue with in-progress agents
        if [ -n "\$_STATE_FILE" ] && [ -f "\$_STATE_FILE" ] && command -v jq &>/dev/null; then
            local _active
            _active=\$(jq -r '.current_issue.status // empty' "\$_STATE_FILE" 2>/dev/null)
            [ "\$_active" = "in_progress" ] && return 0
        fi
        # Check 2: any worker has a non-idle state (running/working)
        for _ws in "\$TRIGGER_DIR/"*.state; do
            [ -f "\$_ws" ] || continue
            # Skip own state file
            case "\$_ws" in */${agent}.state) continue ;; esac
            local _st
            _st=\$(awk '{print \$1}' "\$_ws" 2>/dev/null)
            case "\$_st" in running|working|thinking) return 0 ;; esac
        done
        # Check 3: dispatched marker
        [ "\$_WORK_DISPATCHED" = true ] && return 0
        return 1
    }

    while true; do
        # Check for pending trigger files (messages arrived while session was down)
        PENDING_MSG=\$(_collect_triggers)
        if [ -n "\$PENDING_MSG" ]; then
            echo "running \$(date +%s) \${PENDING_MSG:0:50}" > "\$TRIGGER_DIR/${agent}.state"
            echo "--- [\$(date '+%H:%M:%S')] Found pending message (\${#PENDING_MSG} chars) — feeding to session ---"
            _run_agent_cli "\$PENDING_MSG"
            _CLAUDE_EXIT=\$?
            # After processing DONE/COMPLETE messages, work may be finished
            _WORK_DISPATCHED=false
        elif _has_active_work; then
            # Workers are still running — wait for their DONE triggers instead of picking up new tickets
            echo "idle \$(date +%s) waiting for workers" > "\$TRIGGER_DIR/${agent}.state"
            echo "--- [\$(date '+%H:%M:%S')] Workers still active. Waiting for DONE messages... ---"
            sleep 5
            continue
        else
            echo "running \$(date +%s)" > "\$TRIGGER_DIR/${agent}.state"
            _run_agent_cli "\$INIT_PROMPT"
            _CLAUDE_EXIT=\$?
            # After running init (which may dispatch tasks), mark work as dispatched
            _WORK_DISPATCHED=true
        fi
        echo ""
        if [ "\$_CLAUDE_EXIT" -ne 0 ]; then
            echo "error \$(date +%s)" > "\$TRIGGER_DIR/${agent}.state"
        else
            echo "idle \$(date +%s)" > "\$TRIGGER_DIR/${agent}.state"
        fi
        echo "--- [\$(date '+%H:%M:%S')] Session ended. Restarting in 5s... ---"
        # Auto-notify: guarantee COMPLETE reaches PM if session ended after work was done
        COMPLETE_MARKER="\$TRIGGER_DIR/.work-done"
        if [ -f "\$COMPLETE_MARKER" ]; then
            '${PROMPT_DIR}/send-to-agent.sh' PM "COMPLETE: All tasks finished (auto-notify)"
            echo "--- [\$(date '+%H:%M:%S')] Auto-sent COMPLETE to PM ---"
            rm -f "\$COMPLETE_MARKER"
            _WORK_DISPATCHED=false
        fi
        # Check for trigger files that arrived while session was active
        PENDING_MSG=\$(_collect_triggers)
        if [ -n "\$PENDING_MSG" ]; then
            echo "--- [\$(date '+%H:%M:%S')] Found pending message during post-session check (\${#PENDING_MSG} chars) ---"
            _run_agent_cli "\$PENDING_MSG"
            _WORK_DISPATCHED=false
        fi
        sleep 5
    done
LAUNCHER
            else
                # Worker agent — waits for a trigger file, then starts Claude with its contents
                sed 's/^    //' > "$PROMPT_DIR/run-${agent}.sh" << LAUNCHER
    #!/bin/bash
    cd '${REPO_DIR}'
    printf '\033]0;${label}\007'
    SYSTEM_PROMPT=\$(cat '${PROMPT_DIR}/${agent}-system.txt')
    TRIGGER_DIR='${PROMPT_DIR}/triggers'
    mkdir -p "\$TRIGGER_DIR"
    _PROVIDER='${provider}'
    _MODEL='${model}'
    _CODEX_SANDBOX='${codex_sandbox}'

    echo "╔══════════════════════════════════════╗"
    echo "║  ${label} agent"
    echo "║  Idle — waiting for messages..."
    echo "╚══════════════════════════════════════╝"
    echo ""

    echo "idle \$(date +%s)" > "\$TRIGGER_DIR/${agent}.state"

    # Collect all per-sender trigger files (and legacy single file) into work file
    _collect_worker_triggers() {
        local _work="\$TRIGGER_DIR/${agent}.msg"
        local _found=false
        : > "\$_work"
        for _tf in "\$TRIGGER_DIR/${agent}.from-"*.trigger; do
            [ -f "\$_tf" ] || continue
            cat "\$_tf" >> "\$_work"
            printf '\n' >> "\$_work"
            rm -f "\$_tf"
            _found=true
        done
        # Legacy single trigger file (backward compat)
        if [ -f "\$TRIGGER_DIR/${agent}.trigger" ]; then
            cat "\$TRIGGER_DIR/${agent}.trigger" >> "\$_work"
            printf '\n' >> "\$_work"
            rm -f "\$TRIGGER_DIR/${agent}.trigger"
            _found=true
        fi
        if [ "\$_found" = true ] && [ -s "\$_work" ]; then
            return 0
        fi
        rm -f "\$_work"
        return 1
    }

    # Event-driven loop: wait for trigger files, start Claude with their contents
    while true; do
        if _collect_worker_triggers; then
            WORK_FILE="\$TRIGGER_DIR/${agent}.msg"

            # ACK: confirm message pickup so sender knows we got it
            printf '%s\n' "ACK \$(date '+%H:%M:%S')" > "\$TRIGGER_DIR/${agent}.ack"

            if [ -s "\$WORK_FILE" ]; then
                TASK_PREVIEW=\$(head -c 50 "\$WORK_FILE")
                echo "running \$(date +%s) \$TASK_PREVIEW" > "\$TRIGGER_DIR/${agent}.state"
                PREVIEW=\$(head -c 200 "\$WORK_FILE")
                echo ""
                echo "--- [\$(date '+%H:%M:%S')] Received message (\$(wc -c < "\$WORK_FILE" | tr -d ' ') bytes) ---"
                echo "    \${PREVIEW:0:200}..."
                echo ""
                # Clean done-sent marker from previous run
                rm -f "\$TRIGGER_DIR/${agent}.done-sent"
                # Pipe from file to avoid CLI argument length limits on long messages
                if [ "\$_PROVIDER" = "codex" ]; then
                    printf '%s\n\n---\n\n%s' "\$SYSTEM_PROMPT" "\$(cat "\$WORK_FILE")" | codex exec -m "\$_MODEL" -s "\$_CODEX_SANDBOX" --full-auto -
                else
                    cat "\$WORK_FILE" | claude -p --model "\$_MODEL" --append-system-prompt "\$SYSTEM_PROMPT" --allowedTools "${allowed_tools}" -n "${agent}"
                fi
                _CLAUDE_EXIT=\$?
                echo ""
                # Auto-notify: only send DONE if the agent didn't already send it
                if [ ! -f "\$TRIGGER_DIR/${agent}.done-sent" ]; then
                    '${PROMPT_DIR}/send-to-agent.sh' '${auto_start_label}' "DONE-${agent}: Task completed (auto-notify)"
                    echo "--- [\$(date '+%H:%M:%S')] Auto-sent DONE-${agent} to ${auto_start_agent} ---"
                else
                    echo "--- [\$(date '+%H:%M:%S')] Agent already sent DONE — skipping auto-notify ---"
                fi
                rm -f "\$TRIGGER_DIR/${agent}.done-sent"
                if [ "\$_CLAUDE_EXIT" -ne 0 ]; then
                    echo "error \$(date +%s)" > "\$TRIGGER_DIR/${agent}.state"
                else
                    echo "idle \$(date +%s)" > "\$TRIGGER_DIR/${agent}.state"
                fi
                echo "--- [\$(date '+%H:%M:%S')] Session ended. Waiting for next message... ---"
                echo ""
            else
                echo "--- [\$(date '+%H:%M:%S')] WARNING: trigger file was empty — skipping ---" >&2
            fi
            rm -f "\$WORK_FILE"
        else
            sleep 1
        fi
    done
LAUNCHER
            fi
        fi
        chmod +x "$PROMPT_DIR/run-${agent}.sh"
    }
    
    # ==================== Generate All Prompts & Launchers ====================
    
    echo "Reading workflow.yaml..."
    echo "  Project: ${PROJECT_NAME}"
    echo "  Ticket source: ${TICKET_SOURCE}"
    echo "  Agents: ${AGENTS[*]}"
    echo ""
    
    for agent in "${AGENTS[@]}"; do
        generate_system_prompt "$agent"
        generate_init_prompt "$agent"
        generate_launcher "$agent"
    done
    
    # ==================== Cleanup Previous Sessions ====================
    
    echo "Cleaning up previous agent sessions..."

    # Remove stale trigger files from previous runs
    rm -rf "$PROMPT_DIR/triggers" 2>/dev/null || true

    # Kill any existing tmux session from a previous run
    tmux kill-session -t dunno-agents 2>/dev/null || true
    sleep 1
    
    # ==================== Ensure Ticket Source Labels ====================
    
    if [ "$TICKET_SOURCE" = "github" ]; then
        echo "Ensuring GitHub labels exist..."
        local_repo=$(yq_get '.tickets.github.repo // .project.repo')
        gh label create "$(yq_get '.tickets.github.labels.ready')" --color "0E8A16" --description "Ready for agent team" --repo "$local_repo" 2>/dev/null || true
        gh label create "$(yq_get '.tickets.github.labels.in_progress')" --color "FBCA04" --description "Agent team working" --repo "$local_repo" 2>/dev/null || true
        gh label create "$(yq_get '.tickets.github.labels.done')" --color "6F42C1" --description "Agent team completed" --repo "$local_repo" 2>/dev/null || true
    
        if [ -n "$ISSUE_NUM" ]; then
            gh issue edit "$ISSUE_NUM" --repo "$local_repo" --add-label "$(yq_get '.tickets.github.labels.ready')" 2>/dev/null || true
        fi
    fi
    
    # ==================== Debug: Logging Scripts ====================
    
    if [ "$DEBUG_MODE" = true ]; then
    
    # Build agent list for Python logger
    AGENT_PY_LIST=""
    AGENT_PY_COLORS=""
    AGENT_PY_LABELS=""
    COLOR_CODES=("35" "34" "32" "33" "31" "36" "37" "91" "92" "93")
    SHORT_LABELS=("PM" "ARCH" "BACK" "FRONT" "QA" "DEV" "OPS" "SEC" "DOC" "INF")
    idx=0
    for agent in "${AGENTS[@]}"; do
        label=${SHORT_LABELS[$idx]:-$(echo "$agent" | tr '[:lower:]' '[:upper:]' | cut -c1-4)}
        color=${COLOR_CODES[$idx]:-37}
        AGENT_PY_LIST+="\"${agent}\", "
        AGENT_PY_COLORS+="    \"${agent}\": \"\\033[${color}m\",\n"
        AGENT_PY_LABELS+="    \"${agent}\": \"${label}\",\n"
        ((idx++))
    done
    
    sed 's/^    //' > "$PROMPT_DIR/screen-logger.py" << PYLOGGER
    #!/usr/bin/env python3
    """
    Polls iTerm2 session screen contents every 2 seconds and writes
    filtered, formatted lines to per-agent log files. Filters out noise
    (bash/sleep, tips), emphasizes inter-agent messages and test failures,
    collapses polling waits, and sends iTerm2 notifications.
    """
    import iterm2
    import asyncio
    import os
    import glob
    import re
    import subprocess
    import time
    
    LOG_DIR = "${LOG_DIR}"
    POLL_INTERVAL = 2
    
    AGENTS = [${AGENT_PY_LIST}]
    
    COLORS = {
    $(printf '%b' "$AGENT_PY_COLORS")}
    BOLD = "\033[1m"
    RESET = "\033[0m"
    LABELS = {
    $(printf '%b' "$AGENT_PY_LABELS")}
    
    # ── Filtering patterns ──
    SKIP_PATTERNS = [
        r"^\s*\$\s*$",
        r"Bash\s*\(\s*sleep",
        r"^\s*sleep\s+\d+",
        r"^Tip:",
        r"^💡\s*Tip",
        r"^\s*╭─+╮\s*$",
        r"^\s*│.*Tip.*│\s*$",
        r"^\s*╰─+╯\s*$",
        r"^Waiting for input\.\.\.",
        r"^>\s*$",
        r"find tasks.*work on them",
        r"You may also receive TASK:",
        r"polling loop",
        r"resume polling",
        r"Run TaskList.*find tasks",
    ]
    SKIP_RE = [re.compile(p, re.IGNORECASE) for p in SKIP_PATTERNS]
    
    AGENT_MSG_PATTERNS = [
        re.compile(r"TASK\s*(\[|:)", re.IGNORECASE),
        re.compile(r"BUG\s*:", re.IGNORECASE),
        re.compile(r"COMPLETE\s*:", re.IGNORECASE),
        re.compile(r"send-to-agent\.sh", re.IGNORECASE),
        re.compile(r"Done-\w+", re.IGNORECASE),
        re.compile(r"DONE-\w+", re.IGNORECASE),
        re.compile(r"REVIEW-REQUEST", re.IGNORECASE),
        re.compile(r"REVIEW-APPROVED", re.IGNORECASE),
        re.compile(r"REVIEW-REJECTED", re.IGNORECASE),
    ]
    
    TEST_FAIL_PATTERNS = [
        re.compile(r"FAILED", re.IGNORECASE),
        re.compile(r"FAIL[:\s]", re.IGNORECASE),
        re.compile(r"Error:.*test", re.IGNORECASE),
        re.compile(r"AssertionError", re.IGNORECASE),
        re.compile(r"\d+ failed", re.IGNORECASE),
        re.compile(r"ERRORS?!", re.IGNORECASE),
        re.compile(r"test.*failed", re.IGNORECASE),
    ]
    
    ACCEPT_EDIT_RE = re.compile(r"(allow|accept)\s*(edit|once|always)", re.IGNORECASE)
    
    WAITING_PATTERNS = [
        re.compile(r"No tasks?\.\s*Will check", re.IGNORECASE),
        re.compile(r"Polling for work", re.IGNORECASE),
        re.compile(r"no.*pending.*task", re.IGNORECASE),
        re.compile(r"NO_TASKS", re.IGNORECASE),
        re.compile(r"Run TaskList", re.IGNORECASE),
        re.compile(r"Session ended\. Restarting", re.IGNORECASE),
        re.compile(r"sleep\s+\d+.*then.*check", re.IGNORECASE),
        re.compile(r"TaskList.*no.*tasks", re.IGNORECASE),
    ]
    
    def should_skip(line): return any(p.search(line) for p in SKIP_RE)
    def is_agent_message(line): return any(p.search(line) for p in AGENT_MSG_PATTERNS)
    def is_test_failure(line): return any(p.search(line) for p in TEST_FAIL_PATTERNS)
    def is_accept_edit(line): return bool(ACCEPT_EDIT_RE.search(line))
    def is_waiting(line): return any(p.search(line) for p in WAITING_PATTERNS)
    
    def send_notification(title, message):
        try:
            subprocess.Popen(
                ["osascript", "-e",
                 f'display notification "{message}" with title "{title}" sound name "Glass"'],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        except Exception:
            pass
    
    TRIGGER_DIR = os.path.join(os.path.dirname(LOG_DIR.rstrip("/")), ".team-prompts", "triggers")
    SESSION_START = time.time()
    DASHBOARD_LINES = 0

    def render_dashboard():
        global DASHBOARD_LINES
        now = time.time()
        session_elapsed = int(now - SESSION_START)
        sm, ss = divmod(session_elapsed, 60)
        sh, sm = divmod(sm, 60)

        lines = []
        lines.append("┌─ DASHBOARD ──────────────────────────────────────────────┐")
        done_count = 0
        working_count = 0
        pending_count = 0
        for agent in AGENTS:
            state_file = os.path.join(TRIGGER_DIR, f"{agent}.state")
            status = "idle"
            duration = "—"
            task_preview = ""
            state_ts = 0
            if os.path.exists(state_file):
                try:
                    content = open(state_file).read().strip()
                    parts = content.split(" ", 2)
                    status = parts[0] if parts else "idle"
                    if len(parts) >= 2:
                        state_ts = int(parts[1])
                        elapsed = int(now - state_ts)
                        em, es = divmod(elapsed, 60)
                        duration = f"{em}m {es:02d}s"
                    if len(parts) >= 3:
                        task_preview = parts[2][:40]
                except Exception:
                    pass
            # Also check trigger/msg files as fallback
            msg_file = os.path.join(TRIGGER_DIR, f"{agent}.msg")
            trigger_file = os.path.join(TRIGGER_DIR, f"{agent}.trigger")
            done_file = os.path.join(TRIGGER_DIR, f"{agent}.done-sent")
            # Normalize legacy "working" status
            if status == "working":
                status = "running"
            # Offline detection: active status with stale timestamp (>300s)
            if status not in ("idle", "offline") and state_ts > 0:
                if int(now - state_ts) > 300:
                    status = "offline"
            if os.path.exists(msg_file) and status not in ("running", "thinking", "waitinginput", "retrying"):
                status = "running"
            if os.path.exists(done_file):
                done_count += 1
            # Status icon and color mapping for all 7 statuses
            status_map = {
                "idle":         ("○", ""),
                "running":      ("●", COLORS.get(agent, "\033[32m")),
                "thinking":     ("◌", "\033[36m"),
                "waitinginput": ("◎", "\033[33m"),
                "error":        ("✗", "\033[31m"),
                "retrying":     ("↺", "\033[33m"),
                "offline":      ("■", "\033[90m"),
            }
            if status in ("running", "thinking", "waitinginput", "retrying"):
                working_count += 1
            if os.path.exists(trigger_file) or glob.glob(os.path.join(TRIGGER_DIR, f"{agent}.from-*.trigger")):
                if status not in ("running", "thinking", "waitinginput", "retrying"):
                    pending_count += 1
                    status = "pending"
            icon, color = status_map.get(status, ("○", ""))
            if status == "pending":
                icon, color = "◉", "\033[33m"
            label = LABELS.get(agent, agent.upper())
            task_str = f"  {task_preview}" if task_preview else ""
            lines.append(f"│  {color}{label:<10}{RESET} {icon} {status:<10} {duration:<10}{task_str:<28}│")
        lines.append(f"│  Tasks: {done_count} done · {working_count} ongoing · {pending_count} pending{' ' * 20}│")
        if sh > 0:
            lines.append(f"│  Session: {sh}h {sm:02d}m {ss:02d}s{' ' * 38}│")
        else:
            lines.append(f"│  Session: {sm}m {ss:02d}s{' ' * 41}│")
        lines.append("└──────────────────────────────────────────────────────────┘")

        # Save cursor, move to top, render dashboard, restore cursor
        output = "\033[s\033[H"
        for line in lines:
            output += f"\033[K{line}\n"
        output += "\033[u"
        print(output, end="", flush=True)

        # Reserve space on first render
        if DASHBOARD_LINES == 0:
            DASHBOARD_LINES = len(lines)
            print("\n" * DASHBOARD_LINES, flush=True)

    async def main(connection):
        app = await iterm2.async_get_app(connection)
        sessions = {}
        for window in app.windows:
            for tab in window.tabs:
                for session in tab.sessions:
                    name = await session.async_get_variable("name")
                    if name is None: continue
                    name_lower = name.lower()
                    for agent in AGENTS:
                        if agent in name_lower and agent not in sessions:
                            sessions[agent] = session
                            break

        if not sessions:
            print("No agent sessions found. Retrying in 5s...")
            await asyncio.sleep(5)
            return

        print(f"Logging {len(sessions)} sessions (polling every {POLL_INTERVAL}s)")
        print()

        log_files = {}
        for agent in sessions:
            log_files[agent] = open(os.path.join(LOG_DIR, f"{agent}.log"), "a", buffering=1)

        prev_contents = {agent: "" for agent in sessions}
        waiting_since = {}
        last_notif = {}

        while True:
            render_dashboard()
            for agent, session in sessions.items():
                try:
                    contents = await session.async_get_screen_contents()
                    lines = []
                    for i in range(contents.number_of_lines):
                        lines.append(contents.line(i).string.rstrip())
                    current = "\n".join(lines)
                    if current != prev_contents[agent]:
                        prev_lines = prev_contents[agent].split("\n") if prev_contents[agent] else []
                        new_lines = lines[len(prev_lines):] if len(lines) > len(prev_lines) else lines
                        new_lines = [l for l in new_lines if l.strip()]
                        if not new_lines:
                            prev_contents[agent] = current
                            continue
                        color = COLORS.get(agent, "")
                        label = LABELS.get(agent, agent.upper())
                        now = time.time()
                        for line in new_lines:
                            if should_skip(line): continue
                            if is_waiting(line):
                                if agent not in waiting_since: waiting_since[agent] = now
                                elapsed = int(now - waiting_since[agent])
                                print(f"\r{color}[{label}]{RESET} ⏳ Waiting for tasks ({elapsed}s)...", end="", flush=True)
                                continue
                            else:
                                if agent in waiting_since:
                                    elapsed = int(now - waiting_since[agent])
                                    print(f"\r{color}[{label}]{RESET} ⏳ Done waiting ({elapsed}s)", flush=True)
                                    log_files[agent].write(f"⏳ Waited for tasks ({elapsed}s)\n")
                                    del waiting_since[agent]
                            if is_accept_edit(line):
                                log_files[agent].write("✏️  User accepted edit\n")
                                print(f"{color}[{label}]{RESET} ✏️  User accepted edit", flush=True)
                                continue
                            if is_agent_message(line):
                                log_files[agent].write(f"📨 {line}\n")
                                print(f"{BOLD}{color}[{label}]{RESET} {BOLD}📨 {line}{RESET}", flush=True)
                                if now - last_notif.get(agent, 0) > 10:
                                    send_notification(f"🤖 {label}", line[:120])
                                    last_notif[agent] = now
                                continue
                            if is_test_failure(line):
                                log_files[agent].write(f"❌ {line}\n")
                                print(f"{BOLD}{color}[{label}]{RESET} {BOLD}❌ {line}{RESET}", flush=True)
                                if now - last_notif.get(f"{agent}_fail", 0) > 10:
                                    send_notification(f"❌ Test Failed — {label}", line[:120])
                                    last_notif[f"{agent}_fail"] = now
                                continue
                            log_files[agent].write(line + "\n")
                            print(f"{color}[{label}]{RESET} {line}", flush=True)
                        prev_contents[agent] = current
                except Exception:
                    pass
            await asyncio.sleep(POLL_INTERVAL)
    
    iterm2.run_until_complete(main)
PYLOGGER
    chmod +x "$PROMPT_DIR/screen-logger.py"
    
    # LOGS pane launcher
    sed 's/^    //' > "$PROMPT_DIR/run-logs.sh" << LOGSCRIPT
    #!/bin/bash
    echo "╔══════════════════════════════════════╗"
    echo "║       TEAM LOGS (live)               ║"
    echo "╚══════════════════════════════════════╝"
    echo ""
    LOG_DIR="${LOG_DIR}"
    echo "Waiting for log files in: \$LOG_DIR"
    while [ ! -d "\$LOG_DIR" ]; do sleep 1; done
    sleep 2
    exec tail -f "\$LOG_DIR"/*.log 2>/dev/null
LOGSCRIPT
    chmod +x "$PROMPT_DIR/run-logs.sh"
    
    fi  # end DEBUG_MODE scripts

    # ==================== Status Monitor Script ====================

    STATUS_AGENT_LIST=""
    for agent in "${AGENTS[@]}"; do
        STATUS_AGENT_LIST+="${agent} "
    done
    STATUS_AGENT_LIST="${STATUS_AGENT_LIST% }"

    sed 's/^    //' > "$PROMPT_DIR/run-status.sh" << STATUSSCRIPT
    #!/bin/bash
    printf '\033]0;STATUS\007'
    exec python3 '${PROMPT_DIR}/status-monitor.py' '${PROMPT_DIR}/triggers' ${STATUS_AGENT_LIST}
