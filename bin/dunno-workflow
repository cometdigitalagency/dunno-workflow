    chmod +x "$PROMPT_DIR/run-status.sh"

    cat > "$PROMPT_DIR/status-monitor.py" << 'PYMONITOR'
#!/usr/bin/env python3
"""dunno-workflow Status Monitor — VSCode-inspired sidebar
Left column (this pane): agent list with status + description for every agent.
Selecting an agent expands it in the right tmux area; sidebar stays visible.
Keys: ↑↓ navigate, Enter/Space = focus agent, g/Esc = restore grid, q = quit
Mouse: click agent row or ALL tab
"""
import curses, glob, os, subprocess, sys, time

TRIGGER_DIR      = sys.argv[1]
AGENTS           = sys.argv[2:]
SIDEBAR_W        = 28          # this pane's fixed width (matches build_tmux_session)
GRID_LAYOUT_FILE = os.path.join(TRIGGER_DIR, "grid.layout")
ALL_ROW          = 2           # sidebar row of the ALL tab
AGENT_ROW_H      = 3           # rows per agent: name row + status row + blank
AGENTS_START_ROW = 4           # first agent's name row

# Our own tmux pane ID — captured at startup while we ARE the active pane.
MY_PANE_ID = subprocess.run(
    ["tmux", "display-message", "-p", "#{pane_id}"],
    capture_output=True, text=True
).stdout.strip()

ICONS = {
    "idle": "○", "running": "●", "thinking": "◌",
    "waitinginput": "◎", "error": "✗", "retrying": "↺",
    "offline": "■", "pending": "◉",
}
STATUS_LABEL = {
    "idle": "Idle", "running": "Running", "thinking": "Thinking",
    "waitinginput": "Waiting", "error": "Error", "retrying": "Retry",
    "offline": "Offline", "pending": "Pending",
}

C_RUN, C_THK, C_WRN, C_ERR, C_HDR, C_SEL, C_FOC, C_DIM2 = range(1, 9)


def init_colors():
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(C_RUN,  curses.COLOR_GREEN,  -1)
    curses.init_pair(C_THK,  curses.COLOR_CYAN,   -1)
    curses.init_pair(C_WRN,  curses.COLOR_YELLOW, -1)
    curses.init_pair(C_ERR,  curses.COLOR_RED,    -1)
    curses.init_pair(C_HDR,  curses.COLOR_BLACK,  curses.COLOR_CYAN)
    curses.init_pair(C_SEL,  curses.COLOR_BLACK,  curses.COLOR_WHITE)
    curses.init_pair(C_FOC,  curses.COLOR_WHITE,  curses.COLOR_BLUE)
    curses.init_pair(C_DIM2, curses.COLOR_WHITE,  -1)


def status_cp(s):
    return {
        "running": C_RUN, "thinking": C_THK,
        "waitinginput": C_WRN, "retrying": C_WRN, "pending": C_WRN,
        "error": C_ERR,
    }.get(s, 0)


def read_state(agent):
    f = os.path.join(TRIGGER_DIR, f"{agent}.state")
    status, ts, preview = "idle", None, ""
    if os.path.exists(f):
        try:
            parts = open(f).read().strip().split(" ", 2)
            status = parts[0] if parts else "idle"
            if len(parts) > 1 and parts[1].isdigit():
                ts = int(parts[1])
            if len(parts) > 2:
                preview = parts[2]
        except Exception:
            pass
    triggers = glob.glob(os.path.join(TRIGGER_DIR, f"{agent}.from-*.trigger"))
    if os.path.exists(os.path.join(TRIGGER_DIR, f"{agent}.trigger")):
        triggers.append("x")
    if triggers and status == "idle":
        status = "pending"
    if ts and status not in ("idle", "offline") and time.time() - ts > 300:
        status = "offline"
    duration = ""
    if ts:
        e = int(time.time() - ts)
        duration = f"{e // 60}m {e % 60}s"
    return {"status": status, "duration": duration, "preview": preview}


def put(win, y, x, text, attr=0):
    h, w = win.getmaxyx()
    if y < 0 or y >= h or x < 0 or x >= w:
        return
    n = w - x - 1
    if n <= 0:
        return
    try:
        win.addstr(y, x, text[:n], attr)
    except curses.error:
        pass


# ── tmux helpers ──────────────────────────────────────────────────────────────

def tmux_pane_id(agent):
    try:
        return open(os.path.join(TRIGGER_DIR, f"{agent}.pane")).read().strip()
    except Exception:
        return None


def tmux_focus_layout(agent):
    """Expand agent to fill right area while keeping sidebar pinned.
    Two-step: (1) resize agent to 9999, (2) immediately pin sidebar back.
    Both happen in one shell invocation so the gap is sub-millisecond."""
    pane_id = tmux_pane_id(agent)
    if not pane_id or not MY_PANE_ID:
        return
    cmd = (
        f"tmux resize-pane -t {pane_id} -y 9999"
        f" ; tmux resize-pane -t {pane_id} -x 9999"
        f" ; tmux resize-pane -t {MY_PANE_ID} -x {SIDEBAR_W - 1}"
        f" ; tmux select-pane -t {pane_id}"
    )
    subprocess.Popen(["sh", "-c", cmd])


def tmux_restore_grid():
    """Restore exact grid layout from the saved layout string."""
    try:
        layout = open(GRID_LAYOUT_FILE).read().strip()
        layout_cmd = f"tmux select-layout \"{layout}\""
    except Exception:
        layout_cmd = "tmux select-layout tiled"
    cmd = (
        f"{layout_cmd}"
        f" ; tmux resize-pane -t {MY_PANE_ID} -x {SIDEBAR_W - 1}"
        f" ; tmux select-pane -t {MY_PANE_ID}"
    )
    subprocess.Popen(["sh", "-c", cmd])


# ── Sidebar drawing ───────────────────────────────────────────────────────────

def draw_sidebar(win, states, sel, focused, elapsed):
    h, w = win.getmaxyx()
    sw = min(w, SIDEBAR_W)

    # Header
    put(win, 0, 0, " AGENTS".ljust(sw - 1), curses.color_pair(C_HDR) | curses.A_BOLD)
    put(win, 1, 0, "─" * (sw - 1), curses.A_DIM)

    # ALL tab
    all_attr = (curses.color_pair(C_FOC) | curses.A_BOLD) if focused is None else (
               curses.color_pair(C_SEL) if sel == 0 else curses.A_DIM)
    put(win, ALL_ROW, 0, f" ⊞ ALL  ({len(AGENTS)} agents)".ljust(sw - 1), all_attr)
    put(win, 3, 0, "─" * (sw - 1), curses.A_DIM)

    # Agent list — always fully drawn regardless of focus state
    # Each agent occupies AGENT_ROW_H rows:
    #   row 0:  [icon] NAME
    #   row 1:  STATUS  DURATION  description...
    #   row 2:  (blank separator)
    max_desc = sw - 3   # available chars for description on row 1

    for i, agent in enumerate(AGENTS):
        base = AGENTS_START_ROW + i * AGENT_ROW_H
        if base + 1 >= h - 7:
            break

        st       = states.get(agent, {})
        status   = st.get("status", "idle")
        duration = st.get("duration", "—")
        preview  = st.get("preview", "")
        icon     = ICONS.get(status, "○")
        label    = STATUS_LABEL.get(status, status.capitalize())
        cp       = status_cp(status)

        # Row 0: icon + agent name — highlighted if focused or cursor-selected
        if focused == agent:
            name_attr = curses.color_pair(C_FOC) | curses.A_BOLD
        elif sel == i + 1:
            name_attr = curses.color_pair(C_SEL) | curses.A_BOLD
        else:
            name_attr = curses.color_pair(cp) | curses.A_BOLD

        name_line = f" {icon} {agent.upper()}"
        put(win, base, 0, name_line.ljust(sw - 1), name_attr)

        # Row 1: status label + duration + description
        dur_str  = duration if duration else "—"
        desc     = preview[:max(0, sw - 3 - len(label) - len(dur_str) - 3)]
        row1     = f"   {label} {dur_str}"
        if desc:
            row1 += f"  {desc}"
        put(win, base + 1, 0, row1.ljust(sw - 1),
            curses.color_pair(cp) if cp else curses.A_DIM)

        # Row 2: blank (separator)
        put(win, base + 2, 0, " " * (sw - 1))

    # ── Status summary pinned to bottom ──────────────────────────────────────
    counts = {}
    for st in states.values():
        s = st.get("status", "idle")
        counts[s] = counts.get(s, 0) + 1

    run_n  = counts.get("running", 0) + counts.get("thinking", 0)
    idle_n = counts.get("idle", 0)
    wait_n = counts.get("pending", 0)
    err_n  = counts.get("error", 0) + counts.get("offline", 0)
    sm, ss = elapsed // 60, elapsed % 60

    put(win, h - 6, 0, "─" * (sw - 1), curses.A_DIM)
    put(win, h - 5, 0,
        f" ● {run_n} running  ○ {idle_n} idle".ljust(sw - 1),
        curses.color_pair(C_RUN) if run_n else curses.A_DIM)
    put(win, h - 4, 0,
        (f" ✗ {err_n} error  ◉ {wait_n} pending".ljust(sw - 1)
         if err_n or wait_n else " " * (sw - 1)),
        curses.color_pair(C_ERR) if err_n else curses.color_pair(C_WRN) if wait_n else curses.A_DIM)
    put(win, h - 3, 0, "─" * (sw - 1), curses.A_DIM)
    put(win, h - 2, 0, f" {sm}m{ss}s  ↑↓↵  g=all  q=quit".ljust(sw - 1), curses.A_DIM)


# ── Main loop ─────────────────────────────────────────────────────────────────

def main(stdscr):
    curses.curs_set(0)
    init_colors()
    curses.mousemask(curses.ALL_MOUSE_EVENTS | curses.REPORT_MOUSE_POSITION)
    stdscr.timeout(2000)

    focused = None
    sel     = 0      # 0 = ALL tab, 1..N = agents[0..N-1]
    t0      = time.time()

    while True:
        try:
            h, w = stdscr.getmaxyx()
            # Guard: if our pane has been crushed too narrow/short, just wait
            if h < 8 or w < 8:
                stdscr.getch()
                curses.update_lines_cols()
                continue

            states  = {a: read_state(a) for a in AGENTS}
            elapsed = int(time.time() - t0)

            stdscr.erase()
            draw_sidebar(stdscr, states, sel, focused, elapsed)
            stdscr.refresh()

        except curses.error:
            time.sleep(0.1)
            try:
                curses.update_lines_cols()
            except curses.error:
                pass
            continue

        key = stdscr.getch()

        if key == ord("q"):
            break
        elif key == curses.KEY_UP:
            sel = max(0, sel - 1)
        elif key == curses.KEY_DOWN:
            sel = min(len(AGENTS), sel + 1)
        elif key in (curses.KEY_ENTER, ord("\n"), ord(" ")):
            if sel == 0:
                focused = None
                tmux_restore_grid()
            elif 1 <= sel <= len(AGENTS):
                focused = AGENTS[sel - 1]
                tmux_focus_layout(focused)
        elif key in (ord("g"), ord("a"), 27):
            focused = None
            sel = 0
            tmux_restore_grid()
        elif key == curses.KEY_MOUSE:
            try:
                _, mx, my, _, bstate = curses.getmouse()
                if bstate & curses.BUTTON1_CLICKED and mx < SIDEBAR_W - 1:
                    if my == ALL_ROW:
                        focused = None
                        sel = 0
                        tmux_restore_grid()
                    elif my >= AGENTS_START_ROW:
                        # Map click row → agent index (each agent takes AGENT_ROW_H rows)
                        idx = (my - AGENTS_START_ROW) // AGENT_ROW_H
                        if 0 <= idx < len(AGENTS):
                            ag = AGENTS[idx]
                            if focused == ag:
                                focused = None
                                sel = 0
                                tmux_restore_grid()
                            else:
                                focused = ag
                                sel = idx + 1
                                tmux_focus_layout(ag)
            except curses.error:
                pass
        elif key == curses.KEY_RESIZE:
            curses.update_lines_cols()


curses.wrapper(main)
PYMONITOR
    chmod +x "$PROMPT_DIR/status-monitor.py"

    # ==================== Launch Info ====================
    
    echo "=========================================="
    echo "  Launching Agent Team in iTerm2"
    [ "$TEST_MODE" = true ] && echo "  MODE: TEST (mock issue, no ticket source)"
    [ -n "$ISSUE_NUM" ] && echo "  Ticket #${ISSUE_NUM} queued for architect"
    [ "$DEBUG_MODE" = true ] && echo "  DEBUG: Logging enabled → ${LOG_DIR}"
    echo "=========================================="
    echo ""
    
    # ==================== tmux: Dynamic Layout ====================

    # All agents: interactive first, then workers
    ALL_AGENTS=("$INTERACTIVE_AGENT" "${WORKER_AGENTS[@]}")
    NUM_ALL=${#ALL_AGENTS[@]}

    build_tmux_session() {
        local session="dunno-agents"

        # Create session; first pane becomes the STATUS sidebar
        tmux new-session -d -s "$session" -x 220 -y 55

        # tmux options
        tmux set-option -t "$session" mouse on
        tmux set-option -t "$session" status off
        tmux set-option -t "$session" pane-border-status top
        tmux set-option -t "$session" pane-border-format " #[bold]#{pane_title}#[nobold] "

        # Capture STATUS pane ID
        local STATUS_PANE
        STATUS_PANE=$(tmux display -p -t "${session}:0.0" '#{pane_id}')

        # Split right for the first agent pane
        tmux split-window -h -t "${STATUS_PANE}"
        local PANE_IDS
        PANE_IDS=()
        PANE_IDS+=("$(tmux display -p -t "${session}:" '#{pane_id}')")

        # Resize sidebar to 27 cols (SIDEBAR_W=28 minus border)
        tmux resize-pane -t "${STATUS_PANE}" -x 27

        # Build 2-column agent grid for remaining agents
        local i=1
        while [ $i -lt "$NUM_ALL" ]; do
            local col=$(( i % 2 ))
            if [ "$col" -eq 1 ]; then
                # Right column: split right from the left-column pane in this row
                tmux split-window -h -t "${PANE_IDS[$((i-1))]}"
            else
                # Left column: split down from the pane two positions back
                tmux split-window -v -t "${PANE_IDS[$((i-2))]}"
            fi
            PANE_IDS+=("$(tmux display -p -t "${session}:" '#{pane_id}')")
            ((i++))
        done

        # Name panes and write pane IDs to trigger files for send-to-agent
        mkdir -p "$PROMPT_DIR/triggers"
        tmux select-pane -t "${STATUS_PANE}" -T "STATUS"
        local ai=0
        while [ $ai -lt "$NUM_ALL" ]; do
            local agent="${ALL_AGENTS[$ai]}"
            local label
            label=$(echo "$agent" | tr '[:lower:]' '[:upper:]')
            tmux select-pane -t "${PANE_IDS[$ai]}" -T "$label"
            echo "${PANE_IDS[$ai]}" > "$PROMPT_DIR/triggers/${agent}.pane"
            ((ai++))
        done

        # Key binding: Prefix+g → back to grid (unzoom + focus sidebar)
        tmux bind-key -T prefix g \
            run-shell 'tmux resize-pane -Z -t dunno-agents: 2>/dev/null; tmux select-pane -t dunno-agents:0.0 2>/dev/null'

        # Launch STATUS monitor in sidebar pane
        tmux send-keys -t "${STATUS_PANE}" "bash -l '${PROMPT_DIR}/run-status.sh'" Enter

        # Launch each agent in its pane
        local li=0
        while [ $li -lt "$NUM_ALL" ]; do
            local agent="${ALL_AGENTS[$li]}"
            tmux send-keys -t "${PANE_IDS[$li]}" "bash -l '${PROMPT_DIR}/run-${agent}.sh'" Enter
            ((li++))
        done

        # Save grid layout so status-monitor can restore it after focus mode
        sleep 0.3
        tmux display -p -t "${session}:0" '#{window_layout}' \
            > "$PROMPT_DIR/triggers/grid.layout" 2>/dev/null || true

        # DEBUG: open LOGS in a separate tmux window, then return to main window
        if [ "$DEBUG_MODE" = true ]; then
            tmux new-window -t "${session}" -n "LOGS"
            tmux send-keys -t "${session}:LOGS" "bash -l '${PROMPT_DIR}/run-logs.sh'" Enter
            tmux select-window -t "${session}:0"
        fi

        # Open iTerm2 attached to the tmux session
        osascript << OSAEND 2>/dev/null
tell application "iTerm"
    activate
    set newWin to (create window with default profile command "$(command -v tmux) attach-session -t ${session}")
    set bounds of newWin to {0, 0, 9999, 9999}
end tell
OSAEND
    }

    build_tmux_session

    # ==================== Post-launch Info ====================
    
    echo ""
    echo "Team launched! (${#AGENTS[@]} agents) — tmux session: dunno-agents"
    echo ""
    echo "  Navigation (tmux):"
    echo "    • Click any pane        → focus it, type into that agent"
    echo "    • Sidebar ↑↓ + Enter    → select agent, switch tmux focus to its pane"
    echo "    • Sidebar z             → zoom selected agent to full screen"
    echo "    • Prefix + z            → toggle zoom on current pane"
    echo "    • Prefix + g            → unzoom, return to grid"
    echo "    • Prefix + arrow        → navigate between panes"
    echo ""
    echo "  Sidebar keys (when sidebar pane is active):"
    echo "    • g / Escape            → show all agents (grid view)"
    echo "    • q                     → quit status monitor"
}

# ==================== Dispatch ====================

case "${1:-}" in
    start)          shift; cmd_start "$@" ;;
    init)           shift; cmd_init "$@" ;;
    validate)       cmd_validate ;;
    analyze)        shift; cmd_analyze "$@" ;;
    stop)           cmd_stop ;;
    context)        shift; cmd_context "$@" ;;
    version)        cmd_version ;;
    --version|-v)   cmd_version ;;
    --help|-h|help|"") show_help ;;
    *) echo "Unknown command: $1"; show_help; exit 1 ;;
esac
