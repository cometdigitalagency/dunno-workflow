#!/bin/bash
# =============================================================================
# dunno-workflow тАФ Launch Claude Code agent team in iTerm2 split panes
#
# Reads workflow.yaml from the current directory to configure agents, events,
# ticket sources, and layout. Generates prompts, launchers, and iTerm2 panes.
#
# Install: brew install cometdigitalagency/dunno/dunno-workflow
# Usage:   dunno-workflow start [--debug] [--test] [--issue N]
# =============================================================================

set -e

VERSION="0.3.1"

# ==================== Commands ====================

show_help() {
    echo "dunno-workflow v${VERSION} тАФ Declarative Claude Code agent teams"
    echo ""
    echo "Usage:"
    echo "  dunno-workflow init               Create workflow.yaml in current directory"
    echo "  dunno-workflow start [options]     Launch agent team in iTerm2"
    echo "  dunno-workflow validate            Validate workflow.yaml (schema + event graph)"
    echo "  dunno-workflow analyze [options]   Analyze logs for agent failures, create issues"
    echo "  dunno-workflow stop                Stop all running agent sessions"
    echo "  dunno-workflow version             Show version"
    echo ""
    echo "Global flags:"
    echo "  --help, -h          Show this help"
    echo "  --version, -v       Show version"
    echo ""
    echo "Start options:"
    echo "  --issue, -i <num>   Ticket number to work on"
    echo "  --test, -t          Test mode тАФ mock issue, no ticket source needed"
    echo "  --e2e, -e           End-to-end test тАФ small ticket through full PMтЖТarchitectтЖТworkersтЖТQA flow"
    echo "  --debug, -d         Enable LOGS pane with filtered session logging"
}

cmd_version() { echo "dunno-workflow v${VERSION}"; }

get_template_dir() {
    local script_path
    script_path="$(cd "$(dirname "$0")" && pwd)"
    if [ -d "$script_path/../share/dunno-workflow/templates" ]; then
        echo "$script_path/../share/dunno-workflow/templates"; return
    fi
    if [ -d "$script_path/../templates" ]; then
        echo "$script_path/../templates"; return
    fi
    echo "ERROR: Could not find template directory" >&2; exit 1
}

cmd_init() {
    if [ -f "workflow.yaml" ]; then
        echo "workflow.yaml already exists. Remove it first to start fresh."; exit 1
    fi
    local tpl; tpl="$(get_template_dir)"
    cp "$tpl/workflow.yaml" ./workflow.yaml
    mkdir -p tickets
    if [ -f "$tpl/tickets/TEMPLATE.md" ]; then cp "$tpl/tickets/TEMPLATE.md" ./tickets/TEMPLATE.md; fi
    echo "Created workflow.yaml and tickets/TEMPLATE.md"
    echo "Edit workflow.yaml to configure your agent team, then run: dunno-workflow start"
}

# ==================== Validation Helpers ====================

# Global state for graph validation (bash 3.2 compatible тАФ no associative arrays)
_v_all_agents=""
_v_defined_events=""
_v_agent_sends=""      # newline-delimited "agent:evt1 evt2 ..."
_v_agent_receives=""   # newline-delimited "agent:evt1 evt2 ..."
_v_worker_agents=""
_v_interactive_agent=""

_v_extract_data() {
    _v_all_agents=$(yq '.agents | keys | .[]' workflow.yaml)
    _v_defined_events=$(yq '.events // {} | keys | .[]' workflow.yaml 2>/dev/null)
    _v_agent_sends=""
    _v_agent_receives=""
    _v_worker_agents=""
    _v_interactive_agent=""
    for agent in $_v_all_agents; do
        local s r
        s=$(yq ".agents.$agent.sends // [] | .[]" workflow.yaml 2>/dev/null | tr '\n' ' ')
        r=$(yq ".agents.$agent.receives // [] | .[]" workflow.yaml 2>/dev/null | tr '\n' ' ')
        _v_agent_sends="${_v_agent_sends}${agent}:${s}
"
        _v_agent_receives="${_v_agent_receives}${agent}:${r}
"
        local interactive auto_start
        interactive=$(yq ".agents.$agent.interactive // false" workflow.yaml)
        auto_start=$(yq ".agents.$agent.auto_start // false" workflow.yaml)
        [ "$interactive" = "true" ] && _v_interactive_agent="$agent"
        if [ "$interactive" != "true" ] && [ "$auto_start" != "true" ]; then
            _v_worker_agents="$_v_worker_agents $agent"
        fi
    done
}

_v_agent_sends_list() {
    echo "$_v_agent_sends" | grep "^${1}:" | sed "s/^${1}://" | tr -s ' ' | sed 's/^ //;s/ $//'
}

_v_agent_receives_list() {
    echo "$_v_agent_receives" | grep "^${1}:" | sed "s/^${1}://" | tr -s ' ' | sed 's/^ //;s/ $//'
}

_v_sends_contains() {
    local agent="$1" evt="$2"
    local line
    line=$(echo "$_v_agent_sends" | grep "^${agent}:" || true)
    local events=" ${line#*:}"
    [[ " $events " == *" $evt "* ]] && return 0 || return 1
}

_v_receives_contains() {
    local agent="$1" evt="$2"
    local line
    line=$(echo "$_v_agent_receives" | grep "^${agent}:" || true)
    local events=" ${line#*:}"
    [[ " $events " == *" $evt "* ]] && return 0 || return 1
}

_v_expand_alias() {
    local input="$1"
    local result=""
    local IFS='|'
    for part in $input; do
        part=$(echo "$part" | tr -d ' ')
        if [ "$part" = "workers" ]; then
            result="$result $_v_worker_agents"
        else
            result="$result $part"
        fi
    done
    echo "$result" | tr -s ' ' | sed 's/^ //;s/ $//'
}

# ==================== Graph Checks ====================

_v_check_missing_events() {
    local errors_ref=$1 agent evt
    for agent in $_v_all_agents; do
        for evt in $(_v_agent_sends_list "$agent"); do
            [ -z "$evt" ] && continue
            if ! echo "$_v_defined_events" | grep -qx "$evt" 2>/dev/null; then
                echo "ERROR: Agent '$agent' sends event '$evt' not defined in events:"
                eval "(($errors_ref++))" || true || true
            fi
        done
        for evt in $(_v_agent_receives_list "$agent"); do
            [ -z "$evt" ] && continue
            if ! echo "$_v_defined_events" | grep -qx "$evt" 2>/dev/null; then
                echo "ERROR: Agent '$agent' receives event '$evt' not defined in events:"
                eval "(($errors_ref++))" || true || true
            fi
        done
    done
}

_v_check_orphaned_events() {
    local warnings_ref=$1 evt agent found
    for evt in $_v_defined_events; do
        found=false
        for agent in $_v_all_agents; do
            if _v_sends_contains "$agent" "$evt" || _v_receives_contains "$agent" "$evt"; then
                found=true; break
            fi
        done
        if [ "$found" = false ]; then
            echo "WARNING: Event '$evt' is defined but no agent references it"
            eval "(($warnings_ref++))" || true
        fi
    done
}

_v_check_dead_agents() {
    local errors_ref=$1 agent evt other has_sender
    for agent in $_v_all_agents; do
        for evt in $(_v_agent_receives_list "$agent"); do
            [ -z "$evt" ] && continue
            has_sender=false
            for other in $_v_all_agents; do
                [ "$other" = "$agent" ] && continue
                if _v_sends_contains "$other" "$evt"; then has_sender=true; break; fi
            done
            if [ "$has_sender" = false ]; then
                echo "ERROR: Agent '$agent' receives '$evt' but no other agent sends it (dead agent)"
                eval "(($errors_ref++))" || true
            fi
        done
    done
}

_v_check_unused_sends() {
    local warnings_ref=$1 agent evt other has_receiver
    for agent in $_v_all_agents; do
        for evt in $(_v_agent_sends_list "$agent"); do
            [ -z "$evt" ] && continue
            has_receiver=false
            for other in $_v_all_agents; do
                [ "$other" = "$agent" ] && continue
                if _v_receives_contains "$other" "$evt"; then has_receiver=true; break; fi
            done
            if [ "$has_receiver" = false ]; then
                echo "WARNING: Agent '$agent' sends '$evt' but no other agent receives it"
                eval "(($warnings_ref++))" || true
            fi
        done
    done
}

_v_check_direction_consistency() {
    local errors_ref=$1 evt dir sender receivers_str s r
    for evt in $_v_defined_events; do
        dir=$(yq ".events.$evt.direction // \"\"" workflow.yaml)
        [ -z "$dir" ] || [ "$dir" = '""' ] && continue
        sender="${dir%% ->*}"
        receivers_str="${dir#*-> }"
        sender=$(echo "$sender" | tr -d ' ')
        local expected_senders expected_receivers
        expected_senders=$(_v_expand_alias "$sender")
        expected_receivers=$(_v_expand_alias "$receivers_str")
        for s in $expected_senders; do
            if ! _v_sends_contains "$s" "$evt"; then
                echo "ERROR: Direction says '$s' sends '$evt' but agent config disagrees"
                eval "(($errors_ref++))" || true
            fi
        done
        for r in $expected_receivers; do
            if ! _v_receives_contains "$r" "$evt"; then
                echo "ERROR: Direction says '$r' receives '$evt' but agent config disagrees"
                eval "(($errors_ref++))" || true
            fi
        done
    done
}

_v_check_event_loops() {
    local warnings_ref=$1 evt s r
    for evt in $_v_defined_events; do
        local senders="" receivers=""
        for agent in $_v_all_agents; do
            if _v_sends_contains "$agent" "$evt"; then senders="$senders $agent"; fi
            if _v_receives_contains "$agent" "$evt"; then receivers="$receivers $agent"; fi
        done
        for s in $senders; do
            for r in $receivers; do
                [ "$s" = "$r" ] && continue
                if _v_receives_contains "$s" "$evt" && _v_sends_contains "$r" "$evt"; then
                    echo "WARNING: Event '$evt' has a cycle: '$s' and '$r' both send and receive it"
                    eval "(($warnings_ref++))" || true
                    return 0
                fi
            done
        done
    done
}

_v_check_unreachable_agents() {
    local errors_ref=$1
    [ -z "$_v_interactive_agent" ] && return 0
    local visited="$_v_interactive_agent"
    local queue="$_v_interactive_agent"
    while [ -n "$queue" ]; do
        local current="${queue%% *}"
        if [ "$current" = "$queue" ]; then queue=""; else queue="${queue#* }"; fi
        for evt in $(_v_agent_sends_list "$current"); do
            [ -z "$evt" ] && continue
            for other in $_v_all_agents; do
                _v_receives_contains "$other" "$evt" || continue
                if ! echo " $visited " | grep -q " $other "; then
                    visited="$visited $other"
                    queue="${queue:+$queue }$other"
                fi
            done
        done
    done
    for agent in $_v_all_agents; do
        [ "$agent" = "$_v_interactive_agent" ] && continue
        if ! echo " $visited " | grep -q " $agent "; then
            echo "ERROR: Agent '$agent' is unreachable from interactive agent '$_v_interactive_agent'"
            eval "(($errors_ref++))" || true
        fi
    done
}

_v_check_self_loops() {
    local errors_ref=$1 agent evt
    for agent in $_v_all_agents; do
        for evt in $(_v_agent_sends_list "$agent"); do
            [ -z "$evt" ] && continue
            if _v_receives_contains "$agent" "$evt"; then
                echo "ERROR: Agent '$agent' both sends and receives event '$evt' (self-loop)"
                eval "(($errors_ref++))" || true
            fi
        done
    done
}

_v_render_event_flow() {
    echo ""
    echo "  Event Flow:"
    for evt in $_v_defined_events; do
        local senders="" receivers="" agent
        for agent in $_v_all_agents; do
            if _v_sends_contains "$agent" "$evt"; then senders="${senders:+$senders, }$agent"; fi
            if _v_receives_contains "$agent" "$evt"; then receivers="${receivers:+$receivers, }$agent"; fi
        done
        [ -z "$senders" ] && senders="(none)"
        [ -z "$receivers" ] && receivers="(none)"
        printf "    %-16s %s тФАтФАтЦ║ %s\n" "${evt}:" "$senders" "$receivers"
    done
    echo ""
}

# ==================== Validate Command ====================

cmd_validate() {
    if [ ! -f "workflow.yaml" ]; then echo "ERROR: workflow.yaml not found"; exit 1; fi
    if ! command -v yq &>/dev/null; then echo "ERROR: yq required. brew install yq"; exit 1; fi

    # Phase 0: YAML syntax
    local parse_err
    if ! parse_err=$(yq 'true' workflow.yaml 2>&1); then
        echo "ERROR: workflow.yaml has syntax errors:"
        echo "$parse_err" | sed 's/^/  /'
        exit 1
    fi

    local errors=0 warnings=0

    # Phase 1: Schema checks
    [ "$(yq '.project.name // ""' workflow.yaml)" = "" ] && echo "ERROR: project.name required" && ((errors++))
    [ "$(yq '.tickets.source // ""' workflow.yaml)" = "" ] && echo "ERROR: tickets.source required" && ((errors++))
    local ic; ic=$(yq '[.agents[] | select(.interactive == true)] | length' workflow.yaml)
    [ "$ic" -ne 1 ] && echo "ERROR: exactly one agent must have interactive: true (found $ic)" && ((errors++))

    # Phase 2: Graph checks (only if events or agent event refs exist)
    local has_events has_agent_events
    has_events=$(yq '.events // {} | length' workflow.yaml)
    has_agent_events=$(yq '[.agents[] | ((.sends // []) + (.receives // []))] | flatten | length' workflow.yaml)

    if [ "$has_events" -gt 0 ] || [ "$has_agent_events" -gt 0 ]; then
        _v_extract_data
        _v_check_missing_events errors
        _v_check_orphaned_events warnings
        _v_check_dead_agents errors
        _v_check_unused_sends warnings
        _v_check_direction_consistency errors
        _v_check_event_loops warnings
        _v_check_unreachable_agents errors
        _v_check_self_loops errors
        # Phase 3: Render event flow
        _v_render_event_flow
    fi

    # Phase 4: Summary
    if [ "$errors" -eq 0 ]; then
        echo "workflow.yaml is valid"
        echo "  Project: $(yq '.project.name' workflow.yaml)"
        echo "  Ticket source: $(yq '.tickets.source' workflow.yaml)"
        echo "  Agents: $(yq '.agents | keys | join(", ")' workflow.yaml)"
        [ "$has_events" -gt 0 ] && echo "  Events: $(yq '.events | keys | join(", ")' workflow.yaml)"
        [ "$warnings" -gt 0 ] && echo "  $warnings warning(s)"
        return 0
    else
        echo ""
        echo "$errors error(s), $warnings warning(s)"
        exit 1
    fi
}

# ==================== Analyze Command ====================

ANALYZE_REPORT_REPO="cometdigitalagency/dunno-workflow"
_findings=""
_finding_count=0

_add_finding() {
    local severity="$1" title="$2" detail="$3" evidence="$4" expected="$5"
    _finding_count=$((_finding_count + 1))
    _findings="${_findings}${severity}|${title}|${detail}|${evidence}|${expected}
"
    if [ "$severity" = "ERROR" ]; then
        echo "  тЭМ ${title}"
    else
        echo "  тЪая╕П  ${title}"
    fi
    [ -n "$detail" ] && echo "     тЖТ ${detail}"
    return 0
}

analyze_stuck_agents() {
    local log_dir="$1"
    for logfile in "$log_dir"/*.log; do
        local agent
        agent=$(basename "$logfile" .log)
        [ "$agent" = "pm" ] || [ "$agent" = "architect" ] && continue
        # Check if agent received a TASK but never sent DONE
        if grep -aq "TASK" "$logfile" 2>/dev/null; then
            if ! grep -aq "DONE-${agent}" "$logfile" 2>/dev/null && ! grep -aq "Auto-sent DONE-${agent}" "$logfile" 2>/dev/null; then
                local task_line
                task_line=$(grep -a "TASK" "$logfile" | head -1 | cut -c1-120)
                _add_finding "ERROR" \
                    "STUCK AGENT: ${agent} received TASK but no DONE-${agent} found" \
                    "Task: ${task_line}..." \
                    "$(grep -an 'TASK\|Session ended\|DONE' "$logfile" | tail -5)" \
                    "Agent should send DONE-${agent} after completing work"
            fi
        fi
    done
}

analyze_done_delivery() {
    local log_dir="$1"
    local arch_log="$log_dir/architect.log"
    [ -f "$arch_log" ] || return 0
    for logfile in "$log_dir"/*.log; do
        local agent
        agent=$(basename "$logfile" .log)
        [ "$agent" = "pm" ] || [ "$agent" = "architect" ] && continue
        # Check if auto-DONE was sent but architect didn't receive it
        if grep -aq "Auto-sent DONE-${agent}" "$logfile" 2>/dev/null; then
            if ! grep -aq "DONE-${agent}" "$arch_log" 2>/dev/null; then
                _add_finding "ERROR" \
                    "DONE NOT DELIVERED: ${agent} auto-sent DONE but architect has no matching receipt" \
                    "send-to-agent.sh may have failed to deliver the trigger file" \
                    "$(grep -a 'Auto-sent' "$logfile" | tail -1)" \
                    "Architect should receive DONE-${agent} via trigger file"
            fi
        fi
    done
}

analyze_session_crashes() {
    local log_dir="$1"
    for logfile in "$log_dir"/*.log; do
        local agent
        agent=$(basename "$logfile" .log)
        # Look for error traces
        if grep -qai "error\|traceback\|exception\|panic\|segfault" "$logfile" 2>/dev/null; then
            local err_lines
            err_lines=$(grep -ai "error\|traceback\|exception" "$logfile" | grep -avi "ErrorTracker\|error_rate\|error handling" | head -3)
            if [ -n "$err_lines" ]; then
                _add_finding "ERROR" \
                    "SESSION CRASH: ${agent} has error traces in log" \
                    "" \
                    "$err_lines" \
                    "Agent sessions should complete without errors"
            fi
        fi
    done
}

analyze_permission_blocks() {
    local log_dir="$1"
    for logfile in "$log_dir"/*.log; do
        local agent
        agent=$(basename "$logfile" .log)
        if grep -qai "permission\|not allowed\|denied\|blocked" "$logfile" 2>/dev/null; then
            local perm_lines
            perm_lines=$(grep -ai "permission\|not allowed\|denied\|blocked" "$logfile" | head -3)
            _add_finding "ERROR" \
                "PERMISSION BLOCKED: ${agent} was denied tool access" \
                "Check --allowedTools configuration for this agent" \
                "$perm_lines" \
                "Non-interactive agents should have all needed tools pre-approved"
        fi
    done
}

analyze_dispatch_timeouts() {
    local log_dir="$1"
    local arch_log="$log_dir/architect.log"
    [ -f "$arch_log" ] || return 0
    # Find agents that architect dispatched to but that never received the message
    for logfile in "$log_dir"/*.log; do
        local agent
        agent=$(basename "$logfile" .log)
        [ "$agent" = "pm" ] || [ "$agent" = "architect" ] && continue
        local agent_upper
        agent_upper=$(echo "$agent" | tr '[:lower:]' '[:upper:]')
        # Architect sent to this agent but agent log has no "Received message"
        if grep -aq "send-to-agent.sh.*${agent_upper}" "$arch_log" 2>/dev/null; then
            if ! grep -aq "Received message" "$logfile" 2>/dev/null; then
                _add_finding "ERROR" \
                    "DISPATCH TIMEOUT: architect sent to ${agent} but no message received" \
                    "Trigger file may not have been written or agent loop not running" \
                    "$(grep -a "send-to-agent.*${agent_upper}" "$arch_log" | head -1 | cut -c1-120)" \
                    "Worker should pick up trigger file within 1-2 seconds"
            fi
        fi
    done
}

analyze_missing_complete() {
    local log_dir="$1"
    local arch_log="$log_dir/architect.log"
    local pm_log="$log_dir/pm.log"
    [ -f "$arch_log" ] && [ -f "$pm_log" ] || return 0
    # Check if architect received all DONEs but never sent COMPLETE to PM
    local has_dones=true
    for logfile in "$log_dir"/*.log; do
        local agent
        agent=$(basename "$logfile" .log)
        [ "$agent" = "pm" ] || [ "$agent" = "architect" ] && continue
        if grep -aq "TASK" "$logfile" 2>/dev/null; then
            if ! grep -aq "DONE-${agent}" "$arch_log" 2>/dev/null; then
                has_dones=false
                break
            fi
        fi
    done
    if [ "$has_dones" = true ] && ! grep -aq "COMPLETE" "$pm_log" 2>/dev/null; then
        # Only flag if there were actually tasks dispatched
        if grep -aq "DONE-" "$arch_log" 2>/dev/null; then
            _add_finding "ERROR" \
                "MISSING COMPLETE: all workers reported DONE but PM never received COMPLETE" \
                "Architect may have failed to send COMPLETE message to PM" \
                "$(grep -a 'DONE-' "$arch_log" | tail -3)" \
                "Architect should send COMPLETE to PM after all workers are done"
        fi
    fi
}

_gh_api() {
    local method="$1" endpoint="$2" data="$3"
    local token="${GITHUB_TOKEN:-${DUNNO_GITHUB_TOKEN:-}}"
    if [ -z "$token" ]; then
        echo "ERROR: GITHUB_TOKEN or DUNNO_GITHUB_TOKEN env var required for issue creation." >&2
        echo "  Generate a token at https://github.com/settings/tokens (needs 'repo' scope)" >&2
        echo "  Then: export GITHUB_TOKEN=ghp_..." >&2
        return 1
    fi
    if [ -n "$data" ]; then
        curl -sf -X "$method" \
            -H "Authorization: token $token" \
            -H "Accept: application/vnd.github+json" \
            -H "Content-Type: application/json" \
            -d "$data" \
            "https://api.github.com${endpoint}" 2>/dev/null
    else
        curl -sf -X "$method" \
            -H "Authorization: token $token" \
            -H "Accept: application/vnd.github+json" \
            "https://api.github.com${endpoint}" 2>/dev/null
    fi
}

_ensure_labels() {
    local repo="$1"
    # Create labels if they don't exist (ignore errors if they already exist)
    _gh_api POST "/repos/${repo}/labels" '{"name":"auto-detected","color":"D93F0B","description":"Auto-detected by dunno-workflow analyze"}' >/dev/null 2>&1 || true
    _gh_api POST "/repos/${repo}/labels" '{"name":"bug","color":"D73A4A","description":"Something isn'"'"'t working"}' >/dev/null 2>&1 || true
}

_create_issue() {
    local title="$1" body="$2" dry_run="$3"
    if [ "$dry_run" = true ]; then
        echo "  [DRY RUN] Would create: \"Bug: ${title}\""
        return 0
    fi

    local token="${GITHUB_TOKEN:-${DUNNO_GITHUB_TOKEN:-}}"
    if [ -z "$token" ]; then
        echo "  тЪая╕П  Skipped: no GITHUB_TOKEN set (export GITHUB_TOKEN=ghp_...)"
        return 0
    fi

    # Ensure labels exist
    _ensure_labels "$ANALYZE_REPORT_REPO"

    # Dedup: check if matching issue already exists
    local existing
    existing=$(_gh_api GET "/repos/${ANALYZE_REPORT_REPO}/issues?labels=auto-detected&state=open&per_page=100" "" || true)
    if echo "$existing" | grep -qF "$title" 2>/dev/null; then
        echo "  тПн  Skipped (duplicate): \"${title}\""
        return 0
    fi

    # Escape body for JSON
    local json_body
    json_body=$(printf '%s' "$body" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))' 2>/dev/null || printf '"%s"' "$body")
    local json_title
    json_title=$(printf '%s' "Bug: ${title}" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))' 2>/dev/null || printf '"%s"' "Bug: ${title}")

    local response
    response=$(_gh_api POST "/repos/${ANALYZE_REPORT_REPO}/issues" \
        "{\"title\":${json_title},\"body\":${json_body},\"labels\":[\"bug\",\"auto-detected\"]}") || {
        echo "  тЪая╕П  Failed to create issue (check GITHUB_TOKEN permissions)"
        return 1
    }

    local issue_url
    issue_url=$(echo "$response" | python3 -c 'import sys,json; print(json.loads(sys.stdin.read())["html_url"])' 2>/dev/null || echo "(created)")
    echo "  Created: ${issue_url}"
}

cmd_analyze() {
    local SESSION="" DRY_RUN=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            --session|-s) SESSION="$2"; shift 2 ;;
            --dry-run|-n) DRY_RUN=true; shift ;;
            --help|-h)
                echo "Usage: dunno-workflow analyze [--session <name>] [--dry-run]"
                echo ""
                echo "Options:"
                echo "  --session, -s <name>  Analyze specific session (default: latest)"
                echo "  --dry-run, -n         Show findings without creating issues"
                exit 0 ;;
            *) echo "Unknown option: $1"; exit 1 ;;
        esac
    done

    local LOG_BASE=".team-logs"
    if [ ! -d "$LOG_BASE" ]; then
        echo "ERROR: No .team-logs/ directory found. Run with --debug to enable logging."
        exit 1
    fi

    if [ -z "$SESSION" ]; then
        SESSION=$(ls -1t "$LOG_BASE" 2>/dev/null | head -1)
    fi
    if [ -z "$SESSION" ] || [ ! -d "$LOG_BASE/$SESSION" ]; then
        echo "ERROR: No log sessions found in .team-logs/"
        exit 1
    fi

    local LOG_DIR="$LOG_BASE/$SESSION"
    local log_count
    log_count=$(ls "$LOG_DIR"/*.log 2>/dev/null | wc -l | tr -d ' ')

    echo ""
    echo "  Analyzing session: $SESSION"
    echo "  Logs: $LOG_DIR/ ($log_count agent logs)"
    echo ""
    echo "  Findings:"

    _findings=""
    _finding_count=0

    analyze_stuck_agents "$LOG_DIR"
    analyze_done_delivery "$LOG_DIR"
    analyze_session_crashes "$LOG_DIR"
    analyze_permission_blocks "$LOG_DIR"
    analyze_dispatch_timeouts "$LOG_DIR"
    analyze_missing_complete "$LOG_DIR"

    if [ "$_finding_count" -eq 0 ]; then
        echo "  тЬЕ No issues found. All agents completed successfully."
        echo ""
        return 0
    fi

    echo ""
    echo "  $_finding_count issue(s) found."
    [ "$DRY_RUN" = true ] && echo "  (dry-run mode тАФ no issues will be created)"
    echo ""

    # Read project context
    local source_repo=""
    if [ -f "workflow.yaml" ]; then
        source_repo=$(yq '.project.repo // ""' workflow.yaml 2>/dev/null)
    fi

    # Create issues from findings
    local IFS=$'\n'
    for finding in $_findings; do
        [ -z "$finding" ] && continue
        local sev title detail evidence expected
        sev=$(echo "$finding" | cut -d'|' -f1)
        title=$(echo "$finding" | cut -d'|' -f2)
        detail=$(echo "$finding" | cut -d'|' -f3)
        evidence=$(echo "$finding" | cut -d'|' -f4)
        expected=$(echo "$finding" | cut -d'|' -f5)

        local body
        body="## ${title}

**Detected by:** \`dunno-workflow analyze\`
**Session:** ${SESSION}
**Source repo:** ${source_repo:-unknown}

### What happened
${detail}

### Log evidence
\`\`\`
${evidence}
\`\`\`

### Expected behavior
${expected}

### Labels
\`bug\`, \`auto-detected\`"

        _create_issue "$title" "$body" "$DRY_RUN"
    done
    echo ""
    return 0
}

cmd_stop() {
    echo "Stopping agent sessions..."
    local names=""
    for agent in $(yq '.agents | keys | .[]' workflow.yaml 2>/dev/null || echo "PM ARCHITECT BACKEND FRONTEND QA"); do
        names+="\"$(echo "$agent" | tr '[:lower:]' '[:upper:]')\", "
    done
    names+="\"LOGS\""
    osascript << ENDSCRIPT 2>/dev/null || true
tell application "iTerm2"
    set agentNames to {${names}}
    repeat with w in windows
        repeat with t in tabs of w
            repeat with s in sessions of t
                if name of s is in agentNames then
                    tell s
                        write text (ASCII character 3)
                        write text "exit"
                    end tell
                end if
            end repeat
        end repeat
    end repeat
end tell
ENDSCRIPT
    echo "Done."
}

# ==================== Start Command (engine) ====================

cmd_start() {
    set -e
    
    REPO_DIR="$(pwd)"
    WORKFLOW_FILE="${REPO_DIR}/workflow.yaml"
    ISSUE_NUM=""
    TEST_MODE=false
    DEBUG_MODE=false
    E2E_MODE=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --issue|-i) ISSUE_NUM="$2"; shift 2 ;;
            --test|-t)  TEST_MODE=true; shift ;;
            --e2e|-e)   E2E_MODE=true; shift ;;
            --debug|-d) DEBUG_MODE=true; shift ;;
            --help|-h)
                echo "Usage: dunno-workflow start [--issue <number>] [--test] [--e2e] [--debug]"
                echo ""
                echo "Options:"
                echo "  --issue, -i <num>   Ticket number to work on"
                echo "  --test, -t          Test mode тАФ mock issue, no ticket source needed"
                echo "  --e2e, -e           End-to-end test тАФ small ticket through full flow"
                echo "  --debug, -d         Enable LOGS pane with filtered session logging"
                echo "  --help, -h          Show this help"
                exit 0 ;;
            *) echo "Unknown option: $1"; exit 1 ;;
        esac
    done
    
    # ==================== Dependencies ====================
    
    if ! command -v yq &>/dev/null; then
        echo "ERROR: yq is required but not installed."
        echo "  brew install yq"
        exit 1
    fi
    
    if [ ! -f "$WORKFLOW_FILE" ]; then
        echo "ERROR: workflow.yaml not found at $WORKFLOW_FILE"
        exit 1
    fi
    
    # ==================== Read workflow.yaml ====================
    
    yq_get() { yq "$1" "$WORKFLOW_FILE"; }
    
    PROJECT_NAME=$(yq_get '.project.name')
    REPO_NAME=$(yq_get '.project.repo')
    TICKET_SOURCE=$(yq_get '.tickets.source')
    
    # Read agent names (preserving YAML key order)
    AGENTS=()
    while IFS= read -r agent; do
        AGENTS+=("$agent")
    done < <(yq_get '.agents | keys | .[]')
    
    # Identify interactive agent (PM) vs workers
    INTERACTIVE_AGENT=""
    WORKER_AGENTS=()
    for agent in "${AGENTS[@]}"; do
        if [ "$(yq_get ".agents.$agent.interactive")" = "true" ]; then
            INTERACTIVE_AGENT="$agent"
        else
            WORKER_AGENTS+=("$agent")
        fi
    done
    
    # Check debug_pane from YAML or --debug flag
    if [ "$(yq_get '.layout.debug_pane')" = "true" ]; then
        DEBUG_MODE=true
    fi
    
    # Create directories
    PROMPT_DIR="${REPO_DIR}/.team-prompts"
    mkdir -p "$PROMPT_DIR"
    
    if [ "$DEBUG_MODE" = true ]; then
        LOG_DIR="${REPO_DIR}/.team-logs/$(date '+%Y-%m-%d_%H-%M-%S')"
        mkdir -p "$LOG_DIR"
    fi
    
    # ==================== Ticket Source Functions ====================
    # Generate ticket CLI commands based on tickets.source
    
    generate_ticket_commands() {
        local source="$1"
        case "$source" in
            github)
                local gh_repo
                gh_repo=$(yq_get '.tickets.github.repo // .project.repo')
                local lbl_ready lbl_inprog lbl_done
                lbl_ready=$(yq_get '.tickets.github.labels.ready')
                lbl_inprog=$(yq_get '.tickets.github.labels.in_progress')
                lbl_done=$(yq_get '.tickets.github.labels.done')
    
                TICKET_CREATE="gh issue create --repo ${gh_repo} --title \"\$TITLE\" --label \"${lbl_ready},feature\" --body \"\$BODY\""
                TICKET_LIST_READY="gh issue list --repo ${gh_repo} --label ${lbl_ready} --state open --json number,title --jq '.[0].number // empty'"
                TICKET_VIEW="gh issue view \$N --repo ${gh_repo}"
                TICKET_CLAIM="gh issue edit \$N --repo ${gh_repo} --remove-label ${lbl_ready} --add-label ${lbl_inprog}"
                TICKET_COMMENT="gh issue comment \$N --repo ${gh_repo} --body \"\$MSG\""
                TICKET_CLOSE="gh issue close \$N --repo ${gh_repo} && gh issue edit \$N --repo ${gh_repo} --remove-label ${lbl_inprog} --add-label ${lbl_done}"
                TICKET_LIST_OPEN="gh issue list --repo ${gh_repo} --state open"
                TICKET_LIST_STALE="gh issue list --repo ${gh_repo} --label ${lbl_inprog} --state open --json number,title --jq '.[] | \"\\(.number) \\(.title)\"'"
                ;;
            file)
                local dir
                dir=$(yq_get '.tickets.file.directory // "./tickets"')
                TICKET_CREATE="echo '---\nid: \$(ls ${dir}/*.md 2>/dev/null | wc -l | tr -d \" \")\ntitle: '\"\$TITLE\"'\nstatus: ready\nlabels: [feature]\ncreated: \$(date +%Y-%m-%d)\n---\n\n\$BODY' > '${dir}/\$(date +%s).md'"
                TICKET_LIST_READY="grep -rl 'status: ready' ${dir}/*.md 2>/dev/null | head -1"
                TICKET_VIEW="cat \$N"
                TICKET_CLAIM="sed -i '' 's/status: ready/status: in-progress/' \$N"
                TICKET_COMMENT="echo -e '\n---\n### \$MSG\n\$(date)' >> \$N"
                TICKET_CLOSE="sed -i '' 's/status: in-progress/status: done/' \$N"
                TICKET_LIST_OPEN="grep -rl 'status: \\(ready\\|in-progress\\)' ${dir}/*.md 2>/dev/null"
                TICKET_LIST_STALE="grep -rl 'status: in-progress' ${dir}/*.md 2>/dev/null"
                ;;
            jira)
                local server project_key
                server=$(yq_get '.tickets.jira.server')
                project_key=$(yq_get '.tickets.jira.project_key')
                local st_ready st_inprog st_done
                st_ready=$(yq_get '.tickets.jira.statuses.ready')
                st_inprog=$(yq_get '.tickets.jira.statuses.in_progress')
                st_done=$(yq_get '.tickets.jira.statuses.done')
                TICKET_CREATE="jira issue create --project ${project_key} --type Task --summary \"\$TITLE\" --body \"\$BODY\""
                TICKET_LIST_READY="jira issue list --project ${project_key} --status \"${st_ready}\" --plain --no-headers | head -1 | awk '{print \$1}'"
                TICKET_VIEW="jira issue view \$N"
                TICKET_CLAIM="jira issue move \$N \"${st_inprog}\""
                TICKET_COMMENT="jira issue comment add \$N --body \"\$MSG\""
                TICKET_CLOSE="jira issue move \$N \"${st_done}\""
                TICKET_LIST_OPEN="jira issue list --project ${project_key} --status \"${st_ready}\" --status \"${st_inprog}\""
                TICKET_LIST_STALE="jira issue list --project ${project_key} --status \"${st_inprog}\" --plain --no-headers"
                ;;
            clickup)
                local list_id
                list_id=$(yq_get '.tickets.clickup.list_id')
                local st_ready st_inprog st_done
                st_ready=$(yq_get '.tickets.clickup.statuses.ready')
                st_inprog=$(yq_get '.tickets.clickup.statuses.in_progress')
                st_done=$(yq_get '.tickets.clickup.statuses.done')
                TICKET_CREATE="clickup task create --list-id ${list_id} --name \"\$TITLE\" --description \"\$BODY\" --status \"${st_ready}\""
                TICKET_LIST_READY="clickup task list --list-id ${list_id} --status \"${st_ready}\" | head -1 | awk '{print \$1}'"
                TICKET_VIEW="clickup task view \$N"
                TICKET_CLAIM="clickup task update \$N --status \"${st_inprog}\""
                TICKET_COMMENT="clickup task comment \$N --text \"\$MSG\""
                TICKET_CLOSE="clickup task update \$N --status \"${st_done}\""
                TICKET_LIST_OPEN="clickup task list --list-id ${list_id}"
                TICKET_LIST_STALE="clickup task list --list-id ${list_id} --status \"${st_inprog}\""
                ;;
            *)
                echo "ERROR: Unknown ticket source: $source"
                exit 1 ;;
        esac
    }
    
    generate_ticket_commands "$TICKET_SOURCE"

    # тФАтФА E2E mode: override to file-based tickets with a small test ticket тФАтФА
    if [ "$E2E_MODE" = true ]; then
        TICKET_SOURCE="file"
        generate_ticket_commands "file"
        local ticket_dir="${REPO_DIR}/tickets"
        mkdir -p "$ticket_dir"
        local tpl_dir
        tpl_dir="$(get_template_dir)"
        if [ -f "$tpl_dir/e2e-test-ticket.md" ]; then
            cp "$tpl_dir/e2e-test-ticket.md" "$ticket_dir/e2e-test.md"
            echo "E2E: Created test ticket in $ticket_dir/e2e-test.md"
        fi
        TEST_MODE=true
    fi

    # ==================== Helper: send-to-agent.sh ====================
    
    sed 's/^    //' > "$PROMPT_DIR/send-to-agent.sh" << 'HELPER'
    #!/bin/bash
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    AGENT_NAME=$(echo "$1" | tr '[:upper:]' '[:lower:]')
    shift
    MESSAGE="$*"

    # Write trigger file for the worker's file-watch loop
    TRIGGER_DIR="$SCRIPT_DIR/triggers"
    if ! mkdir -p "$TRIGGER_DIR" 2>/dev/null; then
        echo "ERROR: Failed to create trigger directory: $TRIGGER_DIR" >&2
        exit 1
    fi

    TRIGGER_FILE="$TRIGGER_DIR/${AGENT_NAME}.trigger"
    if ! printf '%s\n' "$MESSAGE" > "$TRIGGER_FILE"; then
        echo "ERROR: Failed to write trigger file: $TRIGGER_FILE" >&2
        exit 1
    fi

    # Verify the write succeeded (non-empty)
    if [ ! -s "$TRIGGER_FILE" ]; then
        echo "ERROR: Trigger file is empty after write: $TRIGGER_FILE" >&2
        exit 1
    fi

    # Track DONE messages so auto-DONE doesn't duplicate them
    case "$MESSAGE" in
        DONE-*|Done-*)
            touch "$TRIGGER_DIR/${AGENT_NAME}.done-sent" 2>/dev/null
            ;;
    esac

    # Deliver message to the iTerm2 pane.
    # Worker agents (event-driven) read from .trigger files тАФ they only need a nudge.
    # Interactive/auto_start agents (PM, architect) receive messages via iTerm2 text
    # input, so we must type the full message into their pane.
    #
    # Long messages (>3KB) are written to a temp file and piped via 'cat' to avoid
    # AppleScript's ~4KB string truncation limit.
    AGENT_UPPER=$(echo "$AGENT_NAME" | tr '[:lower:]' '[:upper:]')

    # Check if target is a worker (has an event-driven polling loop)
    LAUNCHER="$SCRIPT_DIR/run-${AGENT_NAME}.sh"
    if [ -f "$LAUNCHER" ] && grep -q "Event-driven loop" "$LAUNCHER" 2>/dev/null; then
        IS_WORKER=true
    else
        IS_WORKER=false
    fi

    if [ "$IS_WORKER" = true ]; then
        # Worker agent: trigger file is the primary mechanism, just nudge the pane
        PANE_TEXT=""
    else
        # Interactive/auto_start agent: type the full message into the pane
        if [ ${#MESSAGE} -gt 3000 ]; then
            # Long message: write to temp file, type a cat command into the pane
            MSG_FILE="$TRIGGER_DIR/${AGENT_NAME}.msg-input"
            printf '%s\n' "$MESSAGE" > "$MSG_FILE"
            PANE_TEXT="cat '${MSG_FILE}' | claude -p --append-system-prompt \"\$SYSTEM_PROMPT\" --allowedTools \"\$ALLOWED_TOOLS\" -n \"${AGENT_NAME}\""
            # Actually, for interactive sessions we just need to type the message
            PANE_TEXT="$MESSAGE"
        else
            PANE_TEXT="$MESSAGE"
        fi
    fi

    RESULT=$(osascript << EOF 2>&1 || true
    tell application "iTerm2"
        repeat with w in windows
            repeat with t in tabs of w
                repeat with s in sessions of t
                    set sessionName to name of s
                    if sessionName contains "$AGENT_NAME" then
                        tell s
                            write text "$PANE_TEXT"
                        end tell
                        return "sent"
                    end if
                end repeat
            end repeat
        end repeat
        return "not_found"
    end tell
EOF
    )
    if [ "$RESULT" = "not_found" ]; then
        echo "WARNING: iTerm2 pane for '${AGENT_NAME}' not found (trigger file still delivered)" >&2
    fi

    # Wait for receiver to ACK (max 30s) тАФ only for workers with polling loops.
    # Interactive/auto_start agents don't write ACK files.
    if [ "$IS_WORKER" = true ]; then
        ACK_FILE="$TRIGGER_DIR/${AGENT_NAME}.ack"
        WAIT=0
        while [ ! -f "$ACK_FILE" ] && [ $WAIT -lt 30 ]; do
            sleep 1
            WAIT=$((WAIT + 1))
        done

        if [ -f "$ACK_FILE" ]; then
            echo "--- [$(date '+%H:%M:%S')] Acknowledged by ${AGENT_NAME} (${WAIT}s) ---"
            rm -f "$ACK_FILE"
        else
            echo "WARNING: ${AGENT_NAME} did not acknowledge after 30s тАФ trigger file may be pending" >&2
        fi
    else
        echo "--- [$(date '+%H:%M:%S')] Message typed into ${AGENT_NAME} pane ---"
    fi
HELPER
    chmod +x "$PROMPT_DIR/send-to-agent.sh"
    
    # ==================== Generate System Prompts ====================
    
    generate_system_prompt() {
        local agent="$1"
        local role description interactive
        role=$(yq_get ".agents.$agent.role")
        description=$(yq_get ".agents.$agent.description")
        interactive=$(yq_get ".agents.$agent.interactive")
    
        local prompt=""
        prompt+="You are the ${role} for the ${PROJECT_NAME} platform. ${description}\n\n"
    
        # Workflow steps
        prompt+="## YOUR WORKFLOW\n"
        local step_num=1
        while IFS= read -r step; do
            # Interpolate ticket commands into workflow steps
            step="${step//\{repo\}/$REPO_NAME}"
            prompt+="${step_num}. ${step}\n"
            ((step_num++))
        done < <(yq_get ".agents.$agent.workflow[]")
        prompt+="\n"
    
        # Communicating with agents
        prompt+="## COMMUNICATING WITH AGENTS\n"
        prompt+="You can send messages to any agent by running bash commands:\n"
        for other in "${AGENTS[@]}"; do
            if [ "$other" != "$agent" ]; then
                local other_upper
                other_upper=$(echo "$other" | tr '[:lower:]' '[:upper:]')
                prompt+="- Send message to ${other}: bash -c \"'${PROMPT_DIR}/send-to-agent.sh' ${other_upper} 'your message here'\"\n"
            fi
        done
        prompt+="\n"
    
        # Ticket commands section
        prompt+="## TICKET COMMANDS (source: ${TICKET_SOURCE})\n"
        prompt+="- Create ticket: ${TICKET_CREATE}\n"
        prompt+="- List ready tickets: ${TICKET_LIST_READY}\n"
        prompt+="- View ticket: ${TICKET_VIEW}\n"
        prompt+="- Claim ticket (mark in-progress): ${TICKET_CLAIM}\n"
        prompt+="- Comment on ticket: ${TICKET_COMMENT}\n"
        prompt+="- Close ticket (mark done): ${TICKET_CLOSE}\n"
        prompt+="- List open tickets: ${TICKET_LIST_OPEN}\n"
        prompt+="- List stale in-progress tickets: ${TICKET_LIST_STALE}\n"
        prompt+="\n"
    
        # Rules
        local rules_count
        rules_count=$(yq_get ".agents.$agent.rules | length")
        if [ "$rules_count" != "0" ]; then
            prompt+="## RULES\n"
            while IFS= read -r rule; do
                prompt+="- ${rule}\n"
            done < <(yq_get ".agents.$agent.rules[]")
            prompt+="\n"
        fi
    
        # File ownership
        local owns_count never_count
        owns_count=$(yq_get ".agents.$agent.owns.paths | length")
        never_count=$(yq_get ".agents.$agent.owns.never_edit | length")
        if [ "$owns_count" != "0" ] || [ "$never_count" != "0" ]; then
            prompt+="## FILE OWNERSHIP\n"
            if [ "$owns_count" != "0" ]; then
                prompt+="You may edit files matching: "
                prompt+=$(yq_get ".agents.$agent.owns.paths | join(\", \")")
                prompt+="\n"
            fi
            if [ "$never_count" != "0" ]; then
                prompt+="You must NEVER edit: "
                prompt+=$(yq_get ".agents.$agent.owns.never_edit | join(\", \")")
                prompt+="\n"
            fi
            prompt+="\n"
        fi
    
        # Commands (for PM-like agents)
        local cmds_count
        cmds_count=$(yq_get ".agents.$agent.commands // {} | length")
        if [ "$cmds_count" != "0" ]; then
            prompt+="## COMMANDS (when the user says these)\n"
            # Use yq to emit key=value pairs directly to avoid quoting issues
            while IFS= read -r line; do
                local key="${line%%=*}"
                local val="${line#*=}"
                val="${val//\{repo\}/$REPO_NAME}"
                prompt+="- \"${key}\" тЖТ ${val}\n"
            done < <(yq_get ".agents.$agent.commands // {} | to_entries | .[] | .key + \"=\" + .value")
            prompt+="\n"
        fi
    
        # Extra prompt text
        local extra
        extra=$(yq_get ".agents.$agent.prompt_extra // \"\"")
        if [ -n "$extra" ] && [ "$extra" != "\"\"" ] && [ "$extra" != "" ]; then
            prompt+="\n${extra}\n"
        fi
    
        # Stale task recovery for architect (auto_start agents)
        local agent_auto_start
        agent_auto_start=$(yq_get ".agents.$agent.auto_start // false")
        if [ "$agent_auto_start" = "true" ]; then
            prompt+="## STALE TASK RECOVERY\n"
            prompt+="Worker agents auto-send DONE messages when their session ends. However, if you\n"
            prompt+="have been waiting for DONE messages for more than 2 minutes, ping each dispatched\n"
            prompt+="worker to check their status:\n"
            for other in "${AGENTS[@]}"; do
                if [ "$other" != "$agent" ] && [ "$(yq_get ".agents.$other.interactive")" != "true" ] && [ "$(yq_get ".agents.$other.auto_start // false")" != "true" ]; then
                    local other_upper
                    other_upper=$(echo "$other" | tr '[:lower:]' '[:upper:]')
                    prompt+="  ${PROMPT_DIR}/send-to-agent.sh ${other_upper} 'STATUS: Are you done? Reply DONE-${other} if finished.'\n"
                fi
            done
            prompt+="\n"
        fi

        # Completion safety net for architect
        if [ "$agent_auto_start" = "true" ]; then
            prompt+="## COMPLETION SAFETY NET\n"
            prompt+="Before sending COMPLETE to PM, ALWAYS run this command first:\n"
            prompt+="  touch ${PROMPT_DIR}/triggers/.work-done\n"
            prompt+="This ensures PM gets notified even if your session ends unexpectedly.\n\n"
        fi

        # Important rules for event-driven agents
        if [ "$interactive" != "true" ]; then
            prompt+="## IMPORTANT\n"
            prompt+="- If the PM sends you a message (stop, pause, status), handle it immediately.\n"
            prompt+="- ALWAYS post your done marker on the ticket when you finish your tasks.\n"
        fi
    
        printf '%b' "$prompt" > "$PROMPT_DIR/${agent}-system.txt"
    }
    
    # ==================== Generate Init Prompts ====================
    
    generate_init_prompt() {
        local agent="$1"
        local mode="default"
        [ "$TEST_MODE" = true ] && mode="test"
        [ -n "$ISSUE_NUM" ] && mode="issue"
    
        local init_text
        init_text=$(yq_get ".agents.$agent.init.$mode // .agents.$agent.init.default")
    
        # Handle {default} self-reference
        if [ "$init_text" = "{default}" ]; then
            init_text=$(yq_get ".agents.$agent.init.default")
        fi
    
        # Interpolate placeholders
        init_text="${init_text//\{issue_num\}/$ISSUE_NUM}"
        init_text="${init_text//\{repo\}/$REPO_NAME}"
    
        # For test mode with file-based tickets, point architect to the tickets directory
        if [ "$TEST_MODE" = true ] && [ "$agent" = "architect" ] && [ "$TICKET_SOURCE" = "file" ]; then
            local ticket_dir
            ticket_dir=$(yq_get '.tickets.file.directory // "./tickets"')
            init_text+="
    
    Look for ready tickets in the ${ticket_dir}/ directory. Read each .md file and check the
    frontmatter for 'status: ready'. Pick the first one you find, change its status to
    'status: in-progress' using sed, then plan and dispatch tasks to agents."
        elif [ "$TEST_MODE" = true ] && [ "$agent" = "architect" ]; then
            init_text+="
    
    MOCK ISSUE: Add a GET /ping endpoint to the Reddit agent
    ## Summary
    Add a simple health-check endpoint that returns the service status and current timestamp.
    ## Requirements
    - GET /ping endpoint on the Reddit agent returning JSON with status and timestamp
    - A frontend component showing the service latency
    - Tests covering the new functionality
    ## Acceptance Criteria
    - [ ] GET /ping returns 200 with JSON payload
    - [ ] Frontend displays ping latency
    - [ ] All tests pass"
        fi
    
        printf '%s' "$init_text" > "$PROMPT_DIR/${agent}-init.txt"
    }
    
    # ==================== Generate Launcher Scripts ====================
    
    # Map workflow.yaml tool names to Claude Code --allowedTools names
    get_allowed_tools() {
        local agent="$1"
        local tools_list=""
        while IFS= read -r tool; do
            case "$tool" in
                read)          tools_list+="Read," ;;
                edit)          tools_list+="Edit," ;;
                write)         tools_list+="Write," ;;
                bash)          tools_list+="Bash(*)," ;;
                glob)          tools_list+="Glob," ;;
                grep)          tools_list+="Grep," ;;
                task_list)     tools_list+="TaskList," ;;
                task_create)   tools_list+="TaskCreate," ;;
                task_update)   tools_list+="TaskUpdate," ;;
                send_message)  tools_list+="SendMessage," ;;
                *)             tools_list+="${tool}," ;;
            esac
        done < <(yq_get ".agents.$agent.tools[]" 2>/dev/null)
        # Remove trailing comma
        echo "${tools_list%,}"
    }

    generate_launcher() {
        local agent="$1"
        local interactive
        interactive=$(yq_get ".agents.$agent.interactive")
        local label
        label=$(echo "$agent" | tr '[:lower:]' '[:upper:]')
        local allowed_tools auto_start_agent
        allowed_tools=$(get_allowed_tools "$agent")
        # Find the auto_start agent (architect) for DONE callbacks
        auto_start_agent=""
        auto_start_label=""
        for _a in "${AGENTS[@]}"; do
            if [ "$(yq_get ".agents.$_a.auto_start // false")" = "true" ]; then
                auto_start_agent="$_a"
                auto_start_label=$(echo "$_a" | tr '[:lower:]' '[:upper:]')
                break
            fi
        done
    
        if [ "$interactive" = "true" ]; then
            # Interactive agent (PM) тАФ single session, no restart loop
            {
                echo '#!/bin/bash'
                echo "cd '${REPO_DIR}'"
                echo "printf '\\033]0;${label}\\007'"
                echo "SYSTEM_PROMPT=\$(cat '${PROMPT_DIR}/${agent}-system.txt')"
                echo "INIT_PROMPT=\$(cat '${PROMPT_DIR}/${agent}-init.txt')"
                echo 'echo "тХФтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХЧ"'
                echo "echo \"тХС       ${label}                       тХС\""
                echo 'echo "тХатХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХг"'
                echo 'echo "тХС  Commands:                           тХС"'
                yq_get ".agents.$agent.commands // {} | keys | .[]" 2>/dev/null | head -6 | while IFS= read -r cmd; do
                    printf 'echo "тХС  тАв %-35sтХС"\n' "$cmd"
                done
                echo 'echo "тХЪтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХЭ"'
                echo 'echo ""'
                echo "exec claude --append-system-prompt \"\$SYSTEM_PROMPT\" --allowedTools \"${allowed_tools}\" -n \"${agent}\" \"\$INIT_PROMPT\""
            } > "$PROMPT_DIR/run-${agent}.sh"
        else
            local starts_immediately
            starts_immediately=$(yq_get ".agents.$agent.auto_start // false")
    
            if [ "$starts_immediately" = "true" ]; then
                # Architect тАФ starts immediately, restarts if session ends
                sed 's/^    //' > "$PROMPT_DIR/run-${agent}.sh" << LAUNCHER
    #!/bin/bash
    cd '${REPO_DIR}'
    printf '\033]0;${label}\007'
    SYSTEM_PROMPT=\$(cat '${PROMPT_DIR}/${agent}-system.txt')
    INIT_PROMPT=\$(cat '${PROMPT_DIR}/${agent}-init.txt')
    
    echo "тХФтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХЧ"
    echo "тХС  ${label} agent"
    echo "тХС  Starting up..."
    echo "тХЪтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХЭ"
    echo ""
    
    TRIGGER_DIR='${PROMPT_DIR}/triggers'
    mkdir -p "\$TRIGGER_DIR"
    TRIGGER_FILE="\$TRIGGER_DIR/${agent}.trigger"

    while true; do
        # Check for pending trigger file (message arrived while session was down)
        if [ -f "\$TRIGGER_FILE" ]; then
            PENDING_MSG=\$(cat "\$TRIGGER_FILE")
            rm -f "\$TRIGGER_FILE"
            echo "--- [\$(date '+%H:%M:%S')] Found pending message (\${#PENDING_MSG} chars) тАФ feeding to session ---"
            claude --append-system-prompt "\$SYSTEM_PROMPT" --allowedTools "${allowed_tools}" -n "${agent}" "\$PENDING_MSG"
        else
            claude --append-system-prompt "\$SYSTEM_PROMPT" --allowedTools "${allowed_tools}" -n "${agent}" "\$INIT_PROMPT"
        fi
        echo ""
        echo "--- [\$(date '+%H:%M:%S')] Session ended. Restarting in 5s... ---"
        # Auto-notify: guarantee COMPLETE reaches PM if session ended after work was done
        COMPLETE_MARKER="\$TRIGGER_DIR/.work-done"
        if [ -f "\$COMPLETE_MARKER" ]; then
            '${PROMPT_DIR}/send-to-agent.sh' PM "COMPLETE: All tasks finished (auto-notify)"
            echo "--- [\$(date '+%H:%M:%S')] Auto-sent COMPLETE to PM ---"
            rm -f "\$COMPLETE_MARKER"
        fi
        sleep 5
    done
LAUNCHER
            else
                # Worker agent тАФ waits for a trigger file, then starts Claude with its contents
                sed 's/^    //' > "$PROMPT_DIR/run-${agent}.sh" << LAUNCHER
    #!/bin/bash
    cd '${REPO_DIR}'
    printf '\033]0;${label}\007'
    SYSTEM_PROMPT=\$(cat '${PROMPT_DIR}/${agent}-system.txt')
    TRIGGER_DIR='${PROMPT_DIR}/triggers'
    mkdir -p "\$TRIGGER_DIR"
    TRIGGER_FILE="\$TRIGGER_DIR/${agent}.trigger"
    
    echo "тХФтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХЧ"
    echo "тХС  ${label} agent"
    echo "тХС  Idle тАФ waiting for messages..."
    echo "тХЪтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХЭ"
    echo ""
    
    # Event-driven loop: wait for trigger file, start Claude with its contents
    while true; do
        if [ -f "\$TRIGGER_FILE" ]; then
            # Move trigger to a work file so new messages don't collide
            WORK_FILE="\$TRIGGER_DIR/${agent}.msg"
            if ! mv "\$TRIGGER_FILE" "\$WORK_FILE" 2>/dev/null; then
                echo "--- [\$(date '+%H:%M:%S')] WARNING: trigger file vanished before pickup (race condition) ---"
                continue
            fi

            # ACK: confirm message pickup so sender knows we got it
            printf '%s\n' "ACK \$(date '+%H:%M:%S')" > "\$TRIGGER_DIR/${agent}.ack"

            if [ -s "\$WORK_FILE" ]; then
                PREVIEW=\$(head -c 200 "\$WORK_FILE")
                echo ""
                echo "--- [\$(date '+%H:%M:%S')] Received message (\$(wc -c < "\$WORK_FILE" | tr -d ' ') bytes) ---"
                echo "    \${PREVIEW:0:200}..."
                echo ""
                # Clean done-sent marker from previous run
                rm -f "\$TRIGGER_DIR/${agent}.done-sent"
                # Pipe from file to avoid CLI argument length limits on long messages
                cat "\$WORK_FILE" | claude -p --append-system-prompt "\$SYSTEM_PROMPT" --allowedTools "${allowed_tools}" -n "${agent}"
                echo ""
                # Auto-notify: only send DONE if the agent didn't already send it
                if [ ! -f "\$TRIGGER_DIR/${agent}.done-sent" ]; then
                    '${PROMPT_DIR}/send-to-agent.sh' '${auto_start_label}' "DONE-${agent}: Task completed (auto-notify)"
                    echo "--- [\$(date '+%H:%M:%S')] Auto-sent DONE-${agent} to ${auto_start_agent} ---"
                else
                    echo "--- [\$(date '+%H:%M:%S')] Agent already sent DONE тАФ skipping auto-notify ---"
                fi
                rm -f "\$TRIGGER_DIR/${agent}.done-sent"
                echo "--- [\$(date '+%H:%M:%S')] Session ended. Waiting for next message... ---"
                echo ""
            else
                echo "--- [\$(date '+%H:%M:%S')] WARNING: trigger file was empty тАФ skipping ---" >&2
            fi
            rm -f "\$WORK_FILE"
        else
            sleep 1
        fi
    done
LAUNCHER
            fi
        fi
        chmod +x "$PROMPT_DIR/run-${agent}.sh"
    }
    
    # ==================== Generate All Prompts & Launchers ====================
    
    echo "Reading workflow.yaml..."
    echo "  Project: ${PROJECT_NAME}"
    echo "  Ticket source: ${TICKET_SOURCE}"
    echo "  Agents: ${AGENTS[*]}"
    echo ""
    
    for agent in "${AGENTS[@]}"; do
        generate_system_prompt "$agent"
        generate_init_prompt "$agent"
        generate_launcher "$agent"
    done
    
    # ==================== Cleanup Previous Sessions ====================
    
    echo "Cleaning up previous agent sessions..."

    # Remove stale trigger files from previous runs
    rm -rf "$PROMPT_DIR/triggers" 2>/dev/null || true

    CLEANUP_NAMES=""
    for agent in "${AGENTS[@]}"; do
        label=$(echo "$agent" | tr '[:lower:]' '[:upper:]')
        CLEANUP_NAMES+="\"${label}\", "
    done
    CLEANUP_NAMES+="\"LOGS\""
    
    osascript << ENDSCRIPT 2>/dev/null || true
    tell application "iTerm2"
        set agentNames to {${CLEANUP_NAMES}}
        repeat with w in windows
            repeat with t in tabs of w
                repeat with s in sessions of t
                    if name of s is in agentNames then
                        tell s
                            write text (ASCII character 3)
                            write text "exit"
                        end tell
                    end if
                end repeat
            end repeat
        end repeat
    end tell
ENDSCRIPT
    sleep 2
    
    # ==================== Ensure Ticket Source Labels ====================
    
    if [ "$TICKET_SOURCE" = "github" ]; then
        echo "Ensuring GitHub labels exist..."
        local_repo=$(yq_get '.tickets.github.repo // .project.repo')
        gh label create "$(yq_get '.tickets.github.labels.ready')" --color "0E8A16" --description "Ready for agent team" --repo "$local_repo" 2>/dev/null || true
        gh label create "$(yq_get '.tickets.github.labels.in_progress')" --color "FBCA04" --description "Agent team working" --repo "$local_repo" 2>/dev/null || true
        gh label create "$(yq_get '.tickets.github.labels.done')" --color "6F42C1" --description "Agent team completed" --repo "$local_repo" 2>/dev/null || true
    
        if [ -n "$ISSUE_NUM" ]; then
            gh issue edit "$ISSUE_NUM" --repo "$local_repo" --add-label "$(yq_get '.tickets.github.labels.ready')" 2>/dev/null || true
        fi
    fi
    
    # ==================== Debug: Logging Scripts ====================
    
    if [ "$DEBUG_MODE" = true ]; then
    
    # Build agent list for Python logger
    AGENT_PY_LIST=""
    AGENT_PY_COLORS=""
    AGENT_PY_LABELS=""
    COLOR_CODES=("35" "34" "32" "33" "31" "36" "37" "91" "92" "93")
    SHORT_LABELS=("PM" "ARCH" "BACK" "FRONT" "QA" "DEV" "OPS" "SEC" "DOC" "INF")
    idx=0
    for agent in "${AGENTS[@]}"; do
        label=${SHORT_LABELS[$idx]:-$(echo "$agent" | tr '[:lower:]' '[:upper:]' | cut -c1-4)}
        color=${COLOR_CODES[$idx]:-37}
        AGENT_PY_LIST+="\"${agent}\", "
        AGENT_PY_COLORS+="    \"${agent}\": \"\\033[${color}m\",\n"
        AGENT_PY_LABELS+="    \"${agent}\": \"${label}\",\n"
        ((idx++))
    done
    
    sed 's/^    //' > "$PROMPT_DIR/screen-logger.py" << PYLOGGER
    #!/usr/bin/env python3
    """
    Polls iTerm2 session screen contents every 2 seconds and writes
    filtered, formatted lines to per-agent log files. Filters out noise
    (bash/sleep, tips), emphasizes inter-agent messages and test failures,
    collapses polling waits, and sends iTerm2 notifications.
    """
    import iterm2
    import asyncio
    import os
    import re
    import subprocess
    import time
    
    LOG_DIR = "${LOG_DIR}"
    POLL_INTERVAL = 2
    
    AGENTS = [${AGENT_PY_LIST}]
    
    COLORS = {
    $(printf '%b' "$AGENT_PY_COLORS")}
    BOLD = "\033[1m"
    RESET = "\033[0m"
    LABELS = {
    $(printf '%b' "$AGENT_PY_LABELS")}
    
    # тФАтФА Filtering patterns тФАтФА
    SKIP_PATTERNS = [
        r"^\s*\$\s*$",
        r"Bash\s*\(\s*sleep",
        r"^\s*sleep\s+\d+",
        r"^Tip:",
        r"^ЁЯТб\s*Tip",
        r"^\s*тХнтФА+тХо\s*$",
        r"^\s*тФВ.*Tip.*тФВ\s*$",
        r"^\s*тХ░тФА+тХп\s*$",
        r"^Waiting for input\.\.\.",
        r"^>\s*$",
        r"find tasks.*work on them",
        r"You may also receive TASK:",
        r"polling loop",
        r"resume polling",
        r"Run TaskList.*find tasks",
    ]
    SKIP_RE = [re.compile(p, re.IGNORECASE) for p in SKIP_PATTERNS]
    
    AGENT_MSG_PATTERNS = [
        re.compile(r"TASK\s*(\[|:)", re.IGNORECASE),
        re.compile(r"BUG\s*:", re.IGNORECASE),
        re.compile(r"COMPLETE\s*:", re.IGNORECASE),
        re.compile(r"send-to-agent\.sh", re.IGNORECASE),
        re.compile(r"Done-\w+", re.IGNORECASE),
        re.compile(r"DONE-\w+", re.IGNORECASE),
        re.compile(r"REVIEW-REQUEST", re.IGNORECASE),
        re.compile(r"REVIEW-APPROVED", re.IGNORECASE),
        re.compile(r"REVIEW-REJECTED", re.IGNORECASE),
    ]
    
    TEST_FAIL_PATTERNS = [
        re.compile(r"FAILED", re.IGNORECASE),
        re.compile(r"FAIL[:\s]", re.IGNORECASE),
        re.compile(r"Error:.*test", re.IGNORECASE),
        re.compile(r"AssertionError", re.IGNORECASE),
        re.compile(r"\d+ failed", re.IGNORECASE),
        re.compile(r"ERRORS?!", re.IGNORECASE),
        re.compile(r"test.*failed", re.IGNORECASE),
    ]
    
    ACCEPT_EDIT_RE = re.compile(r"(allow|accept)\s*(edit|once|always)", re.IGNORECASE)
    
    WAITING_PATTERNS = [
        re.compile(r"No tasks?\.\s*Will check", re.IGNORECASE),
        re.compile(r"Polling for work", re.IGNORECASE),
        re.compile(r"no.*pending.*task", re.IGNORECASE),
        re.compile(r"NO_TASKS", re.IGNORECASE),
        re.compile(r"Run TaskList", re.IGNORECASE),
        re.compile(r"Session ended\. Restarting", re.IGNORECASE),
        re.compile(r"sleep\s+\d+.*then.*check", re.IGNORECASE),
        re.compile(r"TaskList.*no.*tasks", re.IGNORECASE),
    ]
    
    def should_skip(line): return any(p.search(line) for p in SKIP_RE)
    def is_agent_message(line): return any(p.search(line) for p in AGENT_MSG_PATTERNS)
    def is_test_failure(line): return any(p.search(line) for p in TEST_FAIL_PATTERNS)
    def is_accept_edit(line): return bool(ACCEPT_EDIT_RE.search(line))
    def is_waiting(line): return any(p.search(line) for p in WAITING_PATTERNS)
    
    def send_notification(title, message):
        try:
            subprocess.Popen(
                ["osascript", "-e",
                 f'display notification "{message}" with title "{title}" sound name "Glass"'],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        except Exception:
            pass
    
    async def main(connection):
        app = await iterm2.async_get_app(connection)
        sessions = {}
        for window in app.windows:
            for tab in window.tabs:
                for session in tab.sessions:
                    name = await session.async_get_variable("name")
                    if name is None: continue
                    name_lower = name.lower()
                    for agent in AGENTS:
                        if agent in name_lower and agent not in sessions:
                            sessions[agent] = session
                            break
    
        if not sessions:
            print("No agent sessions found. Retrying in 5s...")
            await asyncio.sleep(5)
            return
    
        print(f"Logging {len(sessions)} sessions (polling every {POLL_INTERVAL}s)")
        print()
    
        log_files = {}
        for agent in sessions:
            log_files[agent] = open(os.path.join(LOG_DIR, f"{agent}.log"), "a", buffering=1)
    
        prev_contents = {agent: "" for agent in sessions}
        waiting_since = {}
        last_notif = {}
    
        while True:
            for agent, session in sessions.items():
                try:
                    contents = await session.async_get_screen_contents()
                    lines = []
                    for i in range(contents.number_of_lines):
                        lines.append(contents.line(i).string.rstrip())
                    current = "\n".join(lines)
                    if current != prev_contents[agent]:
                        prev_lines = prev_contents[agent].split("\n") if prev_contents[agent] else []
                        new_lines = lines[len(prev_lines):] if len(lines) > len(prev_lines) else lines
                        new_lines = [l for l in new_lines if l.strip()]
                        if not new_lines:
                            prev_contents[agent] = current
                            continue
                        color = COLORS.get(agent, "")
                        label = LABELS.get(agent, agent.upper())
                        now = time.time()
                        for line in new_lines:
                            if should_skip(line): continue
                            if is_waiting(line):
                                if agent not in waiting_since: waiting_since[agent] = now
                                elapsed = int(now - waiting_since[agent])
                                print(f"\r{color}[{label}]{RESET} тП│ Waiting for tasks ({elapsed}s)...", end="", flush=True)
                                continue
                            else:
                                if agent in waiting_since:
                                    elapsed = int(now - waiting_since[agent])
                                    print(f"\r{color}[{label}]{RESET} тП│ Done waiting ({elapsed}s)", flush=True)
                                    log_files[agent].write(f"тП│ Waited for tasks ({elapsed}s)\n")
                                    del waiting_since[agent]
                            if is_accept_edit(line):
                                log_files[agent].write("тЬПя╕П  User accepted edit\n")
                                print(f"{color}[{label}]{RESET} тЬПя╕П  User accepted edit", flush=True)
                                continue
                            if is_agent_message(line):
                                log_files[agent].write(f"ЁЯУи {line}\n")
                                print(f"{BOLD}{color}[{label}]{RESET} {BOLD}ЁЯУи {line}{RESET}", flush=True)
                                if now - last_notif.get(agent, 0) > 10:
                                    send_notification(f"ЁЯдЦ {label}", line[:120])
                                    last_notif[agent] = now
                                continue
                            if is_test_failure(line):
                                log_files[agent].write(f"тЭМ {line}\n")
                                print(f"{BOLD}{color}[{label}]{RESET} {BOLD}тЭМ {line}{RESET}", flush=True)
                                if now - last_notif.get(f"{agent}_fail", 0) > 10:
                                    send_notification(f"тЭМ Test Failed тАФ {label}", line[:120])
                                    last_notif[f"{agent}_fail"] = now
                                continue
                            log_files[agent].write(line + "\n")
                            print(f"{color}[{label}]{RESET} {line}", flush=True)
                        prev_contents[agent] = current
                except Exception:
                    pass
            await asyncio.sleep(POLL_INTERVAL)
    
    iterm2.run_until_complete(main)
PYLOGGER
    chmod +x "$PROMPT_DIR/screen-logger.py"
    
    # LOGS pane launcher
    sed 's/^    //' > "$PROMPT_DIR/run-logs.sh" << LOGSCRIPT
    #!/bin/bash
    echo "тХФтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХЧ"
    echo "тХС       ЁЯУЭ TEAM LOGS (filtered)        тХС"
    echo "тХС  ЁЯУи agent msgs  тЭМ test fails        тХС"
    echo "тХС  тЬПя╕П  edits  тП│ waiting                тХС"
    echo "тХатХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХг"
    $(idx=0; for agent in "${AGENTS[@]}"; do
        label=${SHORT_LABELS[$idx]:-$(echo "$agent" | tr '[:lower:]' '[:upper:]' | cut -c1-4)}
        echo "echo \"тХС  ${label} \"";
        ((idx++));
    done)
    echo "тХЪтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХЭ"
    echo ""
    echo "Waiting for agent sessions to start..."
    sleep 5
    exec python3 '${PROMPT_DIR}/screen-logger.py'
LOGSCRIPT
    chmod +x "$PROMPT_DIR/run-logs.sh"
    
    fi  # end DEBUG_MODE scripts
    
    # ==================== Launch Info ====================
    
    echo "=========================================="
    echo "  Launching Agent Team in iTerm2"
    [ "$TEST_MODE" = true ] && echo "  MODE: TEST (mock issue, no ticket source)"
    [ -n "$ISSUE_NUM" ] && echo "  Ticket #${ISSUE_NUM} queued for architect"
    [ "$DEBUG_MODE" = true ] && echo "  DEBUG: Logging enabled тЖТ ${LOG_DIR}"
    echo "=========================================="
    echo ""
    
    # ==================== AppleScript: Dynamic Layout ====================
    
    NUM_WORKERS=${#WORKER_AGENTS[@]}
    ROWS=$(( (NUM_WORKERS + 1) / 2 ))
    
    # Build the AppleScript dynamically
    build_applescript() {
        local as=""
        as+='tell application "iTerm2"\n'
        as+='    activate\n'
        as+='    set newWindow to (create window with default profile)\n'
        as+='    tell newWindow\n'
    
        # Interactive agent (left, full height)
        local int_label
        int_label=$(echo "$INTERACTIVE_AGENT" | tr '[:lower:]' '[:upper:]')
        as+="        tell current session\n"
        as+="            set name to \"${int_label}\"\n"
        as+="            set worker0Session to (split vertically with default profile)\n"
        as+="        end tell\n"
    
        # First worker тАФ split vertically to create column pairs
        local w0_label
        w0_label=$(echo "${WORKER_AGENTS[0]}" | tr '[:lower:]' '[:upper:]')
        as+="        tell worker0Session\n"
        as+="            set name to \"${w0_label}\"\n"
    
        if [ "$NUM_WORKERS" -ge 2 ]; then
            as+="            set worker1Session to (split vertically with default profile)\n"
        fi
        if [ "$DEBUG_MODE" = true ] && [ "$NUM_WORKERS" -ge 2 ]; then
            # Need LOGS column тАФ split from the rightmost worker
            :
        fi
        as+="        end tell\n"
    
        # Second worker (right column top)
        if [ "$NUM_WORKERS" -ge 2 ]; then
            local w1_label
            w1_label=$(echo "${WORKER_AGENTS[1]}" | tr '[:lower:]' '[:upper:]')
            as+="        tell worker1Session\n"
            as+="            set name to \"${w1_label}\"\n"
            if [ "$DEBUG_MODE" = true ]; then
                as+="            set logsSession to (split vertically with default profile)\n"
            fi
            as+="        end tell\n"
    
            if [ "$DEBUG_MODE" = true ]; then
                as+="        tell logsSession\n"
                as+="            set name to \"LOGS\"\n"
                as+="        end tell\n"
            fi
        fi
    
        # Split first worker horizontally for 3rd worker (bottom-left of grid)
        if [ "$NUM_WORKERS" -ge 3 ]; then
            local w2_label
            w2_label=$(echo "${WORKER_AGENTS[2]}" | tr '[:lower:]' '[:upper:]')
            as+="        tell worker0Session\n"
            as+="            set worker2Session to (split horizontally with default profile)\n"
            as+="        end tell\n"
            as+="        tell worker2Session\n"
            as+="            set name to \"${w2_label}\"\n"
            as+="        end tell\n"
        fi
    
        # Split second worker horizontally for 4th worker (bottom-right of grid)
        if [ "$NUM_WORKERS" -ge 4 ]; then
            local w3_label
            w3_label=$(echo "${WORKER_AGENTS[3]}" | tr '[:lower:]' '[:upper:]')
            as+="        tell worker1Session\n"
            as+="            set worker3Session to (split horizontally with default profile)\n"
            as+="        end tell\n"
            as+="        tell worker3Session\n"
            as+="            set name to \"${w3_label}\"\n"
            as+="        end tell\n"
        fi
    
        # Workers 5+ тАФ split from previous row
        local widx=4
        while [ $widx -lt "$NUM_WORKERS" ]; do
            local wn_label prev_idx
            wn_label=$(echo "${WORKER_AGENTS[$widx]}" | tr '[:lower:]' '[:upper:]')
            prev_idx=$((widx - 2))
            as+="        tell worker${prev_idx}Session\n"
            as+="            set worker${widx}Session to (split horizontally with default profile)\n"
            as+="        end tell\n"
            as+="        tell worker${widx}Session\n"
            as+="            set name to \"${wn_label}\"\n"
            as+="        end tell\n"
            ((widx++))
        done
    
        # Launch scripts in each pane
        as+="\n        -- Launch agents\n"
        as+="        tell current session\n"
        as+="            write text \"'${PROMPT_DIR}/run-${INTERACTIVE_AGENT}.sh'\"\n"
        as+="        end tell\n"
    
        for i in "${!WORKER_AGENTS[@]}"; do
            local w="${WORKER_AGENTS[$i]}"
            if [ "$i" = "0" ]; then
                as+="        tell worker0Session\n"
            elif [ "$i" = "1" ]; then
                as+="        tell worker1Session\n"
            else
                as+="        tell worker${i}Session\n"
            fi
            as+="            write text \"'${PROMPT_DIR}/run-${w}.sh'\"\n"
            as+="        end tell\n"
        done
    
        if [ "$DEBUG_MODE" = true ] && [ "$NUM_WORKERS" -ge 2 ]; then
            as+="        tell logsSession\n"
            as+="            write text \"'${PROMPT_DIR}/run-logs.sh'\"\n"
            as+="        end tell\n"
        fi
    
        as+="    end tell\n"
        as+='    set bounds of newWindow to {0, 0, 9999, 9999}\n'
        as+="end tell\n"
    
        printf '%b' "$as"
    }
    
    osascript <<< "$(build_applescript)"
    
    # ==================== Post-launch Info ====================
    
    echo ""
    echo "Team launched! (${#AGENTS[@]} agents)"
    echo ""
    echo "  PM commands:"
    while IFS= read -r cmd; do
        echo "    тАв ${cmd}"
    done < <(yq_get ".agents.${INTERACTIVE_AGENT}.commands // {} | keys | .[]" | head -8)
    echo ""
    echo "  Navigation:"
    echo "    тАв Cmd+[ / Cmd+]     тЖТ Switch panes"
    echo "    тАв Cmd+Shift+Enter   тЖТ Zoom a pane"
}

# ==================== Dispatch ====================

case "${1:-}" in
    start)          shift; cmd_start "$@" ;;
    init)           cmd_init ;;
    validate)       cmd_validate ;;
    analyze)        shift; cmd_analyze "$@" ;;
    stop)           cmd_stop ;;
    version)        cmd_version ;;
    --version|-v)   cmd_version ;;
    --help|-h|help|"") show_help ;;
    *) echo "Unknown command: $1"; show_help; exit 1 ;;
esac
